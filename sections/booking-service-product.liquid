{% comment %}
  Booking service product section for property field services.
  Used by templates/product.booking-service.json.
{% endcomment %}

{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

{%- assign from_price = product.price_min | money -%}
{%- assign booking_page_url = '/pages/book-property-service' -%}
{%- case product.handle -%}
  {%- when 'property-condition-report' -%}
    {%- assign booking_page_url = '/pages/book-property-condition-report' -%}
  {%- when 'routine-inspection' -%}
    {%- assign booking_page_url = '/pages/book-routine-inspection' -%}
  {%- when 'exit-inspection' -%}
    {%- assign booking_page_url = '/pages/book-exit-inspection' -%}
  {%- when 'open-for-inspection-support' -%}
    {%- assign booking_page_url = '/pages/book-open-for-inspection-support' -%}
  {%- when 'maintenance-request-support' -%}
    {%- assign booking_page_url = '/pages/book-maintenance-request-support' -%}
  {%- when 'insurance-claims-management' -%}
    {%- assign booking_page_url = '/pages/book-insurance-claims-management' -%}
  {%- when 'key-installation' -%}
    {%- assign booking_page_url = '/pages/book-key-installation' -%}
{%- endcase -%}

<style>
  .booking-service-wrap { max-width: var(--page-width); margin: 0 auto; padding: 3rem 1.5rem 5rem; }
  .booking-service-hero { display: grid; grid-template-columns: minmax(0, 1fr); gap: 2rem; }
  @media screen and (min-width: 990px) { .booking-service-hero { grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr); align-items: start; } }
  .booking-service-panel { background: rgb(var(--color-background)); border-radius: var(--text-boxes-radius); padding: 2.4rem; box-shadow: 0 0 0 .1rem rgba(var(--color-foreground), .08); }
  .booking-service-eyebrow { text-transform: uppercase; letter-spacing: .13rem; font-size: 1.2rem; margin: 0 0 1rem; opacity: .75; }
  .booking-service-card { background: rgba(var(--color-foreground), .04); border-radius: var(--cards-radius); padding: 2rem; margin-top: 1.6rem; }
  .booking-service-card h3 { margin-top: 0; }
  .booking-service-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .booking-service-price { font-size: 2.2rem; font-weight: 700; margin: 1.2rem 0; }
  .booking-service-description { margin-top: 3rem; }
  .booking-service-description table { width: 100%; }
</style>

<div class="booking-service-wrap color-{{ section.settings.color_scheme }} gradient">
  <div class="booking-service-hero">
    <div class="booking-service-panel">
      <p class="booking-service-eyebrow">Property field service</p>
      <h1 class="product__title {{ section.settings.heading_size }}">{{ product.title | escape }}</h1>
      <p class="booking-service-price">From {{ from_price }}</p>
      <p>Final price depends on the booking time selected. The exact price is confirmed after your booking time is selected and before Shopify checkout.</p>

      <div class="booking-service-card">
        <h3>Booking-first checkout</h3>
        <p>Submit the booking details first. Your selected appointment slot or request is held or reviewed before payment. The booking is only confirmed once payment is completed through Shopify checkout.</p>
      </div>

      <div class="booking-service-card">
        <h3>Booking time pricing</h3>
        <p>This service uses time-based pricing: Standard Hours, After Hours, Saturdays, Sundays and Western Australia public holidays.</p>
      </div>

      <div class="booking-service-actions">
        <a class="button button--primary" href="{{ booking_page_url }}?product={{ product.handle }}">Book Now</a>
        <a class="button button--secondary" href="/pages/how-property-service-bookings-work">How booking works</a>
      </div>
    </div>

    <div class="booking-service-panel">
      <h2>Before you book</h2>
      <ul>
        <li>The selected booking slot may be held temporarily while payment is completed.</li>
        <li>Payment through Shopify checkout is required before the booking is confirmed.</li>
        <li>The Shopify order is fulfilled after the report, photos, attendance summary or service evidence is delivered.</li>
        <li>Some requests may require review before final timing is confirmed.</li>
      </ul>
    </div>
  </div>

  <div class="booking-service-description rte">
    {{ product.description }}
  </div>
</div>

{% schema %}
{
  "name": "Booking service product",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    }
  ],
  "presets": [
    {
      "name": "Booking service product"
    }
  ]
}
{% endschema %}
