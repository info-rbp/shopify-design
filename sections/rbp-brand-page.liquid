n-g{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.24)}.rbp-brandpg-btn-o{background:#fff;color:var(--s7);border-color:var(--br2)}.rbp-brandpg-proof{display:flex;flex-wrap:wrap;gap:14px 20px;margin-top:26px}.rbp-brandpg-proof span{display:inline-flex;align-items:center;gap:8px;color:#cbd5e1;font-size:14px;font-weight:750}.rbp-brandpg-check{width:18px;height:18px;border-radius:999px;display:inline-grid;place-items:center;background:#3b82f6;color:#fff;font-size:12px;line-height:1;flex:0 0 auto}.rbp-brandpg-card{background:#fff;border:1px solid var(--br);border-radius:24px;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-brandpg-hero-card{border:1px solid rgba(255,255,255,.14);border-radius:28px;background:rgba(255,255,255,.08);box-shadow:0 35px 75px rgba(30,64,175,.32);padding:26px}.rbp-brandpg-hero-card h3{margin:0 0 12px;color:#fff;font-size:22px;font-weight:900}.rbp-brandpg-hero-card p{margin:0;color:#cbd5e1;line-height:1.7}.rbp-brandpg-sec{padding:74px 0}.rbp-brandpg-muted{background:#f8fafc}.rbp-brandpg-head{max-width:780px;margin:0 auto 36px;text-align:center}.rbp-brandpg-grid{display:grid;gap:20px}.rbp-brandpg-g2{grid-template-columns:repeat(2,minmax(0,1fr))}.rbp-brandpg-g3{grid-template-columns:repeat(3,minmax(0,1fr))}.rbp-brandpg-g4{grid-template-columns:repeat(4,minmax(0,1fr))}.rbp-brandpg-icon{width:46px;height:46px;border-radius:16px;display:grid;place-items:center;margin-bottom:16px;background:#dbeafe;color:#1d4ed8;font-weight:900}.rbp-brandpg-title{margin:0 0 8px;color:#0f172a;font-size:18px;font-weight:900}.rbp-brandpg-text,.rbp-brandpg-rich,.rbp-brandpg-rich p,.rbp-brandpg-rich li{margin:0;color:#64748b;line-height:1.65;font-size:14px}.rbp-brandpg-list{display:grid;gap:10px;margin:18px 0 0;padding:0;list-style:none}.rbp-brandpg-list li{display:grid;grid-template-columns:22px minmax(0,1fr);gap:10px;color:#64748b;line-height:1.55;font-size:14px}.rbp-brandpg-blue{background:linear-gradient(135deg,#1d4ed8,#1e3a8a);color: