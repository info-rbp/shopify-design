{%- liquid
 assign eyebrow='About Remote Business Partner'
 assign summary='Remote Business Partner exists to give business owners practical support, structured resources and clearer pathways for documents, services, membership and operational growth.'
 assign hero_title='Business support with structure, not noise'
 assign hero_text='We bring practical business services, document pathways, member support and operational resources into one connected platform.'
 assign mission='To make business support easier to access, easier to understand and easier to act on.'
 assign purpose='We help business owners move from uncertainty to practical next steps through documents, advisory support, managed services, resources and membership pathways.'
 assign platform='Remote Business Partner connects service pathways, document products, membership, support resources and marketplace opportunities in one structured business ecosystem.'
 if page.handle == 'our-purpose'
  assign eyebrow='Our Purpose'
  assign summary='Our purpose is to reduce business friction by giving owners clearer access to practical support, documents, guidance and operational pathways.'
  assign hero_title='Built to help business owners move forward'
  assign hero_text='The purpose behind Remote Business Partner is simple: make useful business support easier to find, understand and use.'
  assign mission='To help small businesses make decisions, build structure and access support without getting buried under jargon, confusion or disconnected services.'
  assign purpose='We exist for business owners who need a practical partner, not another vague resource library wearing a motivational quote.'
 elsif page.handle == 'our-platform'
  assign eyebrow='Our Platform'
  assign summary='Our platform brings together business services, document products, marketplace pathways, membership support and Help Center resources.'
  assign hero_title='A connected business support platform'
  assign hero_text='Remote Business Partner is designed as a structured ecosystem for documents, services, membership, resources and business support pathways.'
  assign mission='To connect the moving parts of business support into a platform that is easier to navigate and use.'
  assign platform='The platform combines on-demand services, managed services, applications, document products, Help Center content, membership pathways and marketplace opportunities.'
 endif
-%}
<div class="rbp-brandpg">
<section class="rbp-brandpg-hero"><div class="rbp-brandpg-c"><div class="rbp-brandpg-hero-in"><div><div class="rbp-brandpg-ey"><span class="rbp-brandpg-dot"></span>{{ eyebrow }}</div><h1 class="rbp-brandpg-h1">{{ page.title }}</h1><p class="rbp-brandpg-p">{{ summary }}</p><div class="rbp-brandpg-actions"><a class="rbp-brandpg-btn rbp-brandpg-btn-p" href="/pages/contact">Contact us -&gt;</a><a class="rbp-brandpg-btn rbp-brandpg-btn-g" href="/pages/our-platform">Explore the platform</a></div><div class="rbp-brandpg-proof"><span><span class="rbp-brandpg-check">✓</span>Business-owner focused</span><span><span class="rbp-brandpg-check">✓</span>Practical support pathways</span><span><span class="rbp-brandpg-check">✓</span>Connected resources</span></div></div><aside class="rbp-brandpg-hero-card"><h3>{{ hero_title }}</h3><p>{{ hero_text }}</p></aside></div></div></section>
