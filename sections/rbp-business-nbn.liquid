<style>
/* ─── RBP NBN Design Tokens ─────────────────────────────────────── */
.rbp-nbn {
  --nbn-navy:      #0f172a;
  --nbn-teal:      #0d9488;
  --nbn-teal-mid:  #0f766e;
  --nbn-teal-pale: #ccfbf1;
  --nbn-cyan:      #06b6d4;
  --nbn-cyan-pale: #cffafe;
  --nbn-blue:      #1d4ed8;
  --nbn-blue-pale: #dbeafe;
  --nbn-amber:     #d97706;
  --nbn-amber-pale:#fef3c7;
  --nbn-green:     #059669;
  --nbn-green-pale:#d1fae5;
  --nbn-red:       #dc2626;
  --nbn-red-pale:  #fee2e2;
  --nbn-slate-9:   #0f172a;
  --nbn-slate-7:   #334155;
  --nbn-slate-6:   #475569;
  --nbn-slate-4:   #94a3b8;
  --nbn-slate-2:   #e2e8f0;
  --nbn-slate-1:   #f1f5f9;
  --nbn-slate-0:   #f8fafc;
  --nbn-white:     #ffffff;
  --nbn-radius:    16px;
  --nbn-radius-lg: 24px;
  --nbn-shadow:    0 4px 24px rgba(15,23,42,.10);
  --nbn-shadow-lg: 0 16px 56px rgba(15,23,42,.14);
  background: var(--nbn-white); color: var(--nbn-slate-9);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}
.rbp-nbn *, .rbp-nbn *::before, .rbp-nbn *::after { box-sizing: border-box; margin: 0; }
.rbp-nbn a { text-decoration: none; color: inherit; }
.rbp-nbn ul { list-style: none; padding: 0; }
.rbp-nbn-c { width: min(100% - 2.5rem, 1260px); margin-inline: auto; }
.rbp-nbn-sec { padding: 88px 0; }
.rbp-nbn-sec-sm { padding: 56px 0; }
.rbp-nbn-muted { background: var(--nbn-slate-0); }
.rbp-nbn-teal-bg {
  background: radial-gradient(ellipse 80% 60% at 80% 30%, rgba(13,148,136,.2), transparent 60%),
              radial-gradient(ellipse 50% 70% at 10% 80%, rgba(6,182,212,.14), transparent 55%),
              linear-gradient(145deg, #0f172a 0%, #134e4a 50%, #0f172a 100%);
  color: var(--nbn-white);
}

/* ─── Eyebrow ────────────────────────────────────────────────────── */
.rbp-nbn-eye {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; border-radius: 999px;
  font-size: 11px; font-weight: 800; letter-spacing: .10em; text-transform: uppercase;
  background: var(--nbn-teal-pale); color: var(--nbn-teal);
}
.rbp-nbn-eye--white { background: rgba(255,255,255,.14); color: rgba(255,255,255,.9); border: 1px solid rgba(255,255,255,.22); }
.rbp-nbn-eye--amber { background: var(--nbn-amber-pale); color: var(--nbn-amber); }
.rbp-nbn-eye--green { background: var(--nbn-green-pale); color: var(--nbn-green); }
.rbp-nbn-eye-dot { width: 6px; height: 6px; border-radius: 999px; background: currentColor; animation: nbn-pulse 2s infinite; }
@keyframes nbn-pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

/* ─── Headings ───────────────────────────────────────────────────── */
.rbp-nbn-h1 { font-size: clamp(40px,6vw,76px); font-weight: 900; line-height: 1.0; letter-spacing: -.045em; color: var(--nbn-white); }
.rbp-nbn-h2 { font-size: clamp(28px,4vw,50px); font-weight: 900; line-height: 1.05; letter-spacing: -.035em; }
.rbp-nbn-h3 { font-size: 20px; font-weight: 800; line-height: 1.2; letter-spacing: -.02em; }
.rbp-nbn-p  { font-size: 16px; line-height: 1.75; color: var(--nbn-slate-6); }
.rbp-nbn-head { text-align: center; max-width: 760px; margin: 0 auto 56px; }
.rbp-nbn-head .rbp-nbn-eye { margin-bottom: 16px; }
.rbp-nbn-head .rbp-nbn-h2 { margin: 12px 0 16px; }

/* ─── Hero ───────────────────────────────────────────────────────── */
.rbp-nbn-hero { position: relative; overflow: hidden; }
.rbp-nbn-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%2306b6d4' fill-opacity='0.04'%3E%3Ccircle cx='40' cy='40' r='3'/%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
.rbp-nbn-hero-in {
  display: grid;
  grid-template-columns: minmax(0,1fr) minmax(360px,.85fr);
  gap: 60px; align-items: center;
  padding: 96px 0 80px; min-height: 580px;
}
.rbp-nbn-hero-text .rbp-nbn-eye { margin-bottom: 20px; }
.rbp-nbn-hero-text .rbp-nbn-h1 { margin-bottom: 18px; }
.rbp-nbn-hero-text .rbp-nbn-p { color: #94a3b8; font-size: 18px; max-width: 560px; margin-bottom: 32px; }

/* ─── Hero speed card ────────────────────────────────────────────── */
.rbp-nbn-speed-card {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.14);
  backdrop-filter: blur(24px);
  border-radius: var(--nbn-radius-lg);
  padding: 36px 32px; position: relative; overflow: hidden;
}
.rbp-nbn-speed-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 4px;
  background: linear-gradient(90deg, var(--nbn-cyan), var(--nbn-teal));
}
.rbp-nbn-speed-label { font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: #94a3b8; margin-bottom: 8px; }
.rbp-nbn-speed-num { font-size: 56px; font-weight: 900; color: var(--nbn-white); letter-spacing: -.05em; line-height: 1; }
.rbp-nbn-speed-unit { font-size: 18px; font-weight: 700; color: #94a3b8; margin-left: 4px; }
.rbp-nbn-speed-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin: 24px 0; padding: 24px 0; border-top: 1px solid rgba(255,255,255,.08); border-bottom: 1px solid rgba(255,255,255,.08); }
.rbp-nbn-speed-stat { text-align: center; }
.rbp-nbn-speed-stat-num { font-size: 24px; font-weight: 900; color: var(--nbn-white); }
.rbp-nbn-speed-stat-label { font-size: 12px; color: #64748b; margin-top: 2px; }
.rbp-nbn-tech-badges { display: flex; flex-wrap: wrap; gap: 8px; }
.rbp-nbn-tech-badge {
  padding: 5px 12px; border-radius: 999px;
  font-size: 11px; font-weight: 800; letter-spacing: .06em;
  background: rgba(255,255,255,.08); color: #94a3b8; border: 1px solid rgba(255,255,255,.12);
}
.rbp-nbn-tech-badge--active { background: rgba(13,148,136,.2); color: #5eead4; border-color: rgba(13,148,136,.3); }

/* ─── Buttons ────────────────────────────────────────────────────── */
.rbp-nbn-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 14px 24px; border-radius: 12px; border: none;
  font-size: 14px; font-weight: 800; cursor: pointer; line-height: 1;
  transition: all .2s ease; white-space: nowrap; text-decoration: none;
}
.rbp-nbn-btn--teal   { background: var(--nbn-teal); color: var(--nbn-white); box-shadow: 0 8px 24px rgba(13,148,136,.3); }
.rbp-nbn-btn--teal:hover { background: var(--nbn-teal-mid); transform: translateY(-1px); }
.rbp-nbn-btn--ghost  { background: transparent; color: var(--nbn-slate-7); border: 1.5px solid var(--nbn-slate-2); }
.rbp-nbn-btn--ghost:hover { background: var(--nbn-slate-1); }
.rbp-nbn-btn--white  { background: var(--nbn-white); color: var(--nbn-teal); }
.rbp-nbn-btn--white:hover { background: var(--nbn-teal-pale); }
.rbp-nbn-btn--sm { padding: 10px 18px; font-size: 13px; }
.rbp-nbn-actions { display: flex; flex-wrap: wrap; gap: 12px; }

/* ─── Address Checker ────────────────────────────────────────────── */
.rbp-nbn-checker {
  background: linear-gradient(135deg, var(--nbn-navy) 0%, #134e4a 60%, var(--nbn-navy) 100%);
  border-radius: var(--nbn-radius-lg);
  padding: 56px 48px;
  position: relative; overflow: hidden;
}
.rbp-nbn-checker::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(6,182,212,.14), transparent);
  pointer-events: none;
}
.rbp-nbn-checker-inner { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; text-align: center; }
.rbp-nbn-checker h2 { color: var(--nbn-white); font-size: clamp(26px,3.5vw,40px); font-weight: 900; letter-spacing: -.03em; margin: 16px 0 12px; }
.rbp-nbn-checker p  { color: #94a3b8; font-size: 16px; line-height: 1.65; margin-bottom: 36px; }
.rbp-nbn-checker-form { display: flex; gap: 12px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.14); border-radius: 16px; padding: 8px; }
.rbp-nbn-checker-form input {
  flex: 1; background: transparent; border: none; outline: none;
  padding: 14px 16px; font-size: 15px; color: var(--nbn-white);
  font-family: inherit;
}
.rbp-nbn-checker-form input::placeholder { color: #64748b; }
.rbp-nbn-checker-form button {
  padding: 14px 28px; background: var(--nbn-teal); color: var(--nbn-white);
  border: none; border-radius: 10px; font-size: 14px; font-weight: 800;
  cursor: pointer; white-space: nowrap; transition: background .2s;
  font-family: inherit;
}
.rbp-nbn-checker-form button:hover { background: var(--nbn-teal-mid); }
.rbp-nbn-checker-result {
  margin-top: 20px; padding: 16px 20px;
  border-radius: 12px; font-size: 14px; font-weight: 600;
  display: none;
}
.rbp-nbn-checker-result--checking { display: block; background: rgba(255,255,255,.06); color: #94a3b8; }
.rbp-nbn-checker-result--success  { display: block; background: rgba(5,150,105,.15); color: #6ee7b7; border: 1px solid rgba(5,150,105,.3); }
.rbp-nbn-checker-result--pending  { display: block; background: rgba(245,158,11,.12); color: #fcd34d; border: 1px solid rgba(245,158,11,.3); }
.rbp-nbn-checker-tags { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 24px; }
.rbp-nbn-checker-tag { font-size: 11px; color: #64748b; font-weight: 600; display: flex; align-items: center; gap: 6px; }
.rbp-nbn-checker-tag::before { content: '•'; color: #334155; }

/* ─── Plan cards ─────────────────────────────────────────────────── */
.rbp-nbn-plans { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.rbp-nbn-plan {
  background: var(--nbn-white); border: 1.5px solid var(--nbn-slate-2);
  border-radius: var(--nbn-radius-lg); overflow: hidden;
  display: flex; flex-direction: column;
  transition: transform .25s ease, box-shadow .25s ease;
}
.rbp-nbn-plan:hover { transform: translateY(-4px); box-shadow: var(--nbn-shadow-lg); }
.rbp-nbn-plan--featured { border-color: var(--nbn-teal); box-shadow: 0 0 0 3px rgba(13,148,136,.12), var(--nbn-shadow-lg); transform: scale(1.02); }
.rbp-nbn-plan--featured:hover { transform: scale(1.02) translateY(-4px); }
.rbp-nbn-plan-head {
  padding: 28px 28px 24px;
  position: relative;
}
.rbp-nbn-plan--featured .rbp-nbn-plan-head { background: linear-gradient(135deg, #0f172a, #134e4a); color: var(--nbn-white); }
.rbp-nbn-plan-badge {
  position: absolute; top: 16px; right: 16px;
  background: var(--nbn-teal); color: var(--nbn-white);
  font-size: 10px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
  padding: 4px 12px; border-radius: 999px;
}
.rbp-nbn-plan-name { font-size: 12px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--nbn-slate-4); margin-bottom: 6px; }
.rbp-nbn-plan--featured .rbp-nbn-plan-name { color: rgba(255,255,255,.5); }
.rbp-nbn-plan-speed { font-size: 48px; font-weight: 900; letter-spacing: -.04em; line-height: 1; color: var(--nbn-slate-9); }
.rbp-nbn-plan--featured .rbp-nbn-plan-speed { color: var(--nbn-white); }
.rbp-nbn-plan-speed-unit { font-size: 16px; font-weight: 700; color: var(--nbn-slate-4); margin-left: 4px; }
.rbp-nbn-plan--featured .rbp-nbn-plan-speed-unit { color: rgba(255,255,255,.5); }
.rbp-nbn-plan-speed-label { font-size: 13px; color: var(--nbn-slate-6); margin-top: 2px; }
.rbp-nbn-plan--featured .rbp-nbn-plan-speed-label { color: rgba(255,255,255,.6); }
.rbp-nbn-plan-body { padding: 24px 28px; flex: 1; display: flex; flex-direction: column; }
.rbp-nbn-plan-price { font-size: 32px; font-weight: 900; color: var(--nbn-slate-9); letter-spacing: -.03em; }
.rbp-nbn-plan-price-tbc { font-size: 20px; font-weight: 900; color: var(--nbn-slate-7); }
.rbp-nbn-plan-price sup { font-size: 16px; vertical-align: super; }
.rbp-nbn-plan-price-period { font-size: 14px; color: var(--nbn-slate-4); font-weight: 600; }
.rbp-nbn-plan-tech {
  display: flex; flex-wrap: wrap; gap: 6px; margin: 16px 0;
}
.rbp-nbn-plan-tech-badge {
  padding: 4px 10px; border-radius: 999px;
  font-size: 11px; font-weight: 800;
  background: var(--nbn-teal-pale); color: var(--nbn-teal);
}
.rbp-nbn-plan-features { flex: 1; }
.rbp-nbn-plan-feature {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 8px 0; border-bottom: 1px solid var(--nbn-slate-1);
  font-size: 14px; color: var(--nbn-slate-7); line-height: 1.4;
}
.rbp-nbn-plan-feature:last-child { border-bottom: none; }
.rbp-nbn-plan-feature-icon {
  width: 18px; height: 18px; flex-shrink: 0;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 10px; margin-top: 2px;
}
.rbp-nbn-plan-feature-icon--yes { background: var(--nbn-green-pale); color: var(--nbn-green); }
.rbp-nbn-plan-feature-icon--no  { background: var(--nbn-slate-1);    color: var(--nbn-slate-4); }
.rbp-nbn-plan-cta { padding: 0 28px 28px; }
.rbp-nbn-plan-cta .rbp-nbn-btn { width: 100%; justify-content: center; }

/* ─── Technology explainer ───────────────────────────────────────── */
.rbp-nbn-tech-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.rbp-nbn-tech-card {
  background: var(--nbn-white); border: 1.5px solid var(--nbn-slate-2);
  border-radius: var(--nbn-radius-lg); padding: 32px 28px;
  position: relative; overflow: hidden;
  transition: transform .2s, box-shadow .2s;
}
.rbp-nbn-tech-card:hover { transform: translateY(-3px); box-shadow: var(--nbn-shadow); }
.rbp-nbn-tech-card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
  background: var(--nbn-accent, var(--nbn-teal));
}
.rbp-nbn-tech-icon {
  width: 56px; height: 56px; border-radius: 16px;
  background: var(--nbn-icon-bg, var(--nbn-teal-pale));
  color: var(--nbn-icon-color, var(--nbn-teal));
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; margin-bottom: 20px;
}
.rbp-nbn-tech-card h3 { font-size: 18px; font-weight: 800; margin-bottom: 10px; }
.rbp-nbn-tech-card p { font-size: 14px; color: var(--nbn-slate-6); line-height: 1.65; }
.rbp-nbn-tech-availability {
  margin-top: 16px; display: flex; align-items: center; gap: 8px;
  font-size: 12px; font-weight: 700;
}
.rbp-nbn-avail-dot { width: 8px; height: 8px; border-radius: 50%; }

/* ─── Status panels ──────────────────────────────────────────────── */
.rbp-nbn-status-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.rbp-nbn-status-panel {
  border-radius: var(--nbn-radius-lg); padding: 32px 28px;
  border: 1.5px solid var(--nbn-slate-2);
  background: var(--nbn-white);
}
.rbp-nbn-status-panel--pending { border-color: rgba(245,158,11,.3); background: rgba(254,243,199,.3); }
.rbp-nbn-status-panel--active  { border-color: rgba(5,150,105,.3);  background: rgba(209,250,229,.3); }
.rbp-nbn-status-panel--review  { border-color: rgba(29,78,216,.3);  background: rgba(219,234,254,.3); }
.rbp-nbn-status-icon { font-size: 36px; margin-bottom: 16px; display: block; }
.rbp-nbn-status-panel h3 { font-size: 18px; font-weight: 800; margin-bottom: 8px; }
.rbp-nbn-status-panel p { font-size: 14px; color: var(--nbn-slate-6); line-height: 1.65; }
.rbp-nbn-status-steps { margin-top: 16px; }
.rbp-nbn-status-step { display: flex; align-items: flex-start; gap: 10px; padding: 8px 0; font-size: 13px; color: var(--nbn-slate-7); }
.rbp-nbn-status-step-num { width: 22px; height: 22px; border-radius: 50%; background: var(--nbn-slate-2); color: var(--nbn-slate-6); font-size: 11px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

/* ─── How connection works ───────────────────────────────────────── */
.rbp-nbn-connect-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative; }
.rbp-nbn-connect-steps::before {
  content: ''; position: absolute; top: 28px; left: 12.5%; right: 12.5%;
  height: 2px; background: linear-gradient(90deg, var(--nbn-teal-pale), var(--nbn-teal), var(--nbn-teal-pale));
}
.rbp-nbn-connect-step { position: relative; z-index: 1; text-align: center; padding: 0 16px; }
.rbp-nbn-connect-step-num {
  width: 56px; height: 56px; border-radius: 50%;
  background: var(--nbn-teal); color: var(--nbn-white);
  font-size: 20px; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px;
  box-shadow: 0 0 0 6px white, 0 0 0 8px var(--nbn-teal-pale);
}
.rbp-nbn-connect-step h3 { font-size: 15px; font-weight: 800; margin-bottom: 8px; }
.rbp-nbn-connect-step p { font-size: 13px; color: var(--nbn-slate-6); line-height: 1.6; }

/* ─── FAQ ────────────────────────────────────────────────────────── */
.rbp-nbn-faq { border-radius: var(--nbn-radius-lg); overflow: hidden; border: 1px solid var(--nbn-slate-2); }
.rbp-nbn-faq details { border-bottom: 1px solid var(--nbn-slate-2); background: var(--nbn-white); }
.rbp-nbn-faq details:last-child { border-bottom: none; }
.rbp-nbn-faq summary { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 28px; cursor: pointer; list-style: none; font-size: 15px; font-weight: 700; color: var(--nbn-slate-9); transition: background .15s; }
.rbp-nbn-faq summary:hover { background: var(--nbn-slate-0); }
.rbp-nbn-faq summary::-webkit-details-marker { display: none; }
.rbp-nbn-faq summary::after { content: '+'; font-size: 20px; font-weight: 300; color: var(--nbn-slate-4); transition: transform .2s; }
.rbp-nbn-faq details[open] summary::after { transform: rotate(45deg); }
.rbp-nbn-faq details[open] summary { background: var(--nbn-slate-0); color: var(--nbn-teal); }
.rbp-nbn-faq-body { padding: 0 28px 22px; font-size: 15px; color: var(--nbn-slate-6); line-height: 1.75; }

/* ─── Legal disclaimer ───────────────────────────────────────────── */
.rbp-nbn-legal {
  background: var(--nbn-slate-0); border-top: 1px solid var(--nbn-slate-2);
  padding: 32px 0;
}
.rbp-nbn-legal p { font-size: 12px; color: var(--nbn-slate-4); line-height: 1.7; }

/* ─── CTA Band ───────────────────────────────────────────────────── */
.rbp-nbn-cta-band {
  background: linear-gradient(135deg, #134e4a 0%, #0f766e 50%, #0f172a 100%);
  border-radius: var(--nbn-radius-lg); padding: 60px 52px;
  display: flex; align-items: center; justify-content: space-between; gap: 40px;
  position: relative; overflow: hidden;
}
.rbp-nbn-cta-band::before {
  content: '';
  position: absolute; top: -40%; right: -8%; width: 400px; height: 400px; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,.07), transparent 70%);
}
.rbp-nbn-cta-band h2 { color: var(--nbn-white); font-size: clamp(24px,3.5vw,38px); font-weight: 900; letter-spacing: -.03em; margin-bottom: 10px; }
.rbp-nbn-cta-band p { color: rgba(255,255,255,.68); font-size: 16px; line-height: 1.65; }
.rbp-nbn-cta-actions { display: flex; flex-wrap: wrap; gap: 12px; flex-shrink: 0; }

/* ─── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .rbp-nbn-plans { grid-template-columns: 1fr; max-width: 500px; margin-inline: auto; }
  .rbp-nbn-plan--featured { transform: none; }
  .rbp-nbn-tech-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 900px) {
  .rbp-nbn-hero-in { grid-template-columns: 1fr; gap: 40px; padding: 72px 0 56px; min-height: unset; }
  .rbp-nbn-status-grid { grid-template-columns: 1fr; }
  .rbp-nbn-connect-steps { grid-template-columns: repeat(2, 1fr); gap: 40px; }
  .rbp-nbn-connect-steps::before { display: none; }
