  <section class="rbp-nbn-sec-sm" aria-label="Business NBN call to action">
    <div class="rbp-nbn-c">
      <div class="rbp-nbn-cta-band">
        <div>
          <h2>Ready to connect your business?</h2>
          <p>Check availability at your address, choose a plan and let the RBP team guide your connection through every step.</p>
        </div>
        <div class="rbp-nbn-cta-actions">
          <a class="rbp-nbn-btn rbp-nbn-btn--teal" href="#rbp-nbn-checker" data-rbp-flow="nbn-check-address">Check your address →</a>
          <a class="rbp-nbn-btn rbp-nbn-btn--white" href="/pages/contact">Talk to our team</a>
        </div>
      </div>
    </div>
  </section>

</div>

<script>
(function() {
  var form   = document.getElementById('rbp-nbn-form');
  var input  = document.getElementById('rbp-nbn-address');
  var result = document.getElementById('rbp-nbn-result');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var addr = (input.value || '').trim();
    if (!addr) { input.focus(); return; }

    result.className = 'rbp-nbn-checker-result rbp-nbn-checker-result--checking';
    result.innerHTML = '<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="vertical-align:middle;margin-right:8px;animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/><path d="M9 12a3 3 0 1 0 6 0 3 3 0 0 0-6 0" stroke-opacity=".3"/></svg> Checking availability for: <strong>' + addr.replace(/</g,'&lt;') + '</strong>...';

    // Placeholder — Codex connects /apps/rbp-bridge/api/check-address
    // data-rbp-flow="nbn-address-check" | data-address attribute set below
    form.setAttribute('data-address', addr);
    form.setAttribute('data-rbp-flow', 'nbn-address-check');

    setTimeout(function() {
      result.className = 'rbp-nbn-checker-result rbp-nbn-checker-result--pending';
      result.innerHTML = '📬 <strong>Address submitted.</strong> Your availability check is being processed. Our team will confirm your connection type and available plans. Typically 1–2 business days for manual review addresses.';
    }, 1400);
  });
})();
</script>

<style>
@keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
/* ─── G10 QA: Focus-visible accessibility ──────────────────────── */
.rbp-nbn a:focus-visible,
.rbp-nbn button:focus-visible,
.rbp-nbn input:focus-visible {
  outline: 3px solid #0d9488;
  outline-offset: 3px;
  border-radius: 6px;
}
/* ─── G10 QA: Scroll entrance animations ───────────────────────── */
.rbp-nbn-anim {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1);
}
.rbp-nbn-anim.rbp-nbn-anim--in { opacity: 1; transform: translateY(0); }
.rbp-nbn-anim--d1 { transition-delay: .08s; }
.rbp-nbn-anim--d2 { transition-delay: .16s; }
.rbp-nbn-anim--d3 { transition-delay: .24s; }
</style>

<script>
(function() {
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('rbp-nbn-anim--in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -32px 0px' });
    document.querySelectorAll('.rbp-nbn-anim').forEach(function(el) { io.observe(el); });
  } else {
    document.querySelectorAll('.rbp-nbn-anim').forEach(function(el) {
      el.classList.add('rbp-nbn-anim--in');
    });
  }
})();
</script>

