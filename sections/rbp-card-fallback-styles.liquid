{% liquid
  assign rbp_fallback_context = 'general'
  assign rbp_context_source = ''

  if product
    assign rbp_context_source = product.product_type | append: ' ' | append: product.tags | downcase
  elsif collection
    assign rbp_context_source = collection.handle | append: ' ' | append: collection.title | downcase
  endif

  if rbp_context_source contains 'business nbn' or rbp_context_source contains 'business-nbn' or rbp_context_source contains 'business internet'
    assign rbp_fallback_context = 'nbn'
  elsif rbp_context_source contains 'property field' or rbp_context_source contains 'booking'
    assign rbp_fallback_context = 'property'
  elsif rbp_context_source contains 'membership'
    assign rbp_fallback_context = 'membership'
  elsif rbp_context_source contains 'marketplace' or rbp_context_source contains 'asset-sale' or rbp_context_source contains 'business-in-a-box'
    assign rbp_fallback_context = 'marketplace'
  elsif rbp_context_source contains 'on-demand'
    assign rbp_fallback_context = 'service'
  elsif rbp_context_source contains 'toolkit'
    assign rbp_fallback_context = 'toolkit'
  elsif rbp_context_source contains 'documentation suite' or rbp_context_source contains 'suite'
    assign rbp_fallback_context = 'suite'
  elsif rbp_context_source contains 'template'
    assign rbp_fallback_context = 'template'
  elsif rbp_context_source contains 'custom solution'
    assign rbp_fallback_context = 'custom'
  endif

  assign rbp_fallback_bg = '#eef4ff'
  assign rbp_fallback_accent = '#1d4ed8'

  case rbp_fallback_context
    when 'template'
      assign rbp_fallback_bg = '#ecfdf5'
      assign rbp_fallback_accent = '#047857'
    when 'toolkit'
      assign rbp_fallback_bg = '#f5f3ff'
      assign rbp_fallback_accent = '#6d28d9'
    when 'suite'
      assign rbp_fallback_bg = '#f5f3ff'
      assign rbp_fallback_accent = '#6d28d9'
    when 'service'
      assign rbp_fallback_bg = '#eff6ff'
      assign rbp_fallback_accent = '#2563eb'
    when 'custom'
      assign rbp_fallback_bg = '#eff6ff'
      assign rbp_fallback_accent = '#2563eb'
    when 'nbn'
      assign rbp_fallback_bg = '#f0f9ff'
      assign rbp_fallback_accent = '#0369a1'
    when 'property'
      assign rbp_fallback_bg = '#f0fdf4'
      assign rbp_fallback_accent = '#15803d'
    when 'membership'
      assign rbp_fallback_bg = '#fdf4ff'
      assign rbp_fallback_accent = '#a21caf'
    when 'marketplace'
      assign rbp_fallback_bg = '#fff7ed'
      assign rbp_fallback_accent = '#c2410c'
  endcase
%}

<style>
  :root {
    --rbp-card-fallback-bg: {{ rbp_fallback_bg }};
    --rbp-card-fallback-accent: {{ rbp_fallback_accent }};
  }

  .card-wrapper .card.card--text .card__inner {
    background:
      radial-gradient(circle at 20% 18%, rgba(255,255,255,.95) 0 12%, transparent 13%),
      linear-gradient(135deg, var(--rbp-card-fallback-bg), #ffffff 78%);
    border: 1px solid color-mix(in srgb, var(--rbp-card-fallback-accent) 24%, transparent);
    overflow: hidden;
  }

  .card-wrapper .card.card--text .card__inner::before {
    content: '';
    position: absolute;
    inset: 1.6rem;
    border: 1px solid color-mix(in srgb, var(--rbp-card-fallback-accent) 18%, transparent);
    border-radius: .8rem;
    pointer-events: none;
  }

  .card-wrapper .card.card--text .card__inner::after {
    content: 'RBP';
    position: absolute;
    right: 1.4rem;
    bottom: 1.2rem;
    color: var(--rbp-card-fallback-accent);
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0;
    opacity: .85;
  }

  .card-wrapper .card.card--text .card__content {
    position: relative;
  }

  @media screen and (max-width: 749px) {
    .card-wrapper .card.card--text .card__inner::before {
      inset: 1rem;
      border-radius: .6rem;
    }

    .card-wrapper .card.card--text .card__inner::after {
      right: 1rem;
      bottom: .9rem;
      font-size: 1rem;
    }
  }
</style>

<div class="rbp-card-fallback-scope" data-rbp-card-context="{{ rbp_fallback_context }}" aria-hidden="true"></div>

{% schema %}
{
  "name": "RBP card fallback styles",
  "tag": "div",
  "class": "rbp-card-fallback-style-section",
  "settings": []
}
{% endschema %}