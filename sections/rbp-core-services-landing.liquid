  display: block;
  font-size: 22px;
  font-weight: 900;
  color: var(--rbp-cs-slate-900);
  letter-spacing: -.03em;
}
.rbp-cs-service-card__member {
  display: block;
  font-size: 11px;
  font-weight: 800;
  color: var(--rbp-cs-emerald);
  letter-spacing: .03em;
  margin-top: 3px;
}
.rbp-cs-service-card__body {
  padding: 20px 28px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.rbp-cs-service-card__h3 {
  font-size: 18px;
  font-weight: 900;
  color: var(--rbp-cs-slate-900);
  letter-spacing: -.02em;
  line-height: 1.3;
}
.rbp-cs-service-card__desc {
  font-size: 14px;
  color: var(--rbp-cs-slate-500);
  line-height: 1.65;
  flex: 1;
}
.rbp-cs-service-card__features {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.rbp-cs-service-card__features li {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--rbp-cs-slate-600);
  padding-left: 18px;
  position: relative;
}
.rbp-cs-service-card__features li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: var(--rbp-cs-emerald);
