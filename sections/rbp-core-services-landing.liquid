  letter-spacing: .01em;
}

/* ═══════════════════════════════════════════════════════════
   5. PROCESS STEPS
═══════════════════════════════════════════════════════════ */
.rbp-cs-process {
  padding: 96px 0;
  background: #fff;
}
.rbp-cs-process__steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  position: relative;
}
.rbp-cs-step {
  padding: 32px 28px 32px 0;
  position: relative;
}
.rbp-cs-step__num {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  color: #fff;
  font-size: 18px;
  font-weight: 900;
  display: grid;
  place-items: center;
  margin-bottom: 20px;
  flex-shrink: 0;
  letter-spacing: -.02em;
}
.rbp-cs-step__num--2 { background: linear-gradient(135deg, #6366f1, #7c3aed); }
.rbp-cs-step__num--3 { background: linear-gradient(135deg, #7c3aed, #db2777); }
.rbp-cs-step__num--4 { background: linear-gradient(135deg, #059669, #0d9488); }
.rbp-cs-step__title {
  font-size: 17px;
  font-weight: 900;
  color: var(--rbp-cs-slate-900);
  letter-spacing: -.02em;
  margin-bottom: 10px;
}
.rbp-cs-step__body {
  font-size: 14px;
  color: var(--rbp-cs-slate-500);
  line-height: 1.7;
}
.rbp-cs-step__connector {
  position: absolute;
  top: 60px;
  right: 0;
  width: calc(100% - 56px - 28px);
  height: 2px;
  background: linear-gradient(90deg, rgba(99,102,241,.3), rgba(99,102,241,.1));
  margin-left: calc(56px + 16px);
}

/* ═══════════════════════════════════════════════════════════
   6. BENEFITS
═══════════════════════════════════════════════════════════ */
.rbp-cs-benefits {
  padding: 96px 0;
  background: var(--rbp-cs-slate-50);
}
.rbp-cs-benefits__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  align-items: start;
}
.rbp-cs-benefits__col {
  background: #fff;
  border: 1px solid var(--rbp-cs-border);
  border-radius: 28px;
  overflow: hidden;
}
.rbp-cs-benefits__col-header {
  padding: 32px;
}
.rbp-cs-benefits__col-header--member {
  background: linear-gradient(135deg, #0f172a, #1e1b4b);
  color: #fff;
}
.rbp-cs-benefits__col-header--standard {
  background: var(--rbp-cs-slate-50);
  border-bottom: 1px solid var(--rbp-cs-border);
}
.rbp-cs-benefits__col-badge {
  display: inline-block;
  padding: 5px 14px;
  background: rgba(255,255,255,.15);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: rgba(255,255,255,.9);
  margin-bottom: 16px;
}
.rbp-cs-benefits__col-badge--slate {
  background: var(--rbp-cs-slate-200);
  color: var(--rbp-cs-slate-700);
}
.rbp-cs-benefits__col-h3 {
  font-size: 22px;
  font-weight: 900;
  line-height: 1.25;
  letter-spacing: -.025em;
  margin-bottom: 10px;
  color: inherit;
}
.rbp-cs-benefits__col-header--standard .rbp-cs-benefits__col-h3 { color: var(--rbp-cs-slate-900); }
.rbp-cs-benefits__col-sub {
  font-size: 14px;
  line-height: 1.6;
  color: rgba(255,255,255,.72);
}
.rbp-cs-benefits__col-header--standard .rbp-cs-benefits__col-sub { color: var(--rbp-cs-slate-500); }
.rbp-cs-benefits__list {
  list-style: none;
  padding: 24px 32px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  flex: 1;
}
.rbp-cs-benefit-item {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}
.rbp-cs-benefit-item__icon {
  width: 28px; height: 28px;
  background: rgba(5,150,105,.12);
  border-radius: 8px;
  display: grid;
  place-items: center;
  font-size: 14px;
  flex-shrink: 0;
  color: var(--rbp-cs-emerald);
}
.rbp-cs-benefit-item__icon--slate {
  background: var(--rbp-cs-slate-100);
  color: var(--rbp-cs-slate-600);
  font-size: 16px;
  font-weight: 900;
}
.rbp-cs-benefit-item strong {
  display: block;
  font-size: 14px;
  font-weight: 800;
  color: var(--rbp-cs-slate-900);
  margin-bottom: 3px;
}
.rbp-cs-benefit-item p {
  font-size: 13px;
  color: var(--rbp-cs-slate-500);
  line-height: 1.6;
}
.rbp-cs-benefits__col > .rbp-cs-btn {
  margin: 0 32px 32px;
  width: calc(100% - 64px);
  justify-content: center;
}

/* ═══════════════════════════════════════════════════════════
   7. FAQ
═══════════════════════════════════════════════════════════ */
.rbp-cs-faq {
  padding: 96px 0;
  background: #fff;
}
.rbp-cs-faq__list {
  max-width: 820px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--rbp-cs-border);
  border-radius: 20px;
  overflow: hidden;
}
.rbp-cs-faq__item {
  border-bottom: 1px solid var(--rbp-cs-border);
}
.rbp-cs-faq__item:last-child { border-bottom: none; }
.rbp-cs-faq__q {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  padding: 22px 28px;
  background: transparent;
  border: none;
  cursor: pointer;
  text-align: left;
  font-size: 15px;
  font-weight: 700;
  color: var(--rbp-cs-slate-900);
  transition: background .15s ease;
}
.rbp-cs-faq__q:hover { background: var(--rbp-cs-slate-50); }
.rbp-cs-faq__q[aria-expanded="true"] { background: var(--rbp-cs-slate-50); color: var(--rbp-cs-blue); }
.rbp-cs-faq__chevron {
  width: 20px; height: 20px;
  flex-shrink: 0;
  transition: transform .25s ease;
  color: var(--rbp-cs-slate-400);
}
.rbp-cs-faq__q[aria-expanded="true"] .rbp-cs-faq__chevron {
  transform: rotate(180deg);
  color: var(--rbp-cs-blue);
}
.rbp-cs-faq__a {
  padding: 0 28px 22px;
  font-size: 14.5px;
  color: var(--rbp-cs-slate-500);
  line-height: 1.75;
}
.rbp-cs-faq__footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-top: 40px;
  flex-wrap: wrap;
}
.rbp-cs-faq__footer p {
  font-size: 15px;
  font-weight: 600;
  color: var(--rbp-cs-slate-600);
}

/* ═══════════════════════════════════════════════════════════
   8. CTA BAND
═══════════════════════════════════════════════════════════ */
.rbp-cs-cta-band {
  padding: 80px 0;
  background: linear-gradient(135deg, #0f172a, #1e1b4b, #312e81);
  position: relative;
  overflow: hidden;
}
.rbp-cs-cta-band__inner {
  text-align: center;
  max-width: 760px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.rbp-cs-cta-band__orb {
  position: absolute;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(99,102,241,.3) 0%, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  filter: blur(60px);
  pointer-events: none;
}
.rbp-cs-cta-band__h2 {
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 900;
  color: #fff;
  letter-spacing: -.03em;
  line-height: 1.15;
  margin-bottom: 20px;
}
.rbp-cs-cta-band__sub {
  font-size: 16px;
  color: rgba(255,255,255,.7);
  line-height: 1.7;
  margin-bottom: 40px;
}
.rbp-cs-cta-band__actions {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 28px;
}
.rbp-cs-cta-band__member-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 13.5px;
  color: rgba(255,255,255,.65);
  font-weight: 600;
}

/* ═══════════════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════════════ */
@media (max-width: 1100px) {
  .rbp-cs-pathways__grid { grid-template-columns: repeat(2, 1fr); }
