<style>
.rbp-doc{--b:#1d4ed8;--bd:#1e3a8a;--bs:#dbeafe;--s9:#0f172a;--s7:#334155;--s6:#475569;--s0:#f8fafc;--br:rgba(15,23,42,.1);--br2:rgba(15,23,42,.16);--sh:0 22px 55px rgba(15,23,42,.14);background:#fff;color:var(--s9)}.rbp-doc *{box-sizing:border-box}.rbp-doc a{text-decoration:none;color:inherit}.rbp-doc-c{width:min(100% - 3rem,1200px);margin-inline:auto}.rbp-doc-hero{overflow:hidden;color:#fff;background:radial-gradient(ellipse at top right,rgba(59,130,246,.24),transparent 58%),linear-gradient(135deg,#0f172a 0%,#172554 52%,#0f172a 100%)}.rbp-doc-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(310px,.72fr);gap:56px;align-items:center;padding:86px 0;min-height:560px}.rbp-doc-ey{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:#dbeafe;color:#1d4ed8;font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-doc-hero .rbp-doc-ey{background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28)}.rbp-doc-dot{width:7px;height:7px;border-radius:999px;background:currentColor}.rbp-doc-h1{margin:16px 0 0;color:#fff;font-size:clamp(40px,6vw,76px);line-height:1.02;letter-spacing:-.045em;font-weight:900}.rbp-doc-h2{margin:14px 0 0;color:var(--s9);font-size:clamp(30px,4vw,50px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-doc-p{margin:16px 0 0;color:var(--s6);font-size:16px;line-height:1.75}.rbp-doc-hero .rbp-doc-p{color:#cbd5e1;font-size:18px;max-width:760px}.rbp-doc-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:28px}.rbp-doc-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:14px;padding:14px 18px;border:1px solid transparent;font-size:14px;font-weight:900;line-height:1}.rbp-doc-btn-p{background:#1d4ed8;color:#fff;box-shadow:0 18px 36px rgba(29,78,216,.24)}.rbp-doc-btn-g{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.24)}.rbp-doc-btn-o{background:#fff;color:var(--s7);border-color:var(--br2)}.rbp-doc-proof{display:flex;flex-wrap:wrap;gap:14px 20px;margin-top:26px}.rbp-doc-proof span{display:inline-flex;align-items:center;gap:8px;color:#cbd5e1;font-size:14px;font-weight:750}.rbp-doc-check{width:18px;height:18px;border-radius:999px;display:inline-grid;place-items:center;background:#3b82f6;color:#fff;font-size:12px;line-height:1;flex:0 0 auto}.rbp-doc-card{background:#fff;border:1px solid var(--br);border-radius:24px;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-doc-hero-card{border:1px solid rgba(255,255,255,.14);border-radius:28px;background:rgba(255,255,255,.08);box-shadow:0 35px 75px rgba(30,64,175,.32);padding:26px}.rbp-doc-hero-card h3{margin:0 0 12px;color:#fff;font-size:22px;font-weight:900}.rbp-doc-hero-card p{margin:0;color:#cbd5e1;line-height:1.7}.rbp-doc-sec{padding:74px 0}.rbp-doc-muted{background:#f8fafc}.rbp-doc-head{max-width:780px;margin:0 auto 36px;text-align:center}.rbp-doc-grid{display:grid;gap:20px}.rbp-doc-g2{grid-template-columns:repeat(2,minmax(0,1fr))}.rbp-doc-g3{grid-template-columns:repeat(3,minmax(0,1fr))}.rbp-doc-g4{grid-template-columns:repeat(4,minmax(0,1fr))}.rbp-doc-icon{width:46px;height:46px;border-radius:16px;display:grid;place-items:center;margin-bottom:16px;background:#dbeafe;color:#1d4ed8;font-weight:900}.rbp-doc-title{margin:0 0 8px;color:#0f172a;font-size:18px;font-weight:900}.rbp-doc-text,.rbp-doc-rich,.rbp-doc-rich p,.rbp-doc-rich li{margin:0;color:#64748b;line-height:1.65;font-size:14px}.rbp-doc-list{display:grid;gap:10px;margin:18px 0 0;padding:0;list-style:none}.rbp-doc-list li{display:grid;grid-template-columns:22px minmax(0,1fr);gap:10px;color:#64748b;line-height:1.55;font-size:14px}.rbp-doc-step{position:relative;padding-left:54px}.rbp-doc-step+.rbp-doc-step{margin-top:20px}.rbp-doc-step-num{position:absolute;top:0;left:0;width:40px;height:40px;border-radius:999px;background:#1d4ed8;color:#fff;display:grid;place-items:center;font-size:12px;font-weight:900}.rbp-doc-step h3{margin:0 0 5px;color:#0f172a;font-size:16px;font-weight:900}.rbp-doc-step p{margin:0;color:#64748b;line-height:1.65}.rbp-doc-blue{background:linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;border:0;box-shadow:var(--sh)}.rbp-doc-blue .rbp-doc-title,.rbp-doc-blue .rbp-doc-h2{color:#fff}.rbp-doc-blue .rbp-doc-text,.rbp-doc-blue .rbp-doc-p{color:#dbeafe}.rbp-doc-faq details{background:#fff;border:1px solid var(--br);border-radius:18px;padding:0 18px}.rbp-doc-faq details+details{margin-top:12px}.rbp-doc-faq summary{cursor:pointer;padding:18px 0;color:#0f172a;font-weight:900}.rbp-doc-faq summary::-webkit-details-marker{display:none}.rbp-doc-faq div{padding-bottom:18px;color:#64748b;line-height:1.7}.rbp-doc-cta{border-radius:32px;background:radial-gradient(circle at top right,rgba(255,255,255,.18),transparent 35%),linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;padding:clamp(28px,5vw,56px);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:28px;align-items:center}.rbp-doc-cta h2{margin:0;color:#fff;font-size:clamp(28px,4vw,48px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-doc-cta p{margin:12px 0 0;color:#dbeafe;line-height:1.7;max-width:760px}@media(max-width:989px){.rbp-doc-hero-in,.rbp-doc-g2,.rbp-doc-g3,.rbp-doc-g4,.rbp-doc-cta{grid-template-columns:1fr}.rbp-doc-hero-card{display:none}.rbp-doc-head{text-align:left;margin-inline:0}}@media(max-width:749px){.rbp-doc-c{width:min(100% - 2rem,1200px)}.rbp-doc-sec{padding:54px 0}.rbp-doc-hero-in{padding:68px 0;min-height:auto}.rbp-doc-btn{width:100%}}
</style>
{%- liquid
 assign category='Document Nucleus'
 assign summary='Explore prepared business documents, templates, toolkits and document support pathways designed to help you move faster with more structure.'
 assign card_title='Documents that do more than sit there'
 assign card_text='Use this hub to understand the right document pathway for your business need.'
 assign who1='Business owners who need practical documents'
 assign who2='Teams that need structure without starting from zero'
 assign who3='Operators preparing processes, policies or business materials'
 assign what1='Choose the right document pathway'
 assign what2='Understand what is included'
 assign what3='Move from purchase to onboarding, delivery and review'
 assign cta1='/pages/templates'
 assign cta1_label='Browse templates'
 assign cta2='/pages/contact'
 assign cta2_label='Request document help'
 case page.handle
  when 'templates'
   assign category='Templates'
   assign summary='Individual business documents prepared around a specific need, task, process or decision.'
   assign card_title='Best for a focused business document'
   assign card_text='Templates are the right starting point when you need one clear document prepared for a specific purpose.'
   assign who1='Owners who need one practical document'
   assign who2='Businesses completing a specific process or decision'
   assign who3='Teams that want structure without buying a full suite'
   assign what1='Single document pathway'
   assign what2='Onboarding information collected after purchase'
   assign what3='Delivered document ready for review and use'
   assign cta1='/collections/templates'
   assign cta1_label='View template products'
  when 'documentation-suite'
   assign category='Documentation Suites'
   assign summary='Grouped document packs for businesses that need several connected documents prepared together.'
   assign card_title='Best for connected business documentation'
   assign card_text='Documentation Suites are built for situations where one document is not enough and the supporting materials need to work together.'
   assign who1='Businesses setting up or improving a complete process'
   assign who2='Owners who need several connected documents'
   assign who3='Teams that want consistency across policies, forms and guidance'
   assign what1='Multiple connected documents'
   assign what2='Consistent structure across the suite'
   assign what3='Review and revision pathway where available'
   assign cta1='/collections/documentation-suites'
   assign cta1_label='View documentation suites'
  when 'toolkits'
   assign category='Toolkits'
   assign summary='Practical bundles that combine documents, guidance and resources to help complete a broader business activity.'
   assign card_title='Best for action, not just paperwork'
   assign card_text='Toolkits combine documents and guidance so you can complete a broader operational or business activity with more confidence.'
   assign who1='Businesses working through a practical project'
   assign who2='Operators who need documents plus guidance'
   assign who3='Teams that need a usable bundle of resources'
   assign what1='Documents plus practical guidance'
   assign what2='Resources grouped around a broader outcome'
   assign what3='A clearer pathway from planning to action'
   assign cta1='/collections/toolkits'
   assign cta1_label='View toolkits'
  when 'document-management-system'
   assign category='Document Management System'
   assign summary='A structured pathway for organising, controlling and improving the way your business manages documents.'
   assign card_title='Best for document chaos, sadly common'
   assign card_text='This pathway helps businesses improve document structure, access, consistency and control.'
   assign who1='Businesses with scattered or inconsistent documents'
   assign who2='Teams needing better document control and ownership'
   assign who3='Operators building repeatable business systems'
   assign what1='Document structure review'
   assign what2='Better ownership, access and version control'
   assign what3='Practical document management pathway'
   assign cta1='/pages/contact'
   assign cta1_label='Request document management help'
  when 'our-process'
   assign category='Our Process'
   assign summary='Understand how document products move from purchase to onboarding, preparation, delivery, review and use.'
   assign card_title='The process, minus the mystery fog'
   assign card_text='This page explains what happens after purchase and how document products are prepared and delivered.'
   assign who1='Customers buying a document product'
   assign who2='Businesses preparing onboarding information'
   assign who3='Customers who want to understand delivery and revisions'
   assign what1='Purchase and onboarding steps'
   assign what2='Delivery and review expectations'
   assign what3='Revision or use-immediately pathway'
   assign cta1='/pages/templates'
   assign cta1_label='Browse documents'
 endcase
-%}
<div class="rbp-doc">
<section class="rbp-doc-hero"><div class="rbp-doc-c"><div class="rbp-doc-hero-in"><div><div class="rbp-doc-ey"><span class="rbp-doc-dot"></span>{{ category }}</div><h1 class="rbp-doc-h1">{{ page.title }}</h1><p class="rbp-doc-p">{{ summary }}</p><div class="rbp-doc-actions"><a class="rbp-doc-btn rbp-doc-btn-p" href="{{ cta1 }}">{{ cta1_label }} -&gt;</a><a class="rbp-doc-btn rbp-doc-btn-g" href="{{ cta2 }}">{{ cta2_label }}</a></div><div class="rbp-doc-proof"><span><span class="rbp-doc-check">✓</span>Prepared document pathway</span><span><span class="rbp-doc-check">✓</span>Onboarding after purchase</span><span><span class="rbp-doc-check">✓</span>Review and support options</span></div></div><aside class="rbp-doc-hero-card"><h3>{{ card_title }}</h3><p>{{ card_text }}</p></aside></div></div></section>
<section class="rbp-doc-sec"><div class="rbp-doc-c"><div class="rbp-doc-grid rbp-doc-g2"><div><div class="rbp-doc-ey">What this is</div><h2 class="rbp-doc-h2">A clearer document pathway for your business</h2><p class="rbp-doc-p">{{ summary }}</p>{%- if page.content != blank -%}<div class="rbp-doc-rich" style="margin-top:18px;">{{ page.content }}</div>{%- endif -%}</div><div class="rbp-doc-card rbp-doc-blue"><h3 class="rbp-doc-title">Who it is for</h3><ul class="rbp-doc-list"><li><span class="rbp-doc-check">✓</span><span>{{ who1 }}</span></li><li><span class="rbp-doc-check">✓</span><span>{{ who2 }}</span></li><li><span class="rbp-doc-check">✓</span><span>{{ who3 }}</span></li></ul></div></div></div></section>
<section class="rbp-doc-sec rbp-doc-muted"><div class="rbp-doc-c"><div class="rbp-doc-head"><div class="rbp-doc-ey">Choose the right product type</div><h2 class="rbp-doc-h2">Templates, suites and toolkits serve different jobs</h2><p class="rbp-doc-p">Use the right pathway instead of buying the wrong document and discovering it mid-chaos. Tiny miracle, avoided.</p></div><div class="rbp-doc-grid rbp-doc-g3"><a class="rbp-doc-card" href="/pages/templates"><div class="rbp-doc-icon">TP</div><h3 class="rbp-doc-title">Templates</h3><p class="rbp-doc-text">Individual business documents for a focused need, task, process or decision.</p></a><a class="rbp-doc-card" href="/pages/documentation-suite"><div class="rbp-doc-icon">DS</div><h3 class="rbp-doc-title">Documentation Suites</h3><p class="rbp-doc-text">Grouped documents prepared together for connected business requirements.</p></a><a class="rbp-doc-card" href="/pages/toolkits"><div class="rbp-doc-icon">TK</div><h3 class="rbp-doc-title">Toolkits</h3><p class="rbp-doc-text">Bundles of documents, guidance and resources for broader business activities.</p></a></div></div></section>
<section class="rbp-doc-sec"><div class="rbp-doc-c"><div class="rbp-doc-head"><div class="rbp-doc-ey">What you get</div><h2 class="rbp-doc-h2">Built to help you act, not just download</h2></div><div class="rbp-doc-grid rbp-doc-g3"><div class="rbp-doc-card"><div class="rbp-doc-icon">01</div><h3 class="rbp-doc-title">{{ what1 }}</h3><p class="rbp-doc-text">A structured starting point matched to the kind of document outcome you need.</p></div><div class="rbp-doc-card"><div class="rbp-doc-icon">02</div><h3 class="rbp-doc-title">{{ what2 }}</h3><p class="rbp-doc-text">The right information is collected so the document can be prepared properly.</p></div><div class="rbp-doc-card"><div class="rbp-doc-icon">03</div><h3 class="rbp-doc-title">{{ what3 }}</h3><p class="rbp-doc-text">Review the result, request changes where available, or start using it in your business.</p></div></div></div></section>
<section class="rbp-doc-sec rbp-doc-muted"><div class="rbp-doc-c"><div class="rbp-doc-grid rbp-doc-g2"><div class="rbp-doc-card"><div class="rbp-doc-ey">How ordering works</div><h2 class="rbp-doc-h2">The document process</h2><div class="rbp-doc-step"><span class="rbp-doc-step-num">01</span><h3>Customer buys the document</h3><p>Complete checkout and keep the order confirmation.</p></div><div class="rbp-doc-step"><span class="rbp-doc-step-num">02</span><h3>Customer completes the onboarding form</h3><p>Provide the business information needed to prepare the document.</p></div><div class="rbp-doc-step"><span class="rbp-doc-step-num">03</span><h3>Customer waits for delivery</h3><p>The document is prepared using the submitted information.</p></div><div class="rbp-doc-step"><span class="rbp-doc-step-num">04</span><h3>Customer reviews the order</h3><p>Check the document and confirm it reflects the intended use.</p></div><div class="rbp-doc-step"><span class="rbp-doc-step-num">05</span><h3>Customer asks for revisions or uses it immediately</h3><p>Request revisions where included or available, or begin using the document.</p></div></div><div class="rbp-doc-card"><div class="rbp-doc-ey">Support</div><h2 class="rbp-doc-h2">Need help choosing?</h2><p class="rbp-doc-p">If you are unsure whether you need a template, suite, toolkit or document management support, start with the overview or contact us for routing.</p><ul class="rbp-doc-list"><li><span class="rbp-doc-check">✓</span><span>Use Templates for focused single-document needs.</span></li><li><span class="rbp-doc-check">✓</span><span>Use Documentation Suites for connected document packs.</span></li><li><span class="rbp-doc-check">✓</span><span>Use Toolkits for documents plus practical guidance.</span></li><li><span class="rbp-doc-check">✓</span><span>Use Document Management System support when the issue is structure, control and consistency.</span></li></ul><a class="rbp-doc-btn rbp-doc-btn-p" href="/pages/contact" style="margin-top:22px;">Ask for guidance -&gt;</a></div></div></div></section>
<section class="rbp-doc-sec"><div class="rbp-doc-c"><div class="rbp-doc-head"><div class="rbp-doc-ey">Featured pathways</div><h2 class="rbp-doc-h2">Explore related document areas</h2></div><div class="rbp-doc-grid rbp-doc-g4"><a class="rbp-doc-card" href="/pages/templates"><div class="rbp-doc-icon">TP</div><h3 class="rbp-doc-title">Templates</h3><p class="rbp-doc-text">Focused individual documents.</p></a><a class="rbp-doc-card" href="/pages/documentation-suite"><div class="rbp-doc-icon">DS</div><h3 class="rbp-doc-title">Suites</h3><p class="rbp-doc-text">Connected document packs.</p></a><a class="rbp-doc-card" href="/pages/toolkits"><div class="rbp-doc-icon">TK</div><h3 class="rbp-doc-title">Toolkits</h3><p class="rbp-doc-text">Documents plus practical resources.</p></a><a class="rbp-doc-card" href="/pages/our-process"><div class="rbp-doc-icon">OP</div><h3 class="rbp-doc-title">Our Process</h3><p class="rbp-doc-text">How purchase, onboarding, delivery and review work.</p></a></div></div></section>
<section class="rbp-doc-sec rbp-doc-muted"><div class="rbp-doc-c"><div class="rbp-doc-grid rbp-doc-g2"><div><div class="rbp-doc-ey">FAQ</div><h2 class="rbp-doc-h2">Document questions</h2><p class="rbp-doc-p">A few answers before another support enquiry is born into the inbox wilderness.</p></div><div class="rbp-doc-faq"><details open><summary>Do I receive the document instantly?</summary><div>No. Document products use an onboarding and delivery process unless a product specifically says otherwise.</div></details><details><summary>Why do I need to complete an onboarding form?</summary><div>The onboarding form collects the information required to prepare the document around your business situation.</div></details><details><summary>Can I request revisions?</summary><div>Revisions may be included or available depending on the product. The product page will identify the relevant review and revision pathway.</div></details><details><summary>Which option should I choose?</summary><div>Choose Templates for a single document, Documentation Suites for connected document packs, Toolkits for documents plus practical guidance, and Document Management System support for structure and control.</div></details></div></div></div></section>
<section class="rbp-doc-sec"><div class="rbp-doc-c"><div class="rbp-doc-cta"><div><h2>Ready to choose your document pathway?</h2><p>Browse the document categories or submit an enquiry and we will help route you to the right option. Astonishingly better than guessing.</p></div><div class="rbp-doc-actions"><a class="rbp-doc-btn rbp-doc-btn-g" href="/pages/templates">Browse documents</a><a class="rbp-doc-btn rbp-doc-btn-g" href="/pages/contact">Contact support</a></div></div></div></section>
</div>
{% schema %}{"name":"RBP document hub","settings":[],"presets":[{"name":"RBP document hub"}]}{% endschema %}