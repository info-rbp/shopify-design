<style>
.rbp-footer {
  --rbp-blue: #1d4ed8;
  --rbp-indigo: #4f46e5;
  --rbp-slate-950: #020617;
  --rbp-slate-900: #0f172a;
  --rbp-slate-800: #1e293b;
  --rbp-slate-700: #334155;
  --rbp-slate-600: #475569;
  --rbp-slate-500: #64748b;
  --rbp-slate-400: #94a3b8;
  --rbp-slate-300: #cbd5e1;
  font-family: var(--font-body-family, system-ui, sans-serif);
}
.rbp-footer *, .rbp-footer *::before, .rbp-footer *::after { box-sizing: border-box; }

/* ── Pre-footer CTA band ──────────────────────────────── */
.rbp-footer-cta-band {
  background: linear-gradient(135deg, #0f172a 0%, #172554 55%, #0f172a 100%);
  position: relative; overflow: hidden;
}
.rbp-footer-cta-band::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 30% 50%, rgba(29,78,216,.28) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 50%, rgba(79,70,229,.18) 0%, transparent 55%);
  pointer-events: none;
}
.rbp-footer-cta-inner {
  width: min(100% - 2.5rem, 1280px);
  margin-inline: auto;
  padding: 72px 0;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 40px;
  position: relative;
}
.rbp-footer-cta-text { }
.rbp-footer-cta-eyebrow {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(29,78,216,.25); border: 1px solid rgba(29,78,216,.35);
  border-radius: 999px; padding: 5px 12px;
  color: #93c5fd; font-size: 11px; font-weight: 800;
  letter-spacing: .1em; text-transform: uppercase; margin-bottom: 16px;
}
.rbp-footer-cta-heading {
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 900; letter-spacing: -.03em; line-height: 1.08;
  color: #fff; margin: 0 0 14px;
}
.rbp-footer-cta-heading span { color: #60a5fa; }
.rbp-footer-cta-sub { color: #94a3b8; font-size: 16px; line-height: 1.6; font-weight: 500; max-width: 480px; }
.rbp-footer-cta-actions { display: flex; gap: 12px; align-items: center; flex-shrink: 0; flex-direction: column; }
.rbp-footer-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 24px; border-radius: 13px;
  font-size: 14px; font-weight: 800; text-decoration: none;
  white-space: nowrap; transition: all .18s ease;
}
.rbp-footer-btn-primary {
  background: var(--rbp-blue); color: #fff;
  box-shadow: 0 8px 28px rgba(29,78,216,.35);
}
.rbp-footer-btn-primary:hover { background: #2563eb; transform: translateY(-2px); box-shadow: 0 12px 36px rgba(29,78,216,.45); }
.rbp-footer-btn-ghost {
  background: rgba(255,255,255,.08); color: #cbd5e1;
  border: 1px solid rgba(255,255,255,.14);
}
.rbp-footer-btn-ghost:hover { background: rgba(255,255,255,.14); color: #fff; }

/* ── Main footer ──────────────────────────────────────── */
.rbp-footer-main {
  background: var(--rbp-slate-950);
  padding: 64px 0 0;
}
.rbp-footer-grid {
  width: min(100% - 2.5rem, 1280px);
  margin-inline: auto;
  display: grid;
  grid-template-columns: 280px repeat(5, 1fr);
  gap: 40px;
}

/* Brand column */
.rbp-footer-brand { }
.rbp-footer-logo {
  display: inline-flex; align-items: center; gap: 10px;
  text-decoration: none; color: #fff; margin-bottom: 20px;
}
.rbp-footer-logo-mark {
  width: 38px; height: 38px; border-radius: 11px;
  background: linear-gradient(135deg, var(--rbp-blue) 0%, var(--rbp-indigo) 100%);
  display: grid; place-items: center; font-size: 14px; font-weight: 900; color: #fff;
  box-shadow: 0 4px 14px rgba(29,78,216,.3); flex-shrink: 0;
}
.rbp-footer-logo-text { display: flex; flex-direction: column; }
.rbp-footer-logo-name { font-size: 13.5px; font-weight: 900; letter-spacing: -.02em; color: #fff; }
.rbp-footer-logo-tag { font-size: 10.5px; color: var(--rbp-slate-500); font-weight: 600; margin-top: 2px; }
.rbp-footer-brand-desc { font-size: 13.5px; color: var(--rbp-slate-500); line-height: 1.7; margin-bottom: 24px; font-weight: 500; }
.rbp-footer-trust {
  display: flex; flex-direction: column; gap: 8px;
}
.rbp-footer-trust-item {
  display: flex; align-items: center; gap: 8px;
  font-size: 12px; color: var(--rbp-slate-400); font-weight: 600;
}
.rbp-footer-trust-item svg { color: #22c55e; flex-shrink: 0; }
.rbp-footer-social {
  display: flex; gap: 8px; margin-top: 24px;
}
.rbp-footer-social-link {
  width: 34px; height: 34px; border-radius: 9px;
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  display: grid; place-items: center; color: var(--rbp-slate-400);
  text-decoration: none; transition: all .15s ease;
  font-size: 13px;
}
.rbp-footer-social-link:hover { background: rgba(29,78,216,.25); color: #93c5fd; border-color: rgba(29,78,216,.4); }

/* Nav columns */
.rbp-footer-col { }
.rbp-footer-col-title {
  font-size: 10px; font-weight: 900; text-transform: uppercase;
  letter-spacing: .13em; color: var(--rbp-slate-500);
  margin: 0 0 16px; padding-bottom: 12px;
  border-bottom: 1px solid rgba(255,255,255,.07);
}
.rbp-footer-nav { list-style: none; padding: 0; margin: 0; display: grid; gap: 2px; }
.rbp-footer-nav li a {
  display: flex; align-items: center; gap: 7px;
  padding: 7px 8px; border-radius: 8px;
  color: var(--rbp-slate-400); text-decoration: none;
  font-size: 13px; font-weight: 600; line-height: 1.3;
  transition: color .12s, background .12s;
}
.rbp-footer-nav li a:hover { color: #93c5fd; background: rgba(29,78,216,.12); }
.rbp-footer-nav li a .rbp-ft-badge {
  display: inline-block; padding: 2px 7px;
  background: rgba(29,78,216,.2); color: #93c5fd;
  border-radius: 999px; font-size: 10px; font-weight: 800;
  margin-left: auto;
}
.rbp-footer-nav li a .rbp-ft-badge.new { background: rgba(34,197,94,.15); color: #86efac; }

/* ── Bottom bar ───────────────────────────────────────── */
.rbp-footer-bottom {
  width: min(100% - 2.5rem, 1280px);
  margin-inline: auto;
  padding: 28px 0;
  margin-top: 52px;
  border-top: 1px solid rgba(255,255,255,.07);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
}
.rbp-footer-copy {
  font-size: 12px; color: var(--rbp-slate-600); font-weight: 500; line-height: 1.5;
}
.rbp-footer-copy a { color: var(--rbp-slate-500); text-decoration: none; }
.rbp-footer-copy a:hover { color: #93c5fd; }
.rbp-footer-legal {
  display: flex; gap: 20px; flex-wrap: wrap;
}
.rbp-footer-legal a {
  font-size: 12px; color: var(--rbp-slate-600); text-decoration: none;
  font-weight: 600; transition: color .12s;
}
.rbp-footer-legal a:hover { color: #93c5fd; }

/* ── Newsletter strip ─────────────────────────────────── */
.rbp-footer-newsletter {
  width: min(100% - 2.5rem, 1280px);
  margin-inline: auto;
  padding: 32px 0;
  border-bottom: 1px solid rgba(255,255,255,.07);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
}
.rbp-footer-newsletter-text h3 {
  font-size: 16px; font-weight: 900; color: #fff;
  margin: 0 0 4px; letter-spacing: -.02em;
}
.rbp-footer-newsletter-text p { font-size: 13px; color: var(--rbp-slate-500); margin: 0; font-weight: 500; }
.rbp-footer-newsletter-form {
  display: flex; gap: 8px; flex-shrink: 0; min-width: 340px;
}
.rbp-footer-newsletter-form input {
  flex: 1; border: 1px solid rgba(255,255,255,.12);
  border-radius: 11px; padding: 11px 16px;
  background: rgba(255,255,255,.06); color: #fff;
  font-size: 13.5px; outline: none; font-weight: 500;
  transition: border-color .15s, background .15s;
}
.rbp-footer-newsletter-form input::placeholder { color: var(--rbp-slate-600); }
.rbp-footer-newsletter-form input:focus { border-color: var(--rbp-blue); background: rgba(29,78,216,.1); }
.rbp-footer-newsletter-form button {
  padding: 11px 20px; background: var(--rbp-blue); color: #fff;
  border: none; border-radius: 11px; font-size: 13px; font-weight: 800;
  cursor: pointer; white-space: nowrap; transition: background .15s, transform .15s;
}
.rbp-footer-newsletter-form button:hover { background: #2563eb; transform: translateY(-1px); }

/* ── Responsive ───────────────────────────────────────── */
@media (max-width: 1100px) {
  .rbp-footer-grid { grid-template-columns: 1fr 1fr 1fr; }
  .rbp-footer-brand { grid-column: 1 / -1; }
  .rbp-footer-newsletter { flex-direction: column; align-items: flex-start; gap: 20px; }
  .rbp-footer-newsletter-form { min-width: unset; width: 100%; }
}
@media (max-width: 768px) {
  .rbp-footer-grid { grid-template-columns: 1fr 1fr; }
  .rbp-footer-cta-inner { grid-template-columns: 1fr; text-align: center; }
  .rbp-footer-cta-sub { max-width: 100%; margin-inline: auto; }
  .rbp-footer-cta-actions { flex-direction: row; justify-content: center; }
  .rbp-footer-bottom { flex-direction: column; align-items: flex-start; }
}
@media (max-width: 479px) {
  .rbp-footer-grid { grid-template-columns: 1fr; }
  .rbp-footer-newsletter-form { flex-direction: column; }
}
</style>

