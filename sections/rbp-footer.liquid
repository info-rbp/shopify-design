{% comment %}
  RBP Footer — Trimmed global footer
  Phase 2 footer update aligned to approved navigation.
  Columns: Services, Business Essentials, Membership, Support.
{% endcomment %}

<style>
.rbp-footer {
  --rbp-footer-blue: #1d4ed8;
  --rbp-footer-blue-mid: #2563eb;
  --rbp-footer-navy: #020617;
  --rbp-footer-slate: #94a3b8;
  --rbp-footer-muted: #64748b;
  --rbp-footer-border: rgba(255,255,255,.09);
  font-family: var(--font-body-family, system-ui, sans-serif);
  color: #e2e8f0;
}
.rbp-footer *, .rbp-footer *::before, .rbp-footer *::after { box-sizing: border-box; }
.rbp-footer a { color: inherit; text-decoration: none; }
.rbp-footer-wrap { width: min(100% - 2.5rem, 1280px); margin-inline: auto; }
.rbp-footer-cta { background: linear-gradient(135deg, #0f172a 0%, #172554 58%, #0f172a 100%); border-top: 1px solid rgba(255,255,255,.06); }
.rbp-footer-cta-inner { min-height: 190px; display: grid; grid-template-columns: minmax(0,1fr) auto; align-items: center; gap: 32px; padding: 48px 0; }
.rbp-footer-eyebrow { display: inline-flex; margin: 0 0 12px; color: #93c5fd; font-size: 11px; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
.rbp-footer-cta h2 { margin: 0; color: #fff; font-size: clamp(26px, 4vw, 44px); line-height: 1.08; letter-spacing: -.035em; font-weight: 950; }
.rbp-footer-cta p { margin: 12px 0 0; max-width: 650px; color: var(--rbp-footer-slate); font-size: 15px; line-height: 1.65; }
.rbp-footer-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: flex-end; }
.rbp-footer-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 46px; padding: 0 18px; border-radius: 13px; font-size: 13px; font-weight: 900; white-space: nowrap; transition: background .16s ease, border-color .16s ease, transform .16s ease; }
.rbp-footer-btn-primary { background: var(--rbp-footer-blue); color: #fff; box-shadow: 0 10px 28px rgba(29,78,216,.3); }
.rbp-footer-btn-primary:hover { background: var(--rbp-footer-blue-mid); transform: translateY(-1px); }
.rbp-footer-btn-secondary { background: rgba(255,255,255,.08); color: #e2e8f0; border: 1px solid rgba(255,255,255,.16); }
.rbp-footer-btn-secondary:hover { background: rgba(255,255,255,.13); border-color: rgba(255,255,255,.24); }
.rbp-footer-main { background: var(--rbp-footer-navy); }
.rbp-footer-grid { display: grid; grid-template-columns: minmax(250px, 1.3fr) repeat(4, minmax(145px, 1fr)); gap: 34px; padding: 52px 0 42px; }
.rbp-footer-brand-link { display: inline-flex; align-items: center; gap: 11px; margin-bottom: 16px; }
.rbp-footer-logo { width: 38px; height: 38px; border-radius: 12px; display: grid; place-items: center; background: linear-gradient(135deg, var(--rbp-footer-blue), #4f46e5); color: #fff; font-size: 14px; font-weight: 950; }
.rbp-footer-brand-name { display: block; color: #fff; font-size: 14px; font-weight: 950; letter-spacing: -.02em; }
.rbp-footer-brand-sub { display: block; margin-top: 3px; color: var(--rbp-footer-muted); font-size: 11px; font-weight: 650; }
.rbp-footer-brand p { margin: 0 0 18px; color: var(--rbp-footer-slate); font-size: 13.5px; line-height: 1.7; max-width: 330px; }
.rbp-footer-note { display: grid; gap: 7px; margin-top: 16px; }
.rbp-footer-note span { color: var(--rbp-footer-muted); font-size: 12px; line-height: 1.45; }
.rbp-footer-col h3 { margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid var(--rbp-footer-border); color: #fff; font-size: 11px; font-weight: 950; letter-spacing: .13em; text-transform: uppercase; }
.rbp-footer-nav { display: grid; gap: 2px; list-style: none; margin: 0; padding: 0; }
.rbp-footer-nav a { display: inline-flex; width: 100%; border-radius: 9px; padding: 7px 8px; color: var(--rbp-footer-slate); font-size: 13px; font-weight: 650; line-height: 1.35; }
.rbp-footer-nav a:hover { color: #bfdbfe; background: rgba(29,78,216,.13); }
.rbp-footer-bottom { border-top: 1px solid var(--rbp-footer-border); padding: 22px 0 28px; display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; }
.rbp-footer-copy { margin: 0; color: var(--rbp-footer-muted); font-size: 12px; line-height: 1.55; }
.rbp-footer-legal { display: flex; flex-wrap: wrap; gap: 14px; }
.rbp-footer-legal a { color: var(--rbp-footer-muted); font-size: 12px; font-weight: 650; }
.rbp-footer-legal a:hover { color: #bfdbfe; }
@media (max-width: 1100px) { .rbp-footer-grid { grid-template-columns: 1fr 1fr 1fr; } .rbp-footer-brand { grid-column: 1 / -1; } }
@media (max-width: 760px) { .rbp-footer-cta-inner { grid-template-columns: 1fr; text-align: left; } .rbp-footer-actions { justify-content: flex-start; } .rbp-footer-grid { grid-template-columns: 1fr 1fr; gap: 26px; } .rbp-footer-brand { grid-column: 1 / -1; } }
@media (max-width: 520px) { .rbp-footer-wrap { width: min(100% - 1.5rem, 1280px); } .rbp-footer-grid { grid-template-columns: 1fr; } .rbp-footer-actions, .rbp-footer-btn { width: 100%; } .rbp-footer-bottom { align-items: flex-start; } }
</style>

<footer class="rbp-footer" role="contentinfo" aria-label="Site footer">
  <section class="rbp-footer-cta" aria-label="Footer call to action">
    <div class="rbp-footer-wrap rbp-footer-cta-inner">
      <div>
        <span class="rbp-footer-eyebrow">Start with the right support pathway</span>
        <h2>Practical business support for decisions, delivery and operations.</h2>
        <p>Use Remote Business Partner to access advisory, consulting, implementation support, operational resources, business essentials, membership and help from one connected platform.</p>
      </div>
      <div class="rbp-footer-actions">
        <a class="rbp-footer-btn rbp-footer-btn-primary" href="/pages/business-health-check">Start with a Health Check</a>
        <a class="rbp-footer-btn rbp-footer-btn-secondary" href="/pages/contact">Contact RBP</a>
      </div>
    </div>
  </section>

  <section class="rbp-footer-main" aria-label="Footer navigation">
    <div class="rbp-footer-wrap">
      <div class="rbp-footer-grid">
        <div class="rbp-footer-brand">
          <a class="rbp-footer-brand-link" href="/" aria-label="Remote Business Partner home">
            <span class="rbp-footer-logo" aria-hidden="true">RBP</span>
            <span>
              <span class="rbp-footer-brand-name">Remote Business Partner</span>
              <span class="rbp-footer-brand-sub">Australia's Business Support Platform</span>
            </span>
          </a>
          <p>Advisory, consulting, implementation support, operational resources and essential business services for Australian businesses.</p>
          <div class="rbp-footer-note" aria-label="Store notes">
            <span>Secure checkout through Shopify.</span>
            <span>Digital products and services may use onboarding-led delivery where required.</span>
          </div>
        </div>

        <nav class="rbp-footer-col" aria-label="Services footer links">
          <h3>Services</h3>
          <ul class="rbp-footer-nav">
            <li><a href="/pages/core-services">Advisory</a></li>
            <li><a href="/collections/on-demand-services">Consulting</a></li>
            <li><a href="/pages/custom-solutions">Implementation</a></li>
            <li><a href="/pages/our-process">Operations</a></li>
          </ul>
        </nav>

        <nav class="rbp-footer-col" aria-label="Business essentials footer links">
          <h3>Business Essentials</h3>
          <ul class="rbp-footer-nav">
            <li><a href="/pages/business-nbn">Business NBN</a></li>
            <li><a href="/pages/business-finance">Business Finance</a></li>
            <li><a href="/pages/business-insurance">Business Insurance</a></li>
            <li><a href="/pages/marketplace">Marketplace</a></li>
            <li><a href="/pages/offers">Partner Offers</a></li>
          </ul>
        </nav>

        <nav class="rbp-footer-col" aria-label="Membership footer links">
          <h3>Membership</h3>
          <ul class="rbp-footer-nav">
            <li><a href="/pages/membership">Overview</a></li>
            <li><a href="/pages/membership#benefits">Member Benefits</a></li>
            <li><a href="/pages/membership#faq">Frequently Asked Questions</a></li>
            <li><a href="/pages/sign-up-today">Sign Up</a></li>
          </ul>
        </nav>

        <nav class="rbp-footer-col" aria-label="Support footer links">
          <h3>Support</h3>
          <ul class="rbp-footer-nav">
            <li><a href="/pages/help-centre">Help Centre</a></li>
            <li><a href="/pages/nbn-support-education">NBN Support &amp; Education</a></li>
            <li><a href="/pages/contact">Contact</a></li>
            <li><a href="/pages/about">About</a></li>
            <li><a href="/policies/privacy-policy">Policies</a></li>
          </ul>
        </nav>
      </div>

      <div class="rbp-footer-bottom">
        <p class="rbp-footer-copy">&copy; {{ 'now' | date: '%Y' }} Remote Business Partner. All rights reserved. Prices are in AUD where applicable.</p>
        <nav class="rbp-footer-legal" aria-label="Legal links">
          <a href="/policies/privacy-policy">Privacy</a>
          <a href="/policies/terms-of-service">Terms</a>
          <a href="/policies/refund-policy">Refunds</a>
          <a href="/pages/contact">Contact</a>
        </nav>
      </div>
    </div>
  </section>
</footer>

{% schema %}
{
  "name": "RBP Footer",
  "tag": "div",
  "class": "rbp-footer-wrapper",
  "settings": [],
  "presets": [{ "name": "RBP Footer" }]
}
{% endschema %}
