  RBP Header — Approved IA Navigation
  Phase 2 header navigation update.
  Top-level navigation: Advisory, Consulting, Implementation, Operations, Essentials, Membership, Support.
{% endcomment %}

<style>
:root {
  --rbp-blue: #1d4ed8;
  --rbp-blue-mid: #2563eb;
  --rbp-blue-dark: #1e3a8a;
  --rbp-indigo: #4f46e5;
  --rbp-slate-950: #020617;
  --rbp-slate-900: #0f172a;
  --rbp-slate-800: #1e293b;
  --rbp-slate-700: #334155;
  --rbp-slate-600: #475569;
  --rbp-slate-500: #64748b;
  --rbp-slate-400: #94a3b8;
  --rbp-slate-200: #e2e8f0;
  --rbp-slate-100: #f1f5f9;
  --rbp-slate-50: #f8fafc;
  --rbp-white: #ffffff;
  --rbp-border: rgba(15, 23, 42, .1);
  --rbp-header-h: 72px;
}
.rbp-header { position: sticky; top: 0; z-index: 100; font-family: var(--font-body-family, system-ui, sans-serif); }
.rbp-header *, .rbp-header *::before, .rbp-header *::after { box-sizing: border-box; }
.rbp-announce { background: linear-gradient(90deg, var(--rbp-blue-dark), var(--rbp-blue), var(--rbp-indigo)); color: #fff; text-align: center; font-size: 12.5px; font-weight: 750; padding: 9px 44px 9px 20px; position: relative; }
.rbp-announce a { color: #bfdbfe; text-decoration: underline; text-underline-offset: 2px; }
.rbp-announce-close { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,.16); border: 0; color: #fff; cursor: pointer; width: 22px; height: 22px; border-radius: 6px; display: grid; place-items: center; }
.rbp-nav-shell { background: rgba(255,255,255,.98); backdrop-filter: blur(16px) saturate(180%); -webkit-backdrop-filter: blur(16px) saturate(180%); border-bottom: 1px solid var(--rbp-border); box-shadow: 0 1px 0 rgba(15,23,42,.04); position: relative; }
.rbp-nav-inner { width: min(100% - 2.5rem, 1440px); margin-inline: auto; min-height: var(--rbp-header-h); display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 22px; }
.rbp-brand { display: inline-flex; align-items: center; gap: 11px; color: var(--rbp-slate-900); text-decoration: none; min-width: 220px; }
.rbp-brand-logo { width: 38px; height: 38px; border-radius: 12px; background: linear-gradient(135deg, var(--rbp-blue), var(--rbp-indigo)); color: #fff; display: grid; place-items: center; font-size: 15px; font-weight: 950; box-shadow: 0 4px 12px rgba(29,78,216,.28); }
.rbp-brand-text { display: flex; flex-direction: column; line-height: 1; }
.rbp-brand-name { font-size: 14.5px; font-weight: 950; letter-spacing: -.025em; color: var(--rbp-slate-900); }
.rbp-brand-tagline { font-size: 10.5px; color: var(--rbp-slate-500); font-weight: 650; margin-top: 4px; }
.rbp-desktop-nav { display: flex; align-items: center; justify-content: center; gap: 4px; }
.rbp-nav-btn { appearance: none; border: 0; background: transparent; display: inline-flex; align-items: center; gap: 5px; padding: 10px 12px; border-radius: 12px; color: var(--rbp-slate-700); font-size: 13.5px; font-weight: 850; cursor: pointer; text-decoration: none; white-space: nowrap; transition: background .16s ease, color .16s ease; }
.rbp-nav-btn:hover, .rbp-nav-btn[aria-expanded="true"] { background: #eff6ff; color: var(--rbp-blue); }
.rbp-nav-btn svg { width: 10px; height: 10px; transition: transform .2s ease; }
.rbp-nav-btn[aria-expanded="true"] svg { transform: rotate(180deg); }
.rbp-nav-actions { display: flex; align-items: center; gap: 8px; justify-content: flex-end; }
.rbp-search-trigger, .rbp-cart-btn, .rbp-mobile-toggle { width: 38px; height: 38px; border: 1px solid var(--rbp-border); border-radius: 12px; background: #fff; color: var(--rbp-slate-600); cursor: pointer; display: grid; place-items: center; text-decoration: none; transition: border-color .15s, background .15s, color .15s; }
.rbp-search-trigger:hover, .rbp-cart-btn:hover, .rbp-mobile-toggle:hover { border-color: var(--rbp-blue); color: var(--rbp-blue); background: #eff6ff; }
.rbp-header-cta { display: inline-flex; align-items: center; justify-content: center; gap: 7px; padding: 10px 16px; border-radius: 12px; font-size: 13px; font-weight: 850; text-decoration: none; white-space: nowrap; transition: all .15s ease; }
.rbp-header-cta-outline { border: 1px solid var(--rbp-border); color: var(--rbp-slate-700); background: #fff; }
.rbp-header-cta-outline:hover { border-color: var(--rbp-blue); color: var(--rbp-blue); background: #eff6ff; }
.rbp-header-cta-primary { background: var(--rbp-blue); color: #fff; border: 1px solid transparent; box-shadow: 0 4px 14px rgba(29,78,216,.24); }
.rbp-header-cta-primary:hover { background: var(--rbp-blue-mid); transform: translateY(-1px); }
.rbp-cart-btn { position: relative; }
.rbp-cart-count { position: absolute; top: -6px; right: -6px; min-width: 17px; height: 17px; border-radius: 999px; background: var(--rbp-blue); color: #fff; font-size: 9px; font-weight: 950; display: grid; place-items: center; padding: 0 4px; }
.rbp-mobile-toggle { display: none; place-items: center; }
.rbp-mobile-toggle span { display: block; width: 17px; height: 2px; background: currentColor; border-radius: 999px; margin: 2px 0; transition: transform .2s ease, opacity .2s ease; }
.rbp-mobile-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
.rbp-mobile-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.rbp-mobile-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
.rbp-mega-wrap { position: absolute; left: 0; right: 0; top: calc(100% + 1px); background: #fff; border-top: 1px solid var(--rbp-border); border-bottom: 1px solid var(--rbp-border); box-shadow: 0 32px 72px rgba(15,23,42,.13); opacity: 0; visibility: hidden; pointer-events: none; transform: translateY(-6px); transition: opacity .2s ease, transform .2s ease, visibility .2s; z-index: 99; }
.rbp-mega-wrap.is-open { opacity: 1; visibility: visible; pointer-events: auto; transform: none; }
.rbp-mega-content { width: min(100% - 2.5rem, 1440px); margin-inline: auto; padding: 32px 0 36px; display: grid; grid-template-columns: 280px repeat(3, minmax(0, 1fr)); gap: 32px; }
.rbp-mega-content.cols-2 { grid-template-columns: 280px repeat(2, minmax(0, 1fr)); }
.rbp-mega-sidebar { border-right: 1px solid var(--rbp-border); padding-right: 28px; }
.rbp-mega-hub { display: flex; align-items: center; gap: 12px; background: linear-gradient(135deg, var(--rbp-blue), var(--rbp-indigo)); color: #fff; text-decoration: none; border-radius: 16px; padding: 15px 16px; margin-bottom: 16px; box-shadow: 0 8px 24px rgba(29,78,216,.22); }
.rbp-mega-hub-icon { width: 38px; height: 38px; background: rgba(255,255,255,.18); border-radius: 11px; display: grid; place-items: center; font-size: 17px; flex-shrink: 0; }
.rbp-mega-hub-label { display: block; font-size: 13.5px; font-weight: 950; }
.rbp-mega-hub-sub { display: block; font-size: 11px; opacity: .78; font-weight: 650; margin-top: 2px; }
.rbp-mega-section-label, .rbp-mega-col-title { font-size: 10.5px; font-weight: 950; text-transform: uppercase; letter-spacing: .12em; color: var(--rbp-slate-400); margin: 12px 0 10px; }
.rbp-mega-col-title { padding-bottom: 10px; border-bottom: 1px solid var(--rbp-border); margin-top: 0; }
.rbp-mega-quick-link { display: flex; align-items: center; gap: 8px; padding: 8px 8px; border-radius: 9px; color: var(--rbp-slate-600); text-decoration: none; font-size: 12.5px; font-weight: 750; }
.rbp-mega-quick-link:hover { background: #f8fafc; color: var(--rbp-blue); }
.rbp-mega-quick-link-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--rbp-slate-300); flex-shrink: 0; }
.rbp-mega-link-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 3px; }
.rbp-mega-link { display: flex; align-items: flex-start; gap: 10px; padding: 10px; border-radius: 12px; text-decoration: none; color: var(--rbp-slate-800); transition: background .12s, color .12s; }
.rbp-mega-link:hover { background: #f0f9ff; color: var(--rbp-blue); }
.rbp-mega-link-icon { width: 33px; height: 33px; border-radius: 10px; background: var(--rbp-slate-100); display: grid; place-items: center; font-size: 14px; flex-shrink: 0; margin-top: 1px; }
.rbp-mega-link:hover .rbp-mega-link-icon { background: #dbeafe; }
.rbp-mega-link-name { display: block; font-size: 13.5px; font-weight: 850; line-height: 1.22; }
.rbp-mega-link-desc { display: block; font-size: 11.5px; color: var(--rbp-slate-500); line-height: 1.4; font-weight: 550; margin-top: 2px; }
.rbp-mega-footer { grid-column: 1 / -1; padding-top: 20px; border-top: 1px solid var(--rbp-border); display: flex; align-items: center; justify-content: space-between; gap: 16px; }
.rbp-mega-footer-text { font-size: 13px; color: var(--rbp-slate-500); font-weight: 650; margin: 0; }
.rbp-mega-footer-text strong { color: var(--rbp-slate-800); font-weight: 850; }
.rbp-mega-footer-actions { display: flex; gap: 10px; }
.rbp-mega-footer-btn { display: inline-flex; align-items: center; gap: 7px; padding: 10px 16px; border-radius: 12px; font-size: 12.5px; font-weight: 850; text-decoration: none; transition: all .15s ease; }
.rbp-mega-footer-btn-ghost { background: #f8fafc; color: var(--rbp-slate-700); border: 1px solid var(--rbp-border); }
.rbp-mega-footer-btn-primary { background: var(--rbp-blue); color: #fff; }
.rbp-search-overlay { position: absolute; left: 0; right: 0; top: 100%; background: rgba(255,255,255,.98); backdrop-filter: blur(16px); border-bottom: 1px solid var(--rbp-border); box-shadow: 0 16px 48px rgba(15,23,42,.1); padding: 20px 0; z-index: 98; opacity: 0; visibility: hidden; pointer-events: none; transform: translateY(-8px); transition: all .2s ease; }
.rbp-search-overlay.is-open { opacity: 1; visibility: visible; pointer-events: auto; transform: none; }
.rbp-search-inner { width: min(100% - 2.5rem, 720px); margin-inline: auto; }
.rbp-search-form { display: flex; align-items: center; gap: 12px; border: 1.5px solid var(--rbp-blue); border-radius: 15px; background: #fff; padding: 10px 16px; box-shadow: 0 0 0 4px rgba(29,78,216,.08); }
.rbp-search-form input { flex: 1; border: 0; outline: 0; background: transparent; font-size: 15px; color: var(--rbp-slate-900); }
.rbp-search-submit { border: 0; background: var(--rbp-blue); color: #fff; padding: 9px 15px; border-radius: 10px; cursor: pointer; font-size: 12.5px; font-weight: 850; }
.rbp-search-hints { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
.rbp-search-hint { padding: 5px 12px; background: var(--rbp-slate-100); border-radius: 999px; font-size: 12px; font-weight: 750; color: var(--rbp-slate-600); text-decoration: none; }
.rbp-mobile-nav { position: absolute; left: 0; right: 0; top: 100%; background: #fff; border-bottom: 1px solid var(--rbp-border); box-shadow: 0 20px 50px rgba(15,23,42,.12); max-height: calc(100dvh - var(--rbp-header-h) - 40px); overflow-y: auto; display: none; }
.rbp-mobile-nav.is-open { display: block; }
.rbp-mobile-search-bar { padding: 14px 20px; border-bottom: 1px solid var(--rbp-border); }
.rbp-mobile-search-bar form { display: flex; align-items: center; gap: 10px; border: 1px solid var(--rbp-border); border-radius: 12px; background: var(--rbp-slate-50); padding: 10px 14px; }
.rbp-mobile-search-bar input { flex: 1; border: 0; outline: 0; background: transparent; font-size: 14px; color: var(--rbp-slate-900); }
.rbp-mobile-item { border-bottom: 1px solid rgba(15,23,42,.06); }
.rbp-mobile-item-btn { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 15px 20px; background: transparent; border: 0; cursor: pointer; color: var(--rbp-slate-800); font-size: 14px; font-weight: 850; text-align: left; text-decoration: none; }
.rbp-mobile-item[open] .rbp-mobile-item-btn svg { transform: rotate(180deg); }
.rbp-mobile-sub { background: var(--rbp-slate-50); }
.rbp-mobile-sub a { display: block; padding: 11px 20px 11px 36px; color: var(--rbp-slate-600); font-size: 13px; font-weight: 750; text-decoration: none; border-bottom: 1px solid rgba(15,23,42,.05); }
.rbp-mobile-sub a:hover { color: var(--rbp-blue); background: #eff6ff; }
.rbp-mobile-cta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 16px 20px; border-top: 1px solid var(--rbp-border); }
.rbp-mobile-cta { display: grid; place-items: center; padding: 12px; border-radius: 12px; font-size: 13px; font-weight: 850; text-decoration: none; text-align: center; }
.rbp-mobile-cta-outline { border: 1px solid var(--rbp-border); color: var(--rbp-slate-700); background: #fff; }
.rbp-mobile-cta-primary { background: var(--rbp-blue); color: #fff; }
@media (max-width: 1240px) { .rbp-nav-inner { gap: 14px; } .rbp-brand { min-width: 190px; } .rbp-nav-btn { padding-inline: 9px; font-size: 13px; } .rbp-header-cta-outline { display: none; } }
@media (max-width: 1080px) { .rbp-desktop-nav, .rbp-search-trigger { display: none; } .rbp-mobile-toggle { display: block; } .rbp-nav-inner { grid-template-columns: auto 1fr auto; } }
@media (max-width: 520px) { .rbp-brand-tagline { display: none; } .rbp-header-cta-primary { display: none; } .rbp-nav-inner { width: calc(100% - 1.5rem); gap: 10px; } .rbp-brand { min-width: 0; } .rbp-brand-name { font-size: 13px; } .rbp-announce { font-size: 11.5px; } }
</style>

