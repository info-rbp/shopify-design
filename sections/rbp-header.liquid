{% comment %}
  RBP Header — G1 Global IA Cleanup
  Version: 2.0 | Modern mega-nav, correct service architecture
  Navigation: Home · Membership · Core Services · On-Demand · Business NBN · Marketplace · Custom Solutions · Resources · Contact
  Removed: Managed Services (not a public offer)
{% endcomment %}

<style>
:root {
  --rbp-blue: #1d4ed8;
  --rbp-blue-mid: #2563eb;
  --rbp-blue-dark: #1e3a8a;
  --rbp-indigo: #4f46e5;
  --rbp-slate-950: #020617;
  --rbp-slate-900: #0f172a;
  --rbp-slate-800: #1e293b;
  --rbp-slate-700: #334155;
  --rbp-slate-600: #475569;
  --rbp-slate-500: #64748b;
  --rbp-slate-400: #94a3b8;
  --rbp-slate-200: #e2e8f0;
  --rbp-slate-100: #f1f5f9;
  --rbp-slate-50: #f8fafc;
  --rbp-white: #ffffff;
  --rbp-border: rgba(15,23,42,.09);
  --rbp-header-h: 64px;
}

/* ── Base ─────────────────────────────────────────────── */
.rbp-header { position: sticky; top: 0; z-index: 100; font-family: var(--font-body-family, system-ui, sans-serif); }
.rbp-header *, .rbp-header *::before, .rbp-header *::after { box-sizing: border-box; }

/* ── Announcement bar ─────────────────────────────────── */
.rbp-announce {
  background: linear-gradient(90deg, var(--rbp-blue-dark) 0%, var(--rbp-blue) 50%, var(--rbp-indigo) 100%);
  color: #fff;
  text-align: center;
  font-size: 12.5px;
  font-weight: 700;
  letter-spacing: .01em;
  padding: 9px 20px;
  position: relative;
}
.rbp-announce a { color: #bfdbfe; text-decoration: underline; text-underline-offset: 2px; }
.rbp-announce-close {
  position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
  background: rgba(255,255,255,.15); border: none; color: #fff; cursor: pointer;
  width: 22px; height: 22px; border-radius: 6px; font-size: 14px; display: grid; place-items: center;
}
.rbp-announce-close:hover { background: rgba(255,255,255,.25); }

/* ── Main nav shell ───────────────────────────────────── */
.rbp-nav-shell {
  background: rgba(255,255,255,.97);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border-bottom: 1px solid var(--rbp-border);
  box-shadow: 0 1px 0 0 rgba(15,23,42,.04);
}
.rbp-nav-inner {
  width: min(100% - 2.5rem, 1280px);
  margin-inline: auto;
  height: var(--rbp-header-h);
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 24px;
}

/* ── Brand ────────────────────────────────────────────── */
.rbp-brand {
  display: inline-flex; align-items: center; gap: 11px;
  text-decoration: none; color: var(--rbp-slate-900);
  flex-shrink: 0;
}
.rbp-brand-logo {
  width: 36px; height: 36px; border-radius: 10px;
  background: linear-gradient(135deg, var(--rbp-blue) 0%, var(--rbp-indigo) 100%);
  color: #fff; display: grid; place-items: center;
  font-size: 15px; font-weight: 900; letter-spacing: -.02em;
  box-shadow: 0 4px 12px rgba(29,78,216,.28);
  flex-shrink: 0;
}
.rbp-brand-text { display: flex; flex-direction: column; line-height: 1; }
.rbp-brand-name { font-size: 14px; font-weight: 900; letter-spacing: -.025em; color: var(--rbp-slate-900); }
.rbp-brand-tagline { font-size: 10.5px; color: var(--rbp-slate-500); font-weight: 600; margin-top: 2px; letter-spacing: .01em; }

/* ── Desktop nav ──────────────────────────────────────── */
.rbp-desktop-nav {
  display: flex; align-items: center; justify-content: center; gap: 2px;
}
.rbp-nav-item { position: static; }

.rbp-nav-btn {
  appearance: none; border: none; background: transparent;
  display: inline-flex; align-items: center; gap: 5px;
  padding: 8px 11px; border-radius: 10px;
  color: var(--rbp-slate-600); font-size: 13.5px; font-weight: 800;
  cursor: pointer; text-decoration: none; white-space: nowrap;
  transition: background .15s ease, color .15s ease;
  letter-spacing: -.01em;
}
.rbp-nav-btn:hover, .rbp-nav-btn[aria-expanded="true"] {
  background: #eff6ff; color: var(--rbp-blue);
}
.rbp-nav-btn svg { width: 10px; height: 10px; transition: transform .2s ease; }
.rbp-nav-btn[aria-expanded="true"] svg { transform: rotate(180deg); }

/* ── Mega panel ───────────────────────────────────────── */
.rbp-mega-wrap {
  position: absolute; left: 0; right: 0;
  top: calc(var(--rbp-header-h) + 1px);
  background: #fff;
  border-top: 1px solid var(--rbp-border);
  border-bottom: 1px solid var(--rbp-border);
  box-shadow: 0 32px 72px rgba(15,23,42,.13);
  opacity: 0; visibility: hidden; pointer-events: none;
  transform: translateY(-6px);
  transition: opacity .2s ease, transform .2s ease, visibility .2s;
  z-index: 99;
}
.rbp-mega-wrap.is-open {
  opacity: 1; visibility: visible; pointer-events: auto; transform: none;
}
.rbp-mega-content {
  width: min(100% - 2.5rem, 1280px);
  margin-inline: auto;
  padding: 32px 0 36px;
  display: grid;
  gap: 36px;
}
.rbp-mega-content.cols-2 { grid-template-columns: 260px 1fr; }
.rbp-mega-content.cols-3 { grid-template-columns: 260px 1fr 1fr; }
.rbp-mega-content.cols-4 { grid-template-columns: 260px 1fr 1fr 1fr; }

/* Mega sidebar */
.rbp-mega-sidebar { border-right: 1px solid var(--rbp-border); padding-right: 28px; }
.rbp-mega-hub {
  display: flex; align-items: center; gap: 12px;
  background: linear-gradient(135deg, var(--rbp-blue) 0%, var(--rbp-indigo) 100%);
  color: #fff; text-decoration: none; border-radius: 16px;
  padding: 14px 16px; margin-bottom: 16px;
  box-shadow: 0 8px 24px rgba(29,78,216,.22);
  transition: transform .18s ease, box-shadow .18s ease;
}
.rbp-mega-hub:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(29,78,216,.3); }
.rbp-mega-hub-icon { width: 36px; height: 36px; background: rgba(255,255,255,.18); border-radius: 10px; display: grid; place-items: center; font-size: 16px; flex-shrink: 0; }
.rbp-mega-hub-text { display: flex; flex-direction: column; gap: 2px; }
.rbp-mega-hub-label { font-size: 13px; font-weight: 900; letter-spacing: -.01em; }
.rbp-mega-hub-sub { font-size: 11px; opacity: .75; font-weight: 600; }

.rbp-mega-section-label {
  font-size: 10px; font-weight: 900; text-transform: uppercase;
  letter-spacing: .12em; color: var(--rbp-slate-400);
  margin: 12px 0 8px;
}
.rbp-mega-quick-link {
  display: flex; align-items: center; gap: 8px;
  padding: 7px 8px; border-radius: 9px;
  color: var(--rbp-slate-600); text-decoration: none;
  font-size: 12.5px; font-weight: 700;
  transition: background .12s, color .12s;
}
.rbp-mega-quick-link:hover { background: #f8fafc; color: var(--rbp-blue); }
.rbp-mega-quick-link-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--rbp-slate-300); flex-shrink: 0; }

/* Mega column */
.rbp-mega-col { }
.rbp-mega-col-title {
  font-size: 10px; font-weight: 900; text-transform: uppercase;
  letter-spacing: .12em; color: var(--rbp-slate-400);
  margin: 0 0 12px; padding-bottom: 10px;
  border-bottom: 1px solid var(--rbp-border);
}
.rbp-mega-link-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 2px; }
.rbp-mega-link {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 9px 10px; border-radius: 11px;
  text-decoration: none; color: var(--rbp-slate-800);
  transition: background .12s, color .12s;
}
.rbp-mega-link:hover { background: #f0f9ff; color: var(--rbp-blue); }
.rbp-mega-link-icon {
  width: 32px; height: 32px; border-radius: 9px;
  background: var(--rbp-slate-100); display: grid; place-items: center;
  font-size: 14px; flex-shrink: 0; margin-top: 1px;
}
.rbp-mega-link:hover .rbp-mega-link-icon { background: #dbeafe; }
.rbp-mega-link-body { display: flex; flex-direction: column; gap: 2px; }
.rbp-mega-link-name { font-size: 13.5px; font-weight: 800; letter-spacing: -.01em; line-height: 1.2; }
.rbp-mega-link-desc { font-size: 11.5px; color: var(--rbp-slate-500); line-height: 1.4; font-weight: 500; }

/* Mega footer CTA bar */
.rbp-mega-footer {
  grid-column: 1 / -1;
  padding-top: 20px;
  border-top: 1px solid var(--rbp-border);
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
}
.rbp-mega-footer-text { font-size: 13px; color: var(--rbp-slate-500); font-weight: 600; }
.rbp-mega-footer-text strong { color: var(--rbp-slate-800); font-weight: 800; }
.rbp-mega-footer-actions { display: flex; gap: 10px; }
.rbp-mega-footer-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 9px 16px; border-radius: 11px;
  font-size: 12.5px; font-weight: 800; text-decoration: none;
  transition: all .15s ease;
}
.rbp-mega-footer-btn-ghost { background: #f8fafc; color: var(--rbp-slate-700); border: 1px solid var(--rbp-border); }
.rbp-mega-footer-btn-ghost:hover { background: #f1f5f9; color: var(--rbp-slate-900); }
.rbp-mega-footer-btn-primary { background: var(--rbp-blue); color: #fff; box-shadow: 0 4px 14px rgba(29,78,216,.22); }
.rbp-mega-footer-btn-primary:hover { background: var(--rbp-blue-mid); transform: translateY(-1px); }

/* ── Header actions (right) ───────────────────────────── */
.rbp-nav-actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

.rbp-search-trigger {
  width: 36px; height: 36px; border: 1px solid var(--rbp-border);
  border-radius: 10px; background: #fff; color: var(--rbp-slate-600);
  cursor: pointer; display: grid; place-items: center;
  transition: border-color .15s, background .15s, color .15s;
}
.rbp-search-trigger:hover { border-color: var(--rbp-blue); color: var(--rbp-blue); background: #eff6ff; }

.rbp-header-cta {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 9px 16px; border-radius: 11px; font-size: 13px; font-weight: 800;
  text-decoration: none; white-space: nowrap; transition: all .15s ease;
}
.rbp-header-cta-outline {
  border: 1px solid var(--rbp-border); color: var(--rbp-slate-700); background: #fff;
}
.rbp-header-cta-outline:hover { border-color: var(--rbp-blue); color: var(--rbp-blue); background: #eff6ff; }
.rbp-header-cta-primary {
  background: var(--rbp-blue); color: #fff;
  box-shadow: 0 4px 14px rgba(29,78,216,.24);
  border: 1px solid transparent;
}
.rbp-header-cta-primary:hover { background: var(--rbp-blue-mid); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(29,78,216,.3); }

.rbp-cart-btn {
  position: relative; width: 36px; height: 36px;
  border: 1px solid var(--rbp-border); border-radius: 10px;
  background: #fff; color: var(--rbp-slate-600);
  cursor: pointer; display: grid; place-items: center;
  text-decoration: none; transition: border-color .15s, background .15s, color .15s;
}
.rbp-cart-btn:hover { border-color: var(--rbp-blue); color: var(--rbp-blue); background: #eff6ff; }
.rbp-cart-count {
  position: absolute; top: -5px; right: -5px;
  min-width: 16px; height: 16px; border-radius: 999px;
  background: var(--rbp-blue); color: #fff;
  font-size: 9px; font-weight: 900; display: grid; place-items: center;
  padding: 0 3px;
}

/* ── Mobile toggle ────────────────────────────────────── */
.rbp-mobile-toggle {
  display: none; appearance: none; border: 1px solid var(--rbp-border);
  background: #fff; border-radius: 10px; padding: 8px;
  color: var(--rbp-slate-700); cursor: pointer;
  flex-direction: column; gap: 4px; align-items: center; justify-content: center;
  width: 36px; height: 36px;
}
.rbp-mobile-toggle span {
  display: block; width: 16px; height: 2px; background: currentColor;
  border-radius: 999px; transition: transform .2s ease, opacity .2s ease;
}
.rbp-mobile-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
.rbp-mobile-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.rbp-mobile-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

/* ── Search overlay ───────────────────────────────────── */
.rbp-search-overlay {
  position: absolute; left: 0; right: 0; top: 100%;
  background: rgba(255,255,255,.98); backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--rbp-border);
  box-shadow: 0 16px 48px rgba(15,23,42,.1);
  padding: 20px 0; z-index: 98;
  opacity: 0; visibility: hidden; pointer-events: none;
  transform: translateY(-8px);
  transition: all .2s ease;
}
.rbp-search-overlay.is-open { opacity: 1; visibility: visible; pointer-events: auto; transform: none; }
.rbp-search-inner { width: min(100% - 2.5rem, 680px); margin-inline: auto; }
.rbp-search-form {
  display: flex; align-items: center; gap: 12px;
  border: 1.5px solid var(--rbp-blue); border-radius: 14px;
  background: #fff; padding: 10px 16px;
  box-shadow: 0 0 0 4px rgba(29,78,216,.08);
}
.rbp-search-form input {
  flex: 1; border: none; outline: none; background: transparent;
  font-size: 15px; color: var(--rbp-slate-900); font-weight: 500;
}
.rbp-search-form input::placeholder { color: var(--rbp-slate-400); }
.rbp-search-submit {
  border: none; background: var(--rbp-blue); color: #fff;
  padding: 8px 14px; border-radius: 9px; cursor: pointer;
  font-size: 12.5px; font-weight: 800; transition: background .15s;
}
.rbp-search-submit:hover { background: var(--rbp-blue-mid); }
.rbp-search-hints { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
.rbp-search-hint {
  padding: 5px 12px; background: var(--rbp-slate-100); border-radius: 999px;
  font-size: 12px; font-weight: 700; color: var(--rbp-slate-600);
  text-decoration: none; transition: background .12s, color .12s;
}
.rbp-search-hint:hover { background: #dbeafe; color: var(--rbp-blue); }

/* ── Mobile drawer ────────────────────────────────────── */
.rbp-mobile-nav {
  position: absolute; left: 0; right: 0; top: 100%;
  background: #fff; border-bottom: 1px solid var(--rbp-border);
  box-shadow: 0 20px 50px rgba(15,23,42,.12);
  max-height: calc(100dvh - var(--rbp-header-h) - 40px);
  overflow-y: auto;
  display: none;
}
.rbp-mobile-nav.is-open { display: block; }
.rbp-mobile-search-bar {
  padding: 14px 20px; border-bottom: 1px solid var(--rbp-border);
}
.rbp-mobile-search-bar form {
  display: flex; align-items: center; gap: 10px;
  border: 1px solid var(--rbp-border); border-radius: 11px;
  background: var(--rbp-slate-50); padding: 9px 14px;
}
.rbp-mobile-search-bar input {
  flex: 1; border: none; outline: none; background: transparent;
  font-size: 14px; color: var(--rbp-slate-900);
}
.rbp-mobile-accordion { }
.rbp-mobile-item { border-bottom: 1px solid rgba(15,23,42,.06); }
.rbp-mobile-item-btn {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: 15px 20px;
  background: transparent; border: none; cursor: pointer;
  color: var(--rbp-slate-800); font-size: 14px; font-weight: 850;
  text-align: left; text-decoration: none;
}
.rbp-mobile-item-btn svg { color: var(--rbp-slate-400); transition: transform .2s; flex-shrink: 0; }
.rbp-mobile-item[open] .rbp-mobile-item-btn svg { transform: rotate(180deg); }
.rbp-mobile-sub { background: var(--rbp-slate-50); }
.rbp-mobile-sub a {
  display: block; padding: 11px 20px 11px 36px;
  color: var(--rbp-slate-600); font-size: 13px; font-weight: 700;
  text-decoration: none; border-bottom: 1px solid rgba(15,23,42,.05);
}
.rbp-mobile-sub a:hover { color: var(--rbp-blue); background: #eff6ff; }
.rbp-mobile-cta-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  padding: 16px 20px; border-top: 1px solid var(--rbp-border);
}
.rbp-mobile-cta {
  display: grid; place-items: center; padding: 12px; border-radius: 11px;
  font-size: 13px; font-weight: 800; text-decoration: none; text-align: center;
  transition: all .15s ease;
}
.rbp-mobile-cta-outline {
  border: 1px solid var(--rbp-border); color: var(--rbp-slate-700); background: #fff;
}
.rbp-mobile-cta-primary { background: var(--rbp-blue); color: #fff; }

/* ── Responsive ───────────────────────────────────────── */
@media (max-width: 1023px) {
  .rbp-desktop-nav, .rbp-search-trigger, .rbp-header-cta-outline { display: none; }
  .rbp-mobile-toggle { display: flex; }
  .rbp-nav-inner { grid-template-columns: auto 1fr auto; }
}
@media (max-width: 479px) {
  .rbp-brand-tagline { display: none; }
  .rbp-header-cta-primary { display: none; }
  .rbp-nav-inner { width: calc(100% - 1.5rem); gap: 12px; }
}
</style>

{%- liquid
  assign cart_count = cart.item_count
-%}

<header class="rbp-header" id="rbp-site-header" role="banner">

  {%- comment %} ── Announcement bar ── {% endcomment %}
  <div class="rbp-announce" id="rbp-announce" role="region" aria-label="Announcement">
    🚀 <strong>Remote Business Partner</strong> — Australia's business support platform. 
    <a href="/pages/membership">Join as a Member</a> and unlock exclusive rates &amp; priority access.
    <button class="rbp-announce-close" onclick="this.closest('#rbp-announce').remove()" aria-label="Close announcement">✕</button>
  </div>

  <div class="rbp-nav-shell" style="position:relative;">
    <nav class="rbp-nav-inner" aria-label="Main navigation">

      {%- comment %} ── Brand ── {% endcomment %}
      <a href="/" class="rbp-brand" aria-label="Remote Business Partner — Home">
        <div class="rbp-brand-logo" aria-hidden="true">RBP</div>
        <div class="rbp-brand-text">
          <span class="rbp-brand-name">Remote Business Partner</span>
          <span class="rbp-brand-tagline">Australia's Business Support Platform</span>
        </div>
      </a>

      {%- comment %} ── Desktop nav ── {% endcomment %}
      <div class="rbp-desktop-nav" role="menubar" aria-label="Site navigation">

        {%- comment %} Home ── {% endcomment %}
        <a href="/" class="rbp-nav-btn" role="menuitem">Home</a>

        {%- comment %} Membership ── {% endcomment %}
        <button class="rbp-nav-btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="mega-membership" data-mega="membership">
          Membership
          <svg viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg>
        </button>

        {%- comment %} Core Services ── {% endcomment %}
        <button class="rbp-nav-btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="mega-core" data-mega="core">
          Core Services
          <svg viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg>
        </button>

        {%- comment %} On-Demand ── {% endcomment %}
        <button class="rbp-nav-btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="mega-ondemand" data-mega="ondemand">
          On-Demand
          <svg viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg>
        </button>

        {%- comment %} Business NBN ── {% endcomment %}
        <a href="/pages/business-nbn" class="rbp-nav-btn" role="menuitem">Business NBN</a>

        {%- comment %} Marketplace ── {% endcomment %}
        <button class="rbp-nav-btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="mega-marketplace" data-mega="marketplace">
          Marketplace
          <svg viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg>
        </button>

        {%- comment %} Custom Solutions ── {% endcomment %}
        <button class="rbp-nav-btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="mega-custom" data-mega="custom">
          Custom Solutions
          <svg viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg>
        </button>

        {%- comment %} Resources ── {% endcomment %}
        <button class="rbp-nav-btn" role="menuitem" aria-haspopup="true" aria-expanded="false" aria-controls="mega-resources" data-mega="resources">
          Resources
          <svg viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg>
        </button>

      </div>

      {%- comment %} ── Actions ── {% endcomment %}
      <div class="rbp-nav-actions">
        <button class="rbp-search-trigger" id="rbp-search-btn" aria-label="Search" aria-expanded="false" aria-controls="rbp-search-overlay">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        <a href="/account/login" class="rbp-header-cta rbp-header-cta-outline" aria-label="Login to your account">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="12" cy="7" r="4"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/></svg>
          Login
        </a>
        <a href="/pages/membership" class="rbp-header-cta rbp-header-cta-primary">
