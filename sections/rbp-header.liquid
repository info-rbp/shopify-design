<script>
(function() {
  'use strict';
  const header = document.getElementById('rbp-site-header');
  if (!header) return;

  // ── Mega nav ────────────────────────────────────────────
  const navBtns = header.querySelectorAll('.rbp-nav-btn[data-mega]');
  const megaPanels = header.querySelectorAll('.rbp-mega-wrap');
  let activePanel = null;
  let closeTimer = null;

  function openMega(panelId, btn) {
    clearTimeout(closeTimer);
    if (activePanel && activePanel.id !== panelId) closeMega();
    const panel = document.getElementById(panelId);
    if (!panel) return;
    panel.classList.add('is-open');
    panel.setAttribute('aria-hidden', 'false');
    btn.setAttribute('aria-expanded', 'true');
    activePanel = panel;
  }

  function closeMega() {
    if (!activePanel) return;
    activePanel.classList.remove('is-open');
    activePanel.setAttribute('aria-hidden', 'true');
    const btn = header.querySelector(`[aria-controls="${activePanel.id}"]`);
    if (btn) btn.setAttribute('aria-expanded', 'false');
    activePanel = null;
  }

  function scheduleClose() {
    closeTimer = setTimeout(closeMega, 180);
  }

  navBtns.forEach(btn => {
    const panelId = 'mega-' + btn.dataset.mega;
    btn.addEventListener('mouseenter', () => openMega(panelId, btn));
    btn.addEventListener('mouseleave', scheduleClose);
    btn.addEventListener('click', () => {
      if (activePanel && activePanel.id === panelId) { closeMega(); }
      else { openMega(panelId, btn); }
    });
    btn.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeMega();
    });
  });

  megaPanels.forEach(panel => {
    panel.addEventListener('mouseenter', () => clearTimeout(closeTimer));
    panel.addEventListener('mouseleave', scheduleClose);
  });

  document.addEventListener('click', e => {
    if (!header.contains(e.target)) closeMega();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeMega();
  });

  // ── Search overlay ───────────────────────────────────────
  const searchBtn = document.getElementById('rbp-search-btn');
  const searchOverlay = document.getElementById('rbp-search-overlay');
  if (searchBtn && searchOverlay) {
    searchBtn.addEventListener('click', () => {
      const isOpen = searchOverlay.classList.toggle('is-open');
      searchBtn.setAttribute('aria-expanded', isOpen);
      searchOverlay.setAttribute('aria-hidden', !isOpen);
      if (isOpen) {
        closeMega();
        const input = searchOverlay.querySelector('input');
        if (input) setTimeout(() => input.focus(), 50);
      }
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && searchOverlay.classList.contains('is-open')) {
        searchOverlay.classList.remove('is-open');
        searchBtn.setAttribute('aria-expanded', 'false');
        searchOverlay.setAttribute('aria-hidden', 'true');
        searchBtn.focus();
      }
    });
    document.addEventListener('click', e => {
      if (!header.contains(e.target) && searchOverlay.classList.contains('is-open')) {
        searchOverlay.classList.remove('is-open');
        searchBtn.setAttribute('aria-expanded', 'false');
        searchOverlay.setAttribute('aria-hidden', 'true');
      }
    });
  }

  // ── Mobile drawer ────────────────────────────────────────
  const mobileToggle = document.getElementById('rbp-mobile-toggle');
  const mobileNav = document.getElementById('rbp-mobile-nav');
  if (mobileToggle && mobileNav) {
    mobileToggle.addEventListener('click', () => {
      const isOpen = mobileNav.classList.toggle('is-open');
      mobileToggle.setAttribute('aria-expanded', isOpen);
      mobileNav.setAttribute('aria-hidden', !isOpen);
      mobileToggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });
  }

  // ── Scroll shadow ────────────────────────────────────────
  const shell = header.querySelector('.rbp-nav-shell');
  if (shell) {
    const observer = new IntersectionObserver(
      ([e]) => shell.classList.toggle('is-scrolled', !e.isIntersecting),
      { threshold: [1], rootMargin: '-1px 0px 0px 0px' }
    );
    const sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none;';
    document.body.prepend(sentinel);
    observer.observe(sentinel);
    const style = document.createElement('style');
    style.textContent = '.rbp-nav-shell.is-scrolled { box-shadow: 0 4px 20px rgba(15,23,42,.10); }';
    document.head.appendChild(style);
  }
})();
</script>

