<style>
.rbp-help{--b:#1d4ed8;--bd:#1e3a8a;--bs:#dbeafe;--s9:#0f172a;--s7:#334155;--s6:#475569;--s0:#f8fafc;--br:rgba(15,23,42,.1);--br2:rgba(15,23,42,.16);--sh:0 22px 55px rgba(15,23,42,.14);background:#fff;color:var(--s9)}.rbp-help *{box-sizing:border-box}.rbp-help a{text-decoration:none;color:inherit}.rbp-help-c{width:min(100% - 3rem,1200px);margin-inline:auto}.rbp-help-hero{overflow:hidden;color:#fff;background:radial-gradient(ellipse at top right,rgba(59,130,246,.24),transparent 58%),linear-gradient(135deg,#0f172a 0%,#172554 52%,#0f172a 100%)}.rbp-help-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(310px,.72fr);gap:56px;align-items:center;min-height:560px;padding:86px 0}.rbp-help-ey{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:#dbeafe;color:#1d4ed8;font-size:12px;line-height:1;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-help-hero .rbp-help-ey{background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28)}.rbp-help-dot{width:7px;height:7px;border-radius:999px;background:currentColor}.rbp-help-h1{margin:16px 0 0;color:#fff;font-size:clamp(42px,6vw,78px);line-height:1.02;letter-spacing:-.045em;font-weight:900}.rbp-help-h2{margin:14px 0 0;color:var(--s9);font-size:clamp(30px,4vw,48px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-help-p{margin:16px 0 0;color:var(--s6);font-size:16px;line-height:1.75}.rbp-help-hero .rbp-help-p{color:#cbd5e1;font-size:18px;max-width:760px}.rbp-help-search{margin-top:28px;display:flex;gap:10px;background:#fff;border-radius:18px;padding:8px;box-shadow:0 18px 40px rgba(2,6,23,.28)}.rbp-help-search input{flex:1;min-width:0;border:0;outline:0;color:#0f172a;font-size:16px;padding:12px 14px;background:transparent}.rbp-help-search button{border:0;border-radius:14px;background:#1d4ed8;color:#fff;font-weight:900;padding:12px 18px;cursor:pointer}.rbp-help-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:22px}.rbp-help-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:14px;padding:14px 18px;border:1px solid transparent;font-size:14px;font-weight:900;line-height:1}.rbp-help-btn-p{background:#1d4ed8;color:#fff;box-shadow:0 18px 36px rgba(29,78,216,.24)}.rbp-help-btn-g{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.24)}.rbp-help-btn-o{background:#fff;color:var(--s7);border-color:var(--br2)}.rbp-help-check{width:18px;height:18px;border-radius:999px;display:inline-grid;place-items:center;background:#3b82f6;color:#fff;font-size:12px;line-height:1;flex:0 0 auto}.rbp-help-proof{display:flex;flex-wrap:wrap;gap:14px 20px;margin-top:26px}.rbp-help-proof span{display:inline-flex;align-items:center;gap:8px;color:#cbd5e1;font-size:14px;font-weight:750}.rbp-help-hero-card{border:1px solid rgba(255,255,255,.14);border-radius:28px;background:rgba(255,255,255,.08);box-shadow:0 35px 75px rgba(30,64,175,.32);padding:26px}.rbp-help-hero-card h3{margin:0 0 12px;color:#fff;font-size:22px;font-weight:900}.rbp-help-hero-card p{margin:0;color:#cbd5e1;line-height:1.7}.rbp-help-sec{padding:74px 0}.rbp-help-muted{background:#f8fafc}.rbp-help-head{max-width:780px;margin:0 auto 36px;text-align:center}.rbp-help-grid{display:grid;gap:20px}.rbp-help-g2{grid-template-columns:repeat(2,minmax(0,1fr))}.rbp-help-g3{grid-template-columns:repeat(3,minmax(0,1fr))}.rbp-help-g4{grid-template-columns:repeat(4,minmax(0,1fr))}.rbp-help-card{display:block;background:#fff;border:1px solid var(--br);border-radius:24px;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05);transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}.rbp-help-card:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(15,23,42,.08);border-color:var(--br2)}.rbp-help-icon{width:46px;height:46px;border-radius:16px;display:grid;place-items:center;margin-bottom:16px;background:#dbeafe;color:#1d4ed8;font-weight:900}.rbp-help-title{margin:0 0 8px;color:#0f172a;font-size:18px;font-weight:900}.rbp-help-text,.rbp-help-rich,.rbp-help-rich p,.rbp-help-rich li{margin:0;color:#64748b;line-height:1.65;font-size:14px}.rbp-help-link{display:inline-flex;align-items:center;gap:6px;margin-top:16px;color:#1d4ed8;font-size:13px;font-weight:900}.rbp-help-topic{display:flex;align-items:center;justify-content:space-between;gap:16px;border:1px solid var(--br);border-radius:18px;background:#fff;padding:16px 18px;color:#334155;font-weight:850}.rbp-help-process{counter-reset:s}.rbp-help-step{position:relative;padding-left:54px}.rbp-help-step+.rbp-help-step{margin-top:20px}.rbp-help-step:before{counter-increment:s;content:counter(s,decimal-leading-zero);position:absolute;top:0;left:0;width:40px;height:40px;border-radius:999px;background:#1d4ed8;color:#fff;display:grid;place-items:center;font-size:12px;font-weight:900}.rbp-help-step h3{margin:0 0 5px;color:#0f172a;font-size:16px;font-weight:900}.rbp-help-step p{margin:0;color:#64748b;line-height:1.65}.rbp-help-panel{background:#fff;border:1px solid var(--br);border-radius:28px;padding:28px;box-shadow:0 18px 45px rgba(15,23,42,.08)}.rbp-help-panel-blue{background:linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;border:0;box-shadow:var(--sh)}.rbp-help-panel-blue .rbp-help-h2,.rbp-help-panel-blue .rbp-help-title{color:#fff}.rbp-help-panel-blue .rbp-help-p,.rbp-help-panel-blue .rbp-help-text{color:#dbeafe}.rbp-help-list{display:grid;gap:10px;margin:18px 0 0;padding:0;list-style:none}.rbp-help-list li{display:grid;grid-template-columns:22px minmax(0,1fr);gap:10px;color:#64748b;line-height:1.55;font-size:14px}.rbp-help-faq details{background:#fff;border:1px solid var(--br);border-radius:18px;padding:0 18px}.rbp-help-faq details+details{margin-top:12px}.rbp-help-faq summary{cursor:pointer;padding:18px 0;color:#0f172a;font-weight:900}.rbp-help-faq summary::-webkit-details-marker{display:none}.rbp-help-faq div{padding-bottom:18px;color:#64748b;line-height:1.7}.rbp-help-cta{border-radius:32px;background:radial-gradient(circle at top right,rgba(255,255,255,.18),transparent 35%),linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;padding:clamp(28px,5vw,56px);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:28px;align-items:center}.rbp-help-cta h2{margin:0;color:#fff;font-size:clamp(28px,4vw,48px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-help-cta p{margin:12px 0 0;color:#dbeafe;line-height:1.7;max-width:740px}.rbp-help-quick{display:flex;flex-wrap:wrap;gap:10px;margin-top:22px}.rbp-help-quick a{border:1px solid var(--br2);border-radius:999px;padding:9px 13px;color:#334155;background:#fff;font-size:13px;font-weight:850}@media(max-width:989px){.rbp-help-hero-in,.rbp-help-g2,.rbp-help-g3,.rbp-help-g4,.rbp-help-cta{grid-template-columns:1fr}.rbp-help-hero-card{display:none}.rbp-help-head{text-align:left;margin-inline:0}.rbp-help-search{display:grid}.rbp-help-search button{width:100%}}@media(max-width:749px){.rbp-help-c{width:min(100% - 2rem,1200px)}.rbp-help-sec{padding:54px 0}.rbp-help-hero-in{padding:68px 0}.rbp-help-btn{width:100%}}
</style>
{%- liquid
  assign help_categories = page.metafields.custom.help_categories.value
  assign help_articles = page.metafields.custom.featured_help_articles.value
  assign help_faqs = page.metafields.custom.featured_faqs.value
  assign support_pathways = page.metafields.custom.support_pathways.value
  assign related_processes = page.metafields.custom.related_processes.value
  assign hero_heading = page.metafields.custom.help_hero_heading.value | default: 'How can we help?'
  assign hero_text = page.metafields.custom.help_hero_text.value | default: 'Find answers, support pathways, product guidance, document help, membership information, Business NBN support and service guidance in one place.'
  assign primary_label = page.metafields.custom.primary_cta_label.value | default: 'Contact Support'
  assign primary_link = page.metafields.custom.primary_cta_link.value | default: '/pages/contact'
  assign alt_label = page.metafields.custom.alternate_cta_label.value | default: 'Browse Help Topics'
  assign alt_link = page.metafields.custom.alternate_link.value | default: '#browse-topics'
-%}
<div class="rbp-help">
<section class="rbp-help-hero"><div class="rbp-help-c"><div class="rbp-help-hero-in"><div><div class="rbp-help-ey"><span class="rbp-help-dot"></span>Help Centre</div><h1 class="rbp-help-h1">{{ hero_heading }}</h1><p class="rbp-help-p">{{ hero_text }}</p><form class="rbp-help-search" action="{{ routes.search_url }}" method="get" role="search"><input type="search" name="q" placeholder="Search help topics, products, documents or services" aria-label="Search Help Centre"><button type="submit">Search</button></form><div class="rbp-help-actions"><a class="rbp-help-btn rbp-help-btn-p" href="{{ primary_link }}">{{ primary_label }} -&gt;</a><a class="rbp-help-btn rbp-help-btn-g" href="{{ alt_link }}">{{ alt_label }}</a></div><div class="rbp-help-proof"><span><span class="rbp-help-check">✓</span>Document order support</span><span><span class="rbp-help-check">✓</span>Membership help</span><span><span class="rbp-help-check">✓</span>Business NBN support</span><span><span class="rbp-help-check">✓</span>Business service guidance</span></div></div><aside class="rbp-help-hero-card"><h3>Start with the right pathway</h3><p>Use the Help Centre to find answers or route your enquiry to the right part of Remote Business Partner without sending a majestic mystery message like “help pls”.</p></aside></div></div></section>
<section class="rbp-help-sec rbp-help-muted" id="browse-topics"><div class="rbp-help-c"><div class="rbp-help-head"><div class="rbp-help-ey">Browse by category</div><h2 class="rbp-help-h2">Choose the area you need help with</h2><p class="rbp-help-p">Each category points you toward the right support pathway, page or action.</p></div><div class="rbp-help-grid rbp-help-g4">{%- if help_categories != blank -%}{%- for item in help_categories -%}{%- assign c = item.fields -%}{%- assign destination = c.landing_page.value.url | default: '/pages/contact' -%}<a class="rbp-help-card" href="{{ destination }}"><div class="rbp-help-icon">{{ c.icon_label.value | default: forloop.index }}</div><h3 class="rbp-help-title">{{ c.title.value }}</h3><p class="rbp-help-text">{{ c.short_description.value }}</p><span class="rbp-help-link">{{ c.cta_label.value | default: 'Learn more' }} -&gt;</span></a>{%- endfor -%}{%- else -%}<a class="rbp-help-card" href="#document-help"><div class="rbp-help-icon">DO</div><h3 class="rbp-help-title">Document Orders</h3><p class="rbp-help-text">Templates, suites, toolkits, onboarding forms, delivery and revisions.</p><span class="rbp-help-link">Get document help -&gt;</span></a><a class="rbp-help-card" href="/pages/membership"><div class="rbp-help-icon">MB</div><h3 class="rbp-help-title">Membership</h3><p class="rbp-help-text">Plan selection, inclusions and member access questions.</p><span class="rbp-help-link">Compare membership -&gt;</span></a><a class="rbp-help-card" href="/pages/business-nbn"><div class="rbp-help-icon">NB</div><h3 class="rbp-help-title">Business NBN</h3><p class="rbp-help-text">Availability, plans, provisioning, billing and service issues.</p><span class="rbp-help-link">Get NBN help -&gt;</span></a><a class="rbp-help-card" href="/pages/contact"><div class="rbp-help-icon">GS</div><h3 class="rbp-help-title">General Support</h3><p class="rbp-help-text">Anything that refuses to fit neatly into a category, because naturally it exists.</p><span class="rbp-help-link">Submit enquiry -&gt;</span></a>{%- endif -%}</div></div></section>
<section class="rbp-help-sec"><div class="rbp-help-c"><div class="rbp-help-head"><div class="rbp-help-ey">Popular topics</div><h2 class="rbp-help-h2">Common starting points</h2></div><div class="rbp-help-grid rbp-help-g3">{%- if help_articles != blank -%}{%- for item in help_articles -%}{%- assign a = item.fields -%}<a class="rbp-help-topic" href="{{ a.primary_cta_link.value | default: '/pages/contact' }}">{{ a.title.value }} <span>-&gt;</span></a>{%- endfor -%}{%- else -%}<a class="rbp-help-topic" href="#document-help">How document orders work <span>-&gt;</span></a><a class="rbp-help-topic" href="/pages/business-nbn">How to check Business NBN availability <span>-&gt;</span></a><a class="rbp-help-topic" href="/pages/contact">Support for an existing order <span>-&gt;</span></a>{%- endif -%}</div></div></section>
<section class="rbp-help-sec rbp-help-muted" id="document-help"><div class="rbp-help-c"><div class="rbp-help-grid rbp-help-g2"><div><div class="rbp-help-ey">Document order help</div><h2 class="rbp-help-h2">How document orders work</h2><p class="rbp-help-p">Document products are not treated as generic documents. The process is designed to collect your business information, prepare the document and give you a chance to review it.</p><div class="rbp-help-quick"><a href="/collections/templates">Templates</a><a href="/pages/documentation-suite">Documentation Suites</a><a href="/pages/toolkits">Toolkits</a><a href="/pages/contact">Request document help</a></div></div><div class="rbp-help-panel"><div class="rbp-help-process">{%- assign rendered_process = false -%}{%- if related_processes != blank -%}{%- for p in related_processes limit: 1 -%}{%- assign steps = p.fields.steps.value -%}{%- if steps != blank -%}{%- assign rendered_process = true -%}{%- for st in steps -%}<div class="rbp-help-step"><h3>{{ st.fields.step_title.value }}</h3><p>{{ st.fields.step_description.value }}</p></div>{%- endfor -%}{%- endif -%}{%- endfor -%}{%- endif -%}{%- unless rendered_process -%}<div class="rbp-help-step"><h3>Customer buys the document</h3><p>Complete checkout and keep your order confirmation.</p></div><div class="rbp-help-step"><h3>Customer completes the onboarding form</h3><p>Provide the business information required to prepare the document.</p></div><div class="rbp-help-step"><h3>Customer waits for delivery</h3><p>The document is prepared and delivered according to the stated timeframe.</p></div><div class="rbp-help-step"><h3>Customer reviews the order</h3><p>Review the document and check that it reflects the information provided.</p></div><div class="rbp-help-step"><h3>Customer asks for revisions or uses it immediately</h3><p>Request revisions where included or available, or start using the document.</p></div>{%- endunless -%}</div></div></div></div></section>
<section class="rbp-help-sec"><div class="rbp-help-c"><div class="rbp-help-grid rbp-help-g2"><div class="rbp-help-panel rbp-help-panel-blue"><h2 class="rbp-help-h2">Need more help?</h2><p class="rbp-help-p">Send us the details and we will route your enquiry to the right support pathway.</p><div class="rbp-help-actions"><a class="rbp-help-btn rbp-help-btn-g" href="/pages/contact">Contact Support -&gt;</a><a class="rbp-help-btn rbp-help-btn-g" href="/pages/membership">Ask About Membership</a></div></div><div class="rbp-help-panel"><h3 class="rbp-help-title">Support pathways</h3><ul class="rbp-help-list">{%- if support_pathways != blank -%}{%- for item in support_pathways -%}{%- assign p = item.fields -%}<li><span class="rbp-help-check">✓</span><span><strong>{{ p.title.value }}</strong>: {{ p.description.value }}</span></li>{%- endfor -%}{%- else -%}<li><span class="rbp-help-check">✓</span><span>Self-service: browse FAQs, guides and product pages.</span></li><li><span class="rbp-help-check">✓</span><span>Product/order support: use the contact form with your order number.</span></li><li><span class="rbp-help-check">✓</span><span>NBN support: availability, plans, provisioning and service issues.</span></li>{%- endif -%}</ul></div></div></div></section>
<section class="rbp-help-sec rbp-help-muted" id="help-faq"><div class="rbp-help-c"><div class="rbp-help-grid rbp-help-g2"><div><div class="rbp-help-ey">FAQ</div><h2 class="rbp-help-h2">Common Help Centre questions</h2><p class="rbp-help-p">Answers for the predictable questions, because apparently every business still needs a maze reduction department.</p></div><div class="rbp-help-faq">{%- if help_faqs != blank -%}{%- for item in help_faqs -%}{%- assign f = item.fields -%}<details {% if forloop.first %}open{% endif %}><summary>{{ f.question.value }}</summary><div>{{ f.answer | metafield_tag }}</div></details>{%- endfor -%}{%- else -%}<details open><summary>Where do I start if I am not sure what I need?</summary><div>Start with the closest help category, or use the contact form and choose General Support.</div></details><details><summary>How do document orders work?</summary><div>Buy the document, complete onboarding, wait for delivery, review the document, then request revisions where available or use it immediately.</div></details><details><summary>How do I contact support about an existing order?</summary><div>Use the contact form and include your order number, product name and preferred contact method.</div></details>{%- endif -%}</div></div></div></section>
<section class="rbp-help-sec"><div class="rbp-help-c"><div class="rbp-help-cta"><div><h2>Still need help?</h2><p>Submit the details once and let us route the enquiry properly. A modest victory over inbox chaos.</p></div><div class="rbp-help-actions"><a class="rbp-help-btn rbp-help-btn-g" href="/pages/contact">Contact Support</a><a class="rbp-help-btn rbp-help-btn-g" href="/pages/resources">Browse Resources</a></div></div></div></section>
</div>
{% schema %}{"name":"RBP Help Centre","settings":[],"presets":[{"name":"RBP Help Centre"}]}{% endschema %}