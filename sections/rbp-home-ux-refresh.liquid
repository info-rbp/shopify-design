  border: 1px solid var(--rbp-line);
}
.rbp-mini strong { display: block; color: var(--rbp-ink); font-size: 16px; line-height: 1.25; font-weight: 900; }
.rbp-mini span { display: block; margin-top: 9px; color: var(--rbp-text); font-size: 14px; line-height: 1.58; }

.rbp-split { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.rbp-split-card {
  position: relative;
  overflow: hidden;
  padding: 42px;
  border-radius: 28px;
  color: var(--rbp-white);
  min-height: 100%;
}
.rbp-split-card::before { content: ""; position: absolute; width: 300px; height: 300px; right: -80px; top: -100px; border-radius: 999px; background: rgba(255,255,255,.08); }
.rbp-split-card--member { background: linear-gradient(135deg, #1d4ed8, #132f68); }
.rbp-split-card--partner { background: linear-gradient(135deg, #0f766e, #0b1224); }
.rbp-split-card > * { position: relative; z-index: 1; }
