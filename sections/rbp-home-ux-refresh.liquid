  font-size: 12px;
  letter-spacing: .06em;
}
.rbp-card h3 { color: var(--rbp-ink); font-size: 20px; line-height: 1.18; letter-spacing: -.02em; font-weight: 900; }
.rbp-card p { margin-top: 12px; color: var(--rbp-text); font-size: 15px; line-height: 1.68; }
.rbp-card__link { display: inline-flex; margin-top: 20px; align-items: center; gap: 7px; color: var(--card-accent, var(--rbp-blue)); font-size: 13px; font-weight: 850; }

.rbp-process {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
  counter-reset: rbp-step;
}
.rbp-step {
  position: relative;
  padding: 28px;
  border-radius: var(--rbp-radius);
  background: var(--rbp-white);
  border: 1px solid var(--rbp-line);
}
.rbp-step::before {
  counter-increment: rbp-step;
  content: "0" counter(rbp-step);
  display: inline-flex;
  margin-bottom: 22px;
  color: var(--rbp-blue);
  font-size: 13px;
  font-weight: 950;
  letter-spacing: .08em;
}
.rbp-step h3 { font-size: 18px; font-weight: 900; letter-spacing: -.015em; }
.rbp-step p { margin-top: 10px; color: var(--rbp-text); font-size: 14px; line-height: 1.65; }

.rbp-pathways {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px;
}
.rbp-pathway {
  display: grid;
  grid-template-columns: 68px minmax(0, 1fr);
  gap: 20px;
  align-items: start;
  padding: 28px;
  border-radius: var(--rbp-radius);
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.055);
