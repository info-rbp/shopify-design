}
.rbp-finder h2 { color: var(--rbp-white); font-size: 23px; line-height: 1.15; letter-spacing: -.02em; font-weight: 900; }
.rbp-finder__intro { color: #9fb0c7; margin-top: 8px; font-size: 14px; line-height: 1.55; }
.rbp-finder__list { display: grid; gap: 10px; margin-top: 22px; }
.rbp-finder__item {
  display: grid;
  grid-template-columns: 42px minmax(0, 1fr) auto;
  gap: 14px;
  align-items: center;
  padding: 14px;
  border-radius: 16px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.10);
