}
.rbp-finder__item:hover { transform: translateX(4px); background: rgba(255,255,255,.115); border-color: rgba(255,255,255,.22); }
.rbp-finder__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 13px;
  background: rgba(255,255,255,.12);
  color: #bfdbfe;
  font-size: 12px;
  font-weight: 900;
  letter-spacing: .04em;
}
.rbp-finder__item strong { display: block; color: var(--rbp-white); font-size: 14px; line-height: 1.2; }
.rbp-finder__item span { display: block; color: #90a4bd; font-size: 12px; line-height: 1.45; margin-top: 4px; }
.rbp-finder__arrow { color: rgba(255,255,255,.5); font-weight: 900; }

.rbp-grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 22px; }
.rbp-grid-4 { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 18px; }
.rbp-card {
  position: relative;
  min-height: 100%;
  padding: 28px;
  border: 1px solid var(--rbp-line);
  border-radius: var(--rbp-radius);
  background: var(--rbp-white);
  box-shadow: 0 1px 0 rgba(15, 23, 42, .04);
  transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
}
.rbp-card:hover { transform: translateY(-4px); border-color: color-mix(in srgb, var(--card-accent, var(--rbp-blue)) 42%, var(--rbp-line)); box-shadow: var(--rbp-shadow-sm); }
.rbp-card::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 4px; border-radius: var(--rbp-radius) var(--rbp-radius) 0 0; background: var(--card-accent, var(--rbp-blue)); opacity: .85; }
.rbp-card__icon {
  width: 48px;
  height: 48px;
  border-radius: 15px;
