.rbp-dark-section .rbp-kicker { background: rgba(255,255,255,.1); color: #bfdbfe; border: 1px solid rgba(255,255,255,.14); }
.rbp-dark-section .rbp-title { color: var(--rbp-white); }
.rbp-dark-section .rbp-copy { color: #b6c4d8; }

.rbp-sme {
  display: grid;
  grid-template-columns: minmax(0, .95fr) minmax(0, 1.05fr);
  gap: 56px;
  align-items: center;
}
.rbp-sme .rbp-section-head { text-align: left; margin: 0; }
.rbp-sme__features { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
.rbp-mini {
