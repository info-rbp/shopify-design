}
.rbp-pathway:hover { transform: translateY(-4px); background: rgba(255,255,255,.085); border-color: rgba(255,255,255,.2); }
.rbp-pathway__mark {
  width: 68px;
  height: 68px;
  border-radius: 19px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,.1);
  color: #bfdbfe;
  font-size: 13px;
  font-weight: 950;
  letter-spacing: .05em;
}
.rbp-pathway h3 { font-size: 22px; font-weight: 900; letter-spacing: -.02em; }
.rbp-pathway p { margin-top: 8px; color: #b6c4d8; font-size: 15px; line-height: 1.65; }
.rbp-pathway span { display: inline-flex; margin-top: 16px; color: #93c5fd; font-size: 13px; font-weight: 850; }
.rbp-dark-section {
  padding: 92px 0;
  background:
