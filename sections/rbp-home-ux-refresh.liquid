  color: var(--rbp-white);
  font-size: clamp(48px, 7.4vw, 88px);
  line-height: .98;
  letter-spacing: -.065em;
  font-weight: 950;
}
.rbp-hero__text { max-width: 650px; margin-top: 26px; color: #c6d3e5; font-size: 19px; line-height: 1.74; }
.rbp-hero .rbp-actions { margin-top: 34px; }
.rbp-hero__proof {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
