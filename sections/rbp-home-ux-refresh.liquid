}
.rbp-proof-pill strong { display: block; color: var(--rbp-white); font-size: 13px; line-height: 1.25; }
.rbp-proof-pill span { display: block; color: #91a4bd; font-size: 12px; line-height: 1.45; margin-top: 4px; }

.rbp-finder {
