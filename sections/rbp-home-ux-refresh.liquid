.rbp-split-card h3 { font-size: 29px; line-height: 1.08; letter-spacing: -.03em; font-weight: 930; }
.rbp-split-card p { margin-top: 12px; color: rgba(255,255,255,.76); font-size: 15px; line-height: 1.68; }
.rbp-split-card ul { margin: 22px 0 28px; display: grid; gap: 9px; }
.rbp-split-card li { display: flex; gap: 9px; align-items: flex-start; color: rgba(255,255,255,.86); font-size: 14px; line-height: 1.45; }
.rbp-split-card li::before { content: ""; width: 7px; height: 7px; margin-top: 7px; border-radius: 999px; background: #86efac; flex: 0 0 auto; }

.rbp-resource {
  min-height: 100%;
  padding: 24px;
  border-radius: 18px;
  background: var(--rbp-white);
