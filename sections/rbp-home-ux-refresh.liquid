.rbp-resource:hover { transform: translateY(-4px); border-color: #b8c7dc; box-shadow: var(--rbp-shadow-sm); }
.rbp-resource__type { display: inline-flex; margin-bottom: 14px; padding: 4px 9px; border-radius: 999px; background: #eaf1ff; color: var(--rbp-blue); font-size: 10px; font-weight: 900; letter-spacing: .07em; text-transform: uppercase; }
.rbp-resource h3 { font-size: 16px; line-height: 1.28; letter-spacing: -.01em; font-weight: 900; }
.rbp-resource p { margin-top: 9px; color: var(--rbp-text); font-size: 13px; line-height: 1.6; }

.rbp-final { padding: 92px 0 108px; background: var(--rbp-white); }
.rbp-final__box {
  overflow: hidden;
  position: relative;
  padding: 64px 42px;
  border-radius: 30px;
  text-align: center;
  background:
    radial-gradient(circle at 20% 20%, rgba(59,130,246,.28), transparent 30%),
    linear-gradient(135deg, var(--rbp-blue) 0%, #1e40af 45%, var(--rbp-navy) 100%);
  color: var(--rbp-white);
}
.rbp-final__box::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px); background-size: 48px 48px; opacity: .45; }
.rbp-final__box > * { position: relative; z-index: 1; }
.rbp-final h2 { font-size: clamp(30px, 4vw, 48px); line-height: 1.06; letter-spacing: -.04em; font-weight: 940; }
.rbp-final p { max-width: 620px; margin: 16px auto 30px; color: #d9e5f7; font-size: 17px; line-height: 1.65; }
.rbp-final .rbp-actions { justify-content: center; }

@media (max-width: 1080px) {
  .rbp-hero__grid,
  .rbp-sme { grid-template-columns: 1fr; }
  .rbp-hero { min-height: auto; }
  .rbp-hero__proof { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .rbp-grid-3,
  .rbp-process { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .rbp-grid-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 760px) {
  .rbp-wrap { width: min(100% - 28px, 1180px); }
  .rbp-section,
  .rbp-dark-section,
  .rbp-final { padding: 68px 0; }
  .rbp-hero { padding: 70px 0 58px; }
  .rbp-hero h1 { font-size: clamp(42px, 13vw, 62px); }
  .rbp-hero__text { font-size: 17px; }
  .rbp-hero__proof,
  .rbp-grid-3,
  .rbp-grid-4,
  .rbp-process,
  .rbp-pathways,
  .rbp-sme__features,
  .rbp-split { grid-template-columns: 1fr; }
  .rbp-finder { padding: 22px; }
  .rbp-finder__item { grid-template-columns: 40px minmax(0, 1fr); }
  .rbp-finder__arrow { display: none; }
  .rbp-pathway { grid-template-columns: 1fr; }
  .rbp-split-card,
  .rbp-final__box { padding: 34px 24px; }
  .rbp-actions { width: 100%; }
  .rbp-actions .rbp-btn { flex: 1 1 100%; }
}
@media (prefers-reduced-motion: reduce) {
  .rbp-home-refresh *,
  .rbp-home-refresh *::before,
  .rbp-home-refresh *::after { transition: none !important; scroll-behavior: auto !important; }
}
</style>

