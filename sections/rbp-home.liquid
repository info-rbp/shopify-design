<style>
/* ─── RBP Homepage Tokens ────────────────────────────────────────── */
.rbp-home {
  --h-navy:        #0f172a;
  --h-navy-mid:    #172554;
  --h-blue:        #1d4ed8;
  --h-blue-light:  #3b82f6;
  --h-blue-pale:   #dbeafe;
  --h-teal:        #0d9488;
  --h-teal-pale:   #ccfbf1;
  --h-purple:      #7c3aed;
  --h-purple-pale: #ede9fe;
  --h-amber:       #d97706;
  --h-amber-pale:  #fef3c7;
  --h-green:       #059669;
  --h-green-pale:  #d1fae5;
  --h-slate-9:     #0f172a;
  --h-slate-7:     #334155;
  --h-slate-6:     #475569;
  --h-slate-4:     #94a3b8;
  --h-slate-2:     #e2e8f0;
  --h-slate-1:     #f1f5f9;
  --h-slate-0:     #f8fafc;
  --h-white:       #ffffff;
  --h-radius:      16px;
  --h-radius-lg:   24px;
  --h-shadow:      0 4px 24px rgba(15,23,42,.10);
  --h-shadow-lg:   0 16px 56px rgba(15,23,42,.14);
  background: var(--h-white); color: var(--h-slate-9);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}
.rbp-home *, .rbp-home *::before, .rbp-home *::after { box-sizing: border-box; margin: 0; }
.rbp-home a { text-decoration: none; color: inherit; }
.rbp-home ul { list-style: none; padding: 0; }
.rbp-home-c { width: min(100% - 2.5rem, 1260px); margin-inline: auto; }
.rbp-home-sec { padding: 96px 0; }
.rbp-home-sec-sm { padding: 56px 0; }
.rbp-home-muted { background: var(--h-slate-0); }

/* ─── Eyebrow ────────────────────────────────────────────────────── */
.rbp-home-eye {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; border-radius: 999px;
  font-size: 11px; font-weight: 800; letter-spacing: .10em; text-transform: uppercase;
  background: var(--h-blue-pale); color: var(--h-blue);
}
.rbp-home-eye--white  { background: rgba(255,255,255,.14); color: rgba(255,255,255,.9); border: 1px solid rgba(255,255,255,.22); }
.rbp-home-eye--amber  { background: var(--h-amber-pale); color: var(--h-amber); }
.rbp-home-eye--green  { background: var(--h-green-pale); color: var(--h-green); }
.rbp-home-eye--purple { background: var(--h-purple-pale); color: var(--h-purple); }
.rbp-home-eye--teal   { background: var(--h-teal-pale); color: var(--h-teal); }
.rbp-home-eye-dot { width: 6px; height: 6px; border-radius: 999px; background: currentColor; }

/* ─── Headings ───────────────────────────────────────────────────── */
.rbp-home-h1 { font-size: clamp(44px,7vw,90px); font-weight: 900; line-height: 1.0; letter-spacing: -.05em; color: var(--h-white); }
.rbp-home-h2 { font-size: clamp(30px,4vw,52px); font-weight: 900; line-height: 1.04; letter-spacing: -.035em; }
.rbp-home-h3 { font-size: clamp(18px,2.5vw,24px); font-weight: 800; line-height: 1.2; }
.rbp-home-p  { font-size: 16px; line-height: 1.75; color: var(--h-slate-6); }
.rbp-home-head { text-align: center; max-width: 760px; margin: 0 auto 60px; }
.rbp-home-head .rbp-home-eye { margin-bottom: 16px; }
.rbp-home-head .rbp-home-h2  { margin: 12px 0 16px; }

/* ─── Buttons ────────────────────────────────────────────────────── */
.rbp-home-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 15px 26px; border-radius: 14px; border: none;
  font-size: 15px; font-weight: 800; cursor: pointer; line-height: 1;
  transition: all .2s ease; text-decoration: none; white-space: nowrap;
}
.rbp-home-btn--primary { background: var(--h-blue); color: var(--h-white); box-shadow: 0 10px 28px rgba(29,78,216,.28); }
.rbp-home-btn--primary:hover { background: #1e40af; transform: translateY(-2px); box-shadow: 0 14px 36px rgba(29,78,216,.36); }
.rbp-home-btn--white   { background: var(--h-white); color: var(--h-blue); }
.rbp-home-btn--white:hover { background: var(--h-blue-pale); }
.rbp-home-btn--ghost   { background: transparent; color: rgba(255,255,255,.8); border: 1.5px solid rgba(255,255,255,.24); }
.rbp-home-btn--ghost:hover { background: rgba(255,255,255,.08); }
.rbp-home-btn--sm { padding: 11px 20px; font-size: 13px; }
.rbp-home-actions { display: flex; flex-wrap: wrap; gap: 14px; }

/* ═══════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════ */
.rbp-home-hero {
  background:
    radial-gradient(ellipse 90% 70% at 65% 20%, rgba(59,130,246,.22), transparent 60%),
    radial-gradient(ellipse 50% 80% at 5% 85%, rgba(13,148,136,.16), transparent 55%),
    radial-gradient(ellipse 40% 40% at 85% 85%, rgba(124,58,237,.12), transparent 50%),
    linear-gradient(160deg, #0f172a 0%, #1e3a8a 45%, #0f172a 100%);
  min-height: 100vh; position: relative; overflow: hidden;
  display: flex; align-items: center;
}
.rbp-home-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Ccircle cx='40' cy='40' r='1' fill='%23ffffff' fill-opacity='0.03'/%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
/* Animated gradient orb */
.rbp-home-hero-orb {
  position: absolute; top: 10%; right: -10%;
  width: 600px; height: 600px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,.14), transparent 70%);
  animation: hero-float 8s ease-in-out infinite;
  pointer-events: none;
}
@keyframes hero-float { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-30px) scale(1.05)} }
.rbp-home-hero-in {
  display: grid;
  grid-template-columns: minmax(0,1fr) minmax(380px,.85fr);
  gap: 72px; align-items: center;
  padding: 120px 0 100px;
}
.rbp-home-hero-text { position: relative; z-index: 1; }
.rbp-home-hero-text .rbp-home-eye { margin-bottom: 24px; }
.rbp-home-hero-text .rbp-home-h1 { margin-bottom: 24px; }
.rbp-home-hero-text .rbp-home-p {
  color: #94a3b8; font-size: 19px; max-width: 580px;
  line-height: 1.75; margin-bottom: 36px;
}
.rbp-home-hero-text .rbp-home-actions { margin-bottom: 48px; }

/* ─── Live stats bar under hero CTAs ─────────────────────────────── */
.rbp-home-hero-stats {
  display: flex; flex-wrap: wrap; gap: 32px;
  padding-top: 36px; border-top: 1px solid rgba(255,255,255,.1);
}
.rbp-home-hero-stat-num {
  font-size: 36px; font-weight: 900; color: var(--h-white); letter-spacing: -.04em; line-height: 1;
}
.rbp-home-hero-stat-label { font-size: 12px; color: #64748b; font-weight: 600; margin-top: 3px; }

/* ─── Hero visual panel ──────────────────────────────────────────── */
.rbp-home-hero-panel {
  position: relative; z-index: 1;
}
.rbp-home-hero-card-main {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.14);
  backdrop-filter: blur(28px);
  border-radius: var(--h-radius-lg); padding: 36px 32px;
  position: relative; overflow: hidden;
}
.rbp-home-hero-card-main::before {
  content: ''; position: absolute; top:0;left:0;right:0;height:4px;
  background: linear-gradient(90deg, #3b82f6, #0d9488, #7c3aed);
}
.rbp-home-hero-card-main h3 { color: var(--h-white); font-size: 20px; font-weight: 900; letter-spacing: -.02em; margin-bottom: 6px; }
.rbp-home-hero-card-main p  { color: #64748b; font-size: 14px; line-height: 1.6; margin-bottom: 24px; }
.rbp-home-journey-btns { display: flex; flex-direction: column; gap: 10px; }
.rbp-home-journey-btn {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 16px; border-radius: var(--h-radius);
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  color: var(--h-white); font-size: 14px; font-weight: 700;
  text-decoration: none; transition: all .2s ease;
}
.rbp-home-journey-btn:hover { background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.22); transform: translateX(4px); }
.rbp-home-journey-btn-icon {
  width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 18px;
}
.rbp-home-journey-btn-arrow { margin-left: auto; color: rgba(255,255,255,.4); font-size: 16px; transition: transform .2s; }
.rbp-home-journey-btn:hover .rbp-home-journey-btn-arrow { transform: translateX(4px); color: rgba(255,255,255,.8); }

/* ─── Floating mini-cards ────────────────────────────────────────── */
.rbp-home-hero-float {
  display: flex; gap: 12px; margin-top: 12px;
}
.rbp-home-hero-float-card {
  flex: 1; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--h-radius); padding: 16px;
  text-align: center;
}
.rbp-home-hero-float-card-num { font-size: 22px; font-weight: 900; color: var(--h-white); }
.rbp-home-hero-float-card-label { font-size: 11px; color: #64748b; margin-top: 3px; font-weight: 600; }

/* ═══════════════════════════════════════════════════
   TRUST BAR
═══════════════════════════════════════════════════ */
.rbp-home-trust-bar {
  background: var(--h-navy); padding: 24px 0;
  border-top: 1px solid rgba(255,255,255,.06);
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.rbp-home-trust-items {
  display: flex; align-items: center; justify-content: center;
  flex-wrap: wrap; gap: 40px;
}
.rbp-home-trust-item {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; color: #475569; font-weight: 600; white-space: nowrap;
}
.rbp-home-trust-item svg { color: var(--h-blue); flex-shrink: 0; }

/* ═══════════════════════════════════════════════════
   SERVICE JOURNEY ROUTING
═══════════════════════════════════════════════════ */
.rbp-home-journey {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
}
.rbp-home-journey-card {
  background: var(--h-white); border: 1.5px solid var(--h-slate-2);
  border-radius: var(--h-radius-lg); padding: 40px 32px;
  position: relative; overflow: hidden;
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  text-decoration: none; color: inherit; display: flex; flex-direction: column;
}
.rbp-home-journey-card:hover { transform: translateY(-6px); box-shadow: var(--h-shadow-lg); border-color: var(--h-accent-color, var(--h-blue)); }
.rbp-home-journey-card::after {
  content: ''; position: absolute; top:0;left:0;right:0;height:4px;
  background: var(--h-accent-color, var(--h-blue));
  transform: scaleX(0); transform-origin: left;
  transition: transform .3s ease;
}
.rbp-home-journey-card:hover::after { transform: scaleX(1); }
.rbp-home-journey-card-bg {
  position: absolute; bottom: -20px; right: -20px;
  font-size: 100px; opacity: .04; pointer-events: none; line-height: 1;
}
.rbp-home-journey-icon {
  width: 64px; height: 64px; border-radius: 20px;
  background: var(--h-icon-bg, var(--h-blue-pale));
  color: var(--h-icon-color, var(--h-blue));
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; margin-bottom: 24px;
}
.rbp-home-journey-card h3 { font-size: 20px; font-weight: 900; color: var(--h-slate-9); letter-spacing: -.02em; margin-bottom: 12px; }
.rbp-home-journey-card p  { font-size: 14px; color: var(--h-slate-6); line-height: 1.7; flex: 1; margin-bottom: 24px; }
.rbp-home-journey-card-link {
  font-size: 13px; font-weight: 800; color: var(--h-accent-color, var(--h-blue));
  display: flex; align-items: center; gap: 6px;
  transition: gap .2s ease;
}
.rbp-home-journey-card:hover .rbp-home-journey-card-link { gap: 10px; }

/* ═══════════════════════════════════════════════════
   STATS SECTION
═══════════════════════════════════════════════════ */
.rbp-home-stats {
  background: linear-gradient(135deg, var(--h-navy) 0%, #1e3a8a 50%, var(--h-navy) 100%);
  padding: 80px 0; position: relative; overflow: hidden;
}
.rbp-home-stats::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(59,130,246,.12), transparent 70%);
  pointer-events: none;
}
.rbp-home-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative; z-index: 1; }
.rbp-home-stat-block {
  text-align: center; padding: 32px 24px;
  border-right: 1px solid rgba(255,255,255,.08);
}
.rbp-home-stat-block:last-child { border-right: none; }
.rbp-home-stat-block-num {
  font-size: clamp(36px,5vw,60px); font-weight: 900;
  color: var(--h-white); letter-spacing: -.045em; line-height: 1;
  background: linear-gradient(135deg, var(--h-white), #94a3b8);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.rbp-home-stat-block-label { font-size: 14px; color: #475569; font-weight: 600; margin-top: 8px; }
.rbp-home-stat-block-sub   { font-size: 12px; color: #334155; margin-top: 4px; }

/* ═══════════════════════════════════════════════════
   SERVICE CATEGORIES
═══════════════════════════════════════════════════ */
.rbp-home-services { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.rbp-home-service {
  background: var(--h-white); border: 1.5px solid var(--h-slate-2);
  border-radius: var(--h-radius-lg); padding: 28px 24px;
  display: flex; align-items: flex-start; gap: 18px;
  text-decoration: none; color: inherit;
  transition: transform .2s, box-shadow .2s, border-color .2s;
  position: relative; overflow: hidden;
}
.rbp-home-service:hover { transform: translateY(-3px); box-shadow: var(--h-shadow); border-color: var(--h-service-color, var(--h-blue)); }
.rbp-home-service::after {
  content: ''; position: absolute; bottom:0;left:0;right:0;height:3px;
  background: var(--h-service-color, var(--h-blue));
  transform: scaleX(0); transform-origin: left; transition: transform .25s;
}
.rbp-home-service:hover::after { transform: scaleX(1); }
.rbp-home-service-icon {
  width: 48px; height: 48px; border-radius: 14px;
  background: var(--h-icon-bg, var(--h-blue-pale));
  color: var(--h-icon-color, var(--h-blue));
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
}
.rbp-home-service h3 { font-size: 15px; font-weight: 800; color: var(--h-slate-9); margin-bottom: 5px; }
.rbp-home-service p  { font-size: 13px; color: var(--h-slate-6); line-height: 1.6; }
.rbp-home-service-arrow { margin-left: auto; flex-shrink: 0; color: var(--h-slate-4); align-self: center; font-size: 18px; transition: transform .2s, color .2s; }
.rbp-home-service:hover .rbp-home-service-arrow { transform: translateX(4px); color: var(--h-service-color, var(--h-blue)); }

/* ═══════════════════════════════════════════════════
   WHY RBP — Features grid
═══════════════════════════════════════════════════ */
.rbp-home-why { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 60px; align-items: center; }
.rbp-home-why-features { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.rbp-home-why-feat {
  background: var(--h-white); border: 1.5px solid var(--h-slate-2);
  border-radius: var(--h-radius-lg); padding: 28px 24px;
  transition: transform .2s, box-shadow .2s;
}
.rbp-home-why-feat:hover { transform: translateY(-3px); box-shadow: var(--h-shadow); }
.rbp-home-why-feat-icon {
  width: 48px; height: 48px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; margin-bottom: 16px;
}
.rbp-home-why-feat h3 { font-size: 15px; font-weight: 800; color: var(--h-slate-9); margin-bottom: 6px; }
.rbp-home-why-feat p  { font-size: 13px; color: var(--h-slate-6); line-height: 1.65; }

/* ═══════════════════════════════════════════════════
   FEATURED SHOWCASE — On-demand
═══════════════════════════════════════════════════ */
.rbp-home-showcase {
  background: linear-gradient(135deg, #0f172a 0%, #172554 55%, #0f172a 100%);
  padding: 96px 0; position: relative; overflow: hidden;
}
.rbp-home-showcase::before {
  content: ''; position: absolute; inset:0;
  background: radial-gradient(ellipse 70% 60% at 70% 40%, rgba(59,130,246,.14), transparent 60%);
}
.rbp-home-showcase-in { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1.2fr); gap: 72px; align-items: center; position: relative; z-index: 1; }
.rbp-home-showcase-tag { display: flex; align-items: center; gap: 10px; font-size: 11px; font-weight: 800; letter-spacing: .10em; text-transform: uppercase; color: #64748b; margin-bottom: 20px; }
.rbp-home-showcase-tag-line { flex: 1; height: 1px; background: rgba(255,255,255,.1); }
.rbp-home-showcase h2 { color: var(--h-white); }
.rbp-home-showcase .rbp-home-p { color: #94a3b8; margin: 16px 0 32px; }
.rbp-home-showcase-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.rbp-home-showcase-card {
  background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--h-radius-lg); padding: 24px 20px;
  transition: background .2s, border-color .2s;
}
.rbp-home-showcase-card:hover { background: rgba(255,255,255,.09); border-color: rgba(255,255,255,.2); }
.rbp-home-showcase-card-icon { font-size: 28px; margin-bottom: 14px; display: block; }
.rbp-home-showcase-card h4 { font-size: 14px; font-weight: 800; color: var(--h-white); margin-bottom: 6px; }
.rbp-home-showcase-card p  { font-size: 13px; color: #64748b; line-height: 1.6; }
.rbp-home-showcase-card-count { font-size: 11px; color: #3b82f6; font-weight: 800; margin-top: 10px; letter-spacing: .04em; }

/* ═══════════════════════════════════════════════════
   MEMBERSHIP CTA SPLIT
═══════════════════════════════════════════════════ */
.rbp-home-split { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.rbp-home-split-card {
  border-radius: var(--h-radius-lg); padding: 52px 44px;
  position: relative; overflow: hidden;
}
.rbp-home-split-card::before { content: ''; position: absolute; top:-30%;right:-10%; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.08), transparent 70%); }
.rbp-home-split-card--member { background: linear-gradient(135deg, #1e3a8a, #172554); }
.rbp-home-split-card--partner { background: linear-gradient(135deg, #134e4a, #0f172a); }
.rbp-home-split-card-eye { display: inline-flex; align-items: center; gap: 8px; padding: 5px 12px; border-radius: 999px; font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 20px; }
.rbp-home-split-card--member .rbp-home-split-card-eye { background: rgba(59,130,246,.2); color: #93c5fd; }
.rbp-home-split-card--partner .rbp-home-split-card-eye { background: rgba(13,148,136,.2); color: #5eead4; }
.rbp-home-split-card h3 { color: var(--h-white); font-size: 28px; font-weight: 900; letter-spacing: -.03em; margin-bottom: 12px; }
.rbp-home-split-card p  { color: rgba(255,255,255,.6); font-size: 15px; line-height: 1.7; margin-bottom: 28px; }
.rbp-home-split-card ul { margin-bottom: 32px; display: flex; flex-direction: column; gap: 8px; }
.rbp-home-split-card li { display: flex; align-items: center; gap: 10px; font-size: 14px; color: rgba(255,255,255,.78); font-weight: 600; }
.rbp-home-split-card li::before { content: '✓'; color: #22c55e; font-weight: 900; flex-shrink: 0; }

/* ═══════════════════════════════════════════════════
   RESOURCES PREVIEW
═══════════════════════════════════════════════════ */
.rbp-home-resources { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.rbp-home-resource {
  background: var(--h-white); border: 1.5px solid var(--h-slate-2);
  border-radius: var(--h-radius-lg); padding: 28px 24px;
  text-decoration: none; color: inherit;
  transition: transform .2s, box-shadow .2s, border-color .2s;
  position: relative; overflow: hidden;
}
.rbp-home-resource:hover { transform: translateY(-4px); box-shadow: var(--h-shadow-lg); border-color: var(--h-blue); }
.rbp-home-resource-type {
  display: inline-flex; padding: 3px 10px; border-radius: 999px;
  font-size: 10px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase;
  background: var(--h-blue-pale); color: var(--h-blue); margin-bottom: 14px;
}
.rbp-home-resource h3 { font-size: 15px; font-weight: 800; color: var(--h-slate-9); line-height: 1.3; margin-bottom: 8px; }
.rbp-home-resource p  { font-size: 13px; color: var(--h-slate-6); line-height: 1.6; }

/* ═══════════════════════════════════════════════════
   CTA BAND
═══════════════════════════════════════════════════ */
.rbp-home-cta-band {
