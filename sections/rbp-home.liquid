<script>
(function() {
  // ── Scroll-triggered entrance animations
  if ('IntersectionObserver' in window) {
    var targets = document.querySelectorAll('.rbp-home-journey-card, .rbp-home-why-feat, .rbp-home-service, .rbp-home-resource, .rbp-home-showcase-card, .rbp-home-stat-block');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    targets.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity .5s ease, transform .5s ease';
      io.observe(el);
    });
  }

  // ── Stat counter animation
  var statNums = document.querySelectorAll('.rbp-home-stat-block-num');
  var counted = false;
  function countUp(el) {
    var text = el.textContent;
    var num = parseFloat(text.replace(/[^0-9.]/g, ''));
    if (isNaN(num)) return;
    var suffix = text.replace(/[0-9.]/g, '');
    var duration = 1200;
    var start = performance.now();
    function update(ts) {
      var progress = Math.min((ts - start) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(num * eased) + suffix;
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }
  if ('IntersectionObserver' in window) {
    var statsEl = document.querySelector('.rbp-home-stats');
    if (statsEl) {
      new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting && !counted) {
          counted = true;
          statNums.forEach(countUp);
        }
      }, { threshold: 0.3 }).observe(statsEl);
    }
  }
})();
</script>

