{{ 'rbp-landing.css' | asset_url | stylesheet_tag }}
{% liquid
assign e=section.settings.eyebrow|default:page.title
assign t=section.settings.heading|default:page.title
assign d=section.settings.intro|default:page.content|strip_html|default:'Structured RBP pathways for practical business support.'
assign p=section.settings.primary_label|default:'Start here'
assign pl=section.settings.primary_link|default:'/pages/business-health-check'
assign s=section.settings.secondary_label|default:'Contact RBP'
assign sl=section.settings.secondary_link|default:'/pages/contact'
assign fh=section.settings.final_heading|default:'Move forward with a clearer pathway.'
assign ft=section.settings.final_text|default:'Start with the recommended route or contact RBP if the next step is not obvious yet.'
assign fp=section.settings.final_primary_label|default:p
assign fpl=section.settings.final_primary_link|default:pl
assign fs=section.settings.final_secondary_label
assign fsl=section.settings.final_secondary_link
%}
<section class="rbp-landing"><div class="rbp-container rbp-landing__hero"><div><p class="rbp-eyebrow">{{ e }}</p><h1>{{ t }}</h1><p>{{ d }}</p><p><a class="rbp-button rbp-button--primary" href="{{ pl }}">{{ p }}</a> <a class="rbp-button rbp-button--secondary" href="{{ sl }}">{{ s }}</a></p></div><div class="rbp-landing__visual"><div></div><a href="{{ pl }}"><small>Recommended starting point</small><strong>{{ section.settings.featured_title|default:'RBP pathway' }}</strong></a></div></div><div class="rbp-landing__trust"><span>Australian SME Support</span><span>Structured Business Pathways</span><span>Onboarding-Led Delivery</span><span>Practical Commercial Guidance</span></div><div class="rbp-container rbp-landing__section"><h2>Pathways shaped around the work to be done</h2><div class="rbp-landing__cards"><article><b>Clarify the priority</b><p>Start with the pathway that gives the work proper shape.</p></article><article><b>Choose the right support</b><p>Match advisory, consulting, resources or implementation support to the need.</p></article><article><b>Move into next steps</b><p>Use onboarding-led delivery and business-ready documentation.</p></article></div></div><div class="rbp-container rbp-landing__section"><h2>Explore the available pathways</h2><div class="rbp-landing__grid">{% for block in section.blocks %}<article {{ block.shopify_attributes }}><span>{{ block.settings.type_label }}</span><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p><a href="{{ block.settings.link }}">{{ block.settings.cta_text|default:'View pathway' }}</a></article>{% else %}<article><span>Pathway</span><h3>{{ page.title }}</h3><p>Open this RBP pathway for practical support, resources or next steps.</p><a href="{{ pl }}">View pathway</a></article>{% endfor %}</div></div><div class="rbp-container rbp-landing__final"><h2>{{ fh }}</h2><p>{{ ft }}</p><a class="rbp-button rbp-button--primary" href="{{ fpl }}">{{ fp }}</a>{% if fs != blank and fsl != blank %} <a class="rbp-button rbp-button--secondary" href="{{ fsl }}">{{ fs }}</a>{% endif %}</div></section>
{% schema %}{"name":"RBP landing page","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow"},{"type":"text","id":"heading","label":"Heading"},{"type":"textarea","id":"intro","label":"Intro copy"},{"type":"text","id":"primary_label","label":"Primary CTA label"},{"type":"url","id":"primary_link","label":"Primary CTA link"},{"type":"text","id":"secondary_label","label":"Secondary CTA label"},{"type":"url","id":"secondary_link","label":"Secondary CTA link"},{"type":"text","id":"featured_title","label":"Featured card title"},{"type":"text","id":"final_heading","label":"Final CTA heading","default":"Move forward with a clearer pathway."},{"type":"textarea","id":"final_text","label":"Final CTA text","default":"Start with the recommended route or contact RBP if the next step is not obvious yet."},{"type":"text","id":"final_primary_label","label":"Final primary CTA label"},{"type":"url","id":"final_primary_link","label":"Final primary CTA link"},{"type":"text","id":"final_secondary_label","label":"Final secondary CTA label"},{"type":"url","id":"final_secondary_link","label":"Final secondary CTA link"}],"blocks":[{"type":"pathway_card","name":"Pathway card","settings":[{"type":"text","id":"type_label","label":"Type label","default":"Pathway"},{"type":"text","id":"title","label":"Title","default":"Pathway title"},{"type":"textarea","id":"text","label":"Text","default":"Short pathway description."},{"type":"url","id":"link","label":"Link"},{"type":"text","id":"cta_text","label":"CTA text","default":"View pathway"}]}],"presets":[{"name":"RBP landing page"}]}{% endschema %}
