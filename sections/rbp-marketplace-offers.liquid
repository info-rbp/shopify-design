<style>
.rbp-mo{--b:#1d4ed8;--bd:#1e3a8a;--bs:#dbeafe;--s9:#0f172a;--s7:#334155;--s6:#475569;--s0:#f8fafc;--br:rgba(15,23,42,.1);--br2:rgba(15,23,42,.16);--sh:0 22px 55px rgba(15,23,42,.14);background:#fff;color:var(--s9)}.rbp-mo *{box-sizing:border-box}.rbp-mo a{text-decoration:none;color:inherit}.rbp-mo-c{width:min(100% - 3rem,1200px);margin-inline:auto}.rbp-mo-hero{overflow:hidden;color:#fff;background:radial-gradient(ellipse at top right,rgba(59,130,246,.25),transparent 58%),radial-gradient(ellipse at bottom left,rgba(99,102,241,.16),transparent 60%),linear-gradient(135deg,#0f172a 0%,#172554 52%,#0f172a 100%)}.rbp-mo-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.72fr);gap:56px;align-items:center;padding:88px 0;min-height:570px}.rbp-mo-ey{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:#dbeafe;color:#1d4ed8;font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-mo-hero .rbp-mo-ey{background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28)}.rbp-mo-dot{width:7px;height:7px;border-radius:999px;background:currentColor}.rbp-mo-h1{margin:16px 0 0;color:#fff;font-size:clamp(40px,6vw,76px);line-height:1.02;letter-spacing:-.045em;font-weight:900}.rbp-mo-h2{margin:14px 0 0;color:var(--s9);font-size:clamp(30px,4vw,50px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-mo-p{margin:16px 0 0;color:var(--s6);font-size:16px;line-height:1.75}.rbp-mo-hero .rbp-mo-p{color:#cbd5e1;font-size:18px;max-width:760px}.rbp-mo-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:28px}.rbp-mo-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:14px;padding:14px 18px;border:1px solid transparent;font-size:14px;font-weight:900;line-height:1}.rbp-mo-btn-p{background:#1d4ed8;color:#fff;box-shadow:0 18px 36px rgba(29,78,216,.24)}.rbp-mo-btn-g{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.24)}.rbp-mo-btn-o{background:#fff;color:var(--s7);border-color:var(--br2)}.rbp-mo-proof{display:flex;flex-wrap:wrap;gap:14px 20px;margin-top:26px}.rbp-mo-proof span{display:inline-flex;align-items:center;gap:8px;color:#cbd5e1;font-size:14px;font-weight:750}.rbp-mo-check{width:18px;height:18px;border-radius:999px;display:inline-grid;place-items:center;background:#3b82f6;color:#fff;font-size:12px;line-height:1;flex:0 0 auto}.rbp-mo-card{background:#fff;border:1px solid var(--br);border-radius:24px;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-mo-hero-card{border:1px solid rgba(255,255,255,.14);border-radius:28px;background:rgba(255,255,255,.08);box-shadow:0 35px 75px rgba(30,64,175,.32);padding:26px}.rbp-mo-hero-card h3{margin:0 0 12px;color:#fff;font-size:22px;font-weight:900}.rbp-mo-hero-card p{margin:0;color:#cbd5e1;line-height:1.7}.rbp-mo-sec{padding:74px 0}.rbp-mo-muted{background:#f8fafc}.rbp-mo-head{max-width:820px;margin:0 auto 36px;text-align:center}.rbp-mo-grid{display:grid;gap:20px}.rbp-mo-g2{grid-template-columns:repeat(2,minmax(0,1fr))}.rbp-mo-g3{grid-template-columns:repeat(3,minmax(0,1fr))}.rbp-mo-g4{grid-template-columns:repeat(4,minmax(0,1fr))}.rbp-mo-icon{width:46px;height:46px;border-radius:16px;display:grid;place-items:center;margin-bottom:16px;background:#dbeafe;color:#1d4ed8;font-weight:900}.rbp-mo-title{margin:0 0 8px;color:#0f172a;font-size:18px;font-weight:900}.rbp-mo-text,.rbp-mo-rich,.rbp-mo-rich p,.rbp-mo-rich li{margin:0;color:#64748b;line-height:1.65;font-size:14px}.rbp-mo-link{display:inline-flex;align-items:center;gap:6px;margin-top:16px;color:#1d4ed8;font-size:13px;font-weight:900}.rbp-mo-blue{background:linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;border:0;box-shadow:var(--sh)}.rbp-mo-blue .rbp-mo-title,.rbp-mo-blue .rbp-mo-h2{color:#fff}.rbp-mo-blue .rbp-mo-text,.rbp-mo-blue .rbp-mo-p{color:#dbeafe}.rbp-mo-list{display:grid;gap:10px;margin:18px 0 0;padding:0;list-style:none}.rbp-mo-list li{display:grid;grid-template-columns:22px minmax(0,1fr);gap:10px;color:#64748b;line-height:1.55;font-size:14px}.rbp-mo-blue .rbp-mo-list li{color:#dbeafe}.rbp-mo-offer{position:relative;overflow:hidden}.rbp-mo-badge{position:absolute;top:18px;right:18px;border-radius:999px;background:#dbeafe;color:#1d4ed8;font-size:11px;font-weight:900;padding:6px 10px;text-transform:uppercase;letter-spacing:.06em}.rbp-mo-price{font-size:28px;font-weight:900;color:#0f172a;margin:12px 0 4px}.rbp-mo-meta{color:#64748b;font-size:12px;font-weight:800}.rbp-mo-step{position:relative;padding-left:54px}.rbp-mo-step+.rbp-mo-step{margin-top:20px}.rbp-mo-step-num{position:absolute;top:0;left:0;width:40px;height:40px;border-radius:999px;background:#1d4ed8;color:#fff;display:grid;place-items:center;font-size:12px;font-weight:900}.rbp-mo-step h3{margin:0 0 5px;color:#0f172a;font-size:16px;font-weight:900}.rbp-mo-step p{margin:0;color:#64748b;line-height:1.65}.rbp-mo-faq details{background:#fff;border:1px solid var(--br);border-radius:18px;padding:0 18px}.rbp-mo-faq details+details{margin-top:12px}.rbp-mo-faq summary{cursor:pointer;padding:18px 0;color:#0f172a;font-weight:900}.rbp-mo-faq summary::-webkit-details-marker{display:none}.rbp-mo-faq div{padding-bottom:18px;color:#64748b;line-height:1.7}.rbp-mo-cta{border-radius:32px;background:radial-gradient(circle at top right,rgba(255,255,255,.18),transparent 35%),linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;padding:clamp(28px,5vw,56px);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:28px;align-items:center}.rbp-mo-cta h2{margin:0;color:#fff;font-size:clamp(28px,4vw,48px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-mo-cta p{margin:12px 0 0;color:#dbeafe;line-height:1.7;max-width:760px}@media(max-width:989px){.rbp-mo-hero-in,.rbp-mo-g2,.rbp-mo-g3,.rbp-mo-g4,.rbp-mo-cta{grid-template-columns:1fr}.rbp-mo-hero-card{display:none}.rbp-mo-head{text-align:left;margin-inline:0}}@media(max-width:749px){.rbp-mo-c{width:min(100% - 2rem,1200px)}.rbp-mo-sec{padding:54px 0}.rbp-mo-hero-in{padding:68px 0;min-height:auto}.rbp-mo-btn{width:100%}}
</style>
{%- liquid
 assign mode='marketplace'
 assign eyebrow='Marketplace'
 assign summary='Explore business offers, commercial pathways and curated opportunities connected to the Remote Business Partner platform.'
 assign hero_card_title='Marketplace, minus the clutter'
 assign hero_card_text='A commercial hub for offers, categories and partner-style opportunities, structured so customers are not left wandering through random links like lost office interns.'
 assign primary_label='Browse offers'
 assign primary_link='/pages/exclusive-offers'
 assign secondary_label='Contact us'
 assign secondary_link='/pages/contact'
 if page.handle == 'exclusive-offers'
  assign mode='offers'
  assign eyebrow='Exclusive Offers'
  assign summary='Browse selected offers available through Remote Business Partner, including business support, partner pathways and premium opportunities where available.'
  assign hero_card_title='Selected offers and member opportunities'
  assign hero_card_text='Use this page for curated offers that need stronger positioning, clear terms and a proper enquiry path.'
  assign primary_label='View offer categories'
  assign primary_link='/pages/offers-by-categories'
 elsif page.handle == 'top-offers'
  assign mode='offers'
  assign eyebrow='Top Offers'
  assign summary='A focused page for high-priority offers, featured opportunities and commercially important promotions.'
  assign hero_card_title='Best current opportunities'
  assign hero_card_text='Top offers should be clear, current and easy to act on, which sounds obvious until the internet gets involved.'
  assign primary_label='View all categories'
  assign primary_link='/pages/offers-by-categories'
 elsif page.handle == 'limited-time-offers'
  assign mode='offers'
  assign eyebrow='Limited Time Offers'
  assign summary='View time-sensitive offers, short-window opportunities and promotions that require faster action.'
  assign hero_card_title='Time-sensitive, not chaotic'
  assign hero_card_text='Limited-time offers need clear dates, eligibility and next steps, not a vague countdown powered by anxiety.'
  assign primary_label='Contact about an offer'
  assign primary_link='/pages/contact'
 elsif page.handle == 'offers-by-categories'
  assign mode='categories'
  assign eyebrow='Offer Categories'
  assign summary='Browse marketplace and offer opportunities by category so customers can find the right commercial pathway faster.'
  assign hero_card_title='Offers grouped by purpose'
  assign hero_card_text='Categories help customers choose between services, documents, membership, Business NBN and partner-style pathways.'
  assign primary_label='View top offers'
  assign primary_link='/pages/top-offers'
 endif
-%}
<div class="rbp-mo">
<section class="rbp-mo-hero"><div class="rbp-mo-c"><div class="rbp-mo-hero-in"><div><div class="rbp-mo-ey"><span class="rbp-mo-dot"></span>{{ eyebrow }}</div><h1 class="rbp-mo-h1">{{ page.title }}</h1><p class="rbp-mo-p">{{ summary }}</p><div class="rbp-mo-actions"><a class="rbp-mo-btn rbp-mo-btn-p" href="{{ primary_link }}">{{ primary_label }} -&gt;</a><a class="rbp-mo-btn rbp-mo-btn-g" href="{{ secondary_link }}">{{ secondary_label }}</a></div><div class="rbp-mo-proof"><span><span class="rbp-mo-check">✓</span>Curated pathways</span><span><span class="rbp-mo-check">✓</span>Clear enquiry route</span><span><span class="rbp-mo-check">✓</span>RBP support alignment</span></div></div><aside class="rbp-mo-hero-card"><h3>{{ hero_card_title }}</h3><p>{{ hero_card_text }}</p></aside></div></div></section>
<section class="rbp-mo-sec"><div class="rbp-mo-c"><div class="rbp-mo-grid rbp-mo-g2"><div><div class="rbp-mo-ey">Overview</div><h2 class="rbp-mo-h2">A clearer commercial pathway</h2><p class="rbp-mo-p">{{ summary }}</p>{%- if page.content != blank -%}<div class="rbp-mo-rich" style="margin-top:18px;">{{ page.content }}</div>{%- endif -%}</div><div class="rbp-mo-card rbp-mo-blue"><h3 class="rbp-mo-title">How this area should work</h3><ul class="rbp-mo-list"><li><span class="rbp-mo-check">✓</span><span>Customers can browse by offer type, category or urgency.</span></li><li><span class="rbp-mo-check">✓</span><span>Each offer should have clear eligibility, terms and next steps.</span></li><li><span class="rbp-mo-check">✓</span><span>Archived buying/listing pages remain unpublished and are not primary routes.</span></li><li><span class="rbp-mo-check">✓</span><span>Contact is the fallback path where an offer needs scoping or confirmation.</span></li></ul></div></div></div></section>
<section class="rbp-mo-sec rbp-mo-muted"><div class="rbp-mo-c"><div class="rbp-mo-head"><div class="rbp-mo-ey">Marketplace routes</div><h2 class="rbp-mo-h2">Choose the right offer pathway</h2><p class="rbp-mo-p">The marketplace and offer pages now use a shared experience so customers do not have to reverse-engineer the site like a tiny detective.</p></div><div class="rbp-mo-grid rbp-mo-g4"><a class="rbp-mo-card" href="/pages/marketplace"><div class="rbp-mo-icon">MP</div><h3 class="rbp-mo-title">Marketplace</h3><p class="rbp-mo-text">Main hub for commercial opportunities, offers and partner-style pathways.</p><span class="rbp-mo-link">Open marketplace -&gt;</span></a><a class="rbp-mo-card" href="/pages/exclusive-offers"><div class="rbp-mo-icon">EX</div><h3 class="rbp-mo-title">Exclusive Offers</h3><p class="rbp-mo-text">Selected offers and premium opportunities where available.</p><span class="rbp-mo-link">View exclusive offers -&gt;</span></a><a class="rbp-mo-card" href="/pages/top-offers"><div class="rbp-mo-icon">TO</div><h3 class="rbp-mo-title">Top Offers</h3><p class="rbp-mo-text">Featured and high-priority offers for easier discovery.</p><span class="rbp-mo-link">View top offers -&gt;</span></a><a class="rbp-mo-card" href="/pages/limited-time-offers"><div class="rbp-mo-icon">LT</div><h3 class="rbp-mo-title">Limited Time</h3><p class="rbp-mo-text">Time-sensitive opportunities, promotions and short-window offers.</p><span class="rbp-mo-link">View limited-time offers -&gt;</span></a></div></div></section>
<section class="rbp-mo-sec"><div class="rbp-mo-c"><div class="rbp-mo-head"><div class="rbp-mo-ey">Offer cards</div><h2 class="rbp-mo-h2">Featured offer placeholders</h2><p class="rbp-mo-p">These are structured offer cards ready for real offer content. Empty promotions pretending to be live deals would be bad. Stunning insight, I know.</p></div><div class="rbp-mo-grid rbp-mo-g3"><div class="rbp-mo-card rbp-mo-offer"><span class="rbp-mo-badge">Featured</span><div class="rbp-mo-icon">01</div><h3 class="rbp-mo-title">Premium Member opportunities</h3><p class="rbp-mo-text">Use this slot for offers available to customers tagged as Premium Member.</p><div class="rbp-mo-price">TBC</div><div class="rbp-mo-meta">Eligibility and terms to confirm</div><a class="rbp-mo-link" href="/pages/contact">Enquire about this offer -&gt;</a></div><div class="rbp-mo-card rbp-mo-offer"><span class="rbp-mo-badge">Business</span><div class="rbp-mo-icon">02</div><h3 class="rbp-mo-title">Business support offer</h3><p class="rbp-mo-text">Use this slot for advisory, service or managed support offers.</p><div class="rbp-mo-price">TBC</div><div class="rbp-mo-meta">Scope and availability to confirm</div><a class="rbp-mo-link" href="/pages/business-advisor">View service pathway -&gt;</a></div><div class="rbp-mo-card rbp-mo-offer"><span class="rbp-mo-badge">Partner</span><div class="rbp-mo-icon">03</div><h3 class="rbp-mo-title">Partner-style opportunity</h3><p class="rbp-mo-text">Use this slot for external, marketplace or partner offers once approved.</p><div class="rbp-mo-price">TBC</div><div class="rbp-mo-meta">Commercial terms to confirm</div><a class="rbp-mo-link" href="/pages/contact">Request details -&gt;</a></div></div></div></section>
<section class="rbp-mo-sec rbp-mo-muted"><div class="rbp-mo-c"><div class="rbp-mo-head"><div class="rbp-mo-ey">Categories</div><h2 class="rbp-mo-h2">Browse by business need</h2></div><div class="rbp-mo-grid rbp-mo-g4"><a class="rbp-mo-card" href="/pages/business-advisor"><div class="rbp-mo-icon">SV</div><h3 class="rbp-mo-title">Services</h3><p class="rbp-mo-text">Advisory, decision support, managed service and custom solution offers.</p></a><a class="rbp-mo-card" href="/pages/templates"><div class="rbp-mo-icon">DN</div><h3 class="rbp-mo-title">Documents</h3><p class="rbp-mo-text">Templates, documentation suites, toolkits and document support.</p></a><a class="rbp-mo-card" href="/pages/membership"><div class="rbp-mo-icon">PM</div><h3 class="rbp-mo-title">Premium Membership</h3><p class="rbp-mo-text">Premium Member access, subscription billing and member-only pathways.</p></a><a class="rbp-mo-card" href="/pages/business-nbn"><div class="rbp-mo-icon">NB</div><h3 class="rbp-mo-title">Business NBN</h3><p class="rbp-mo-text">Business internet, plan guidance, serviceability and provisioning support.</p></a></div></div></section>
<section class="rbp-mo-sec"><div class="rbp-mo-c"><div class="rbp-mo-grid rbp-mo-g2"><div class="rbp-mo-card"><div class="rbp-mo-ey">Buying process</div><h2 class="rbp-mo-h2">How customers should act on an offer</h2><div class="rbp-mo-step"><span class="rbp-mo-step-num">01</span><h3>Review the offer category</h3><p>Check whether the offer relates to services, documents, membership, Business NBN or a partner pathway.</p></div><div class="rbp-mo-step"><span class="rbp-mo-step-num">02</span><h3>Check eligibility and terms</h3><p>Offers should state availability, dates, exclusions, pricing and any Premium Member rules.</p></div><div class="rbp-mo-step"><span class="rbp-mo-step-num">03</span><h3>Submit an enquiry or follow the CTA</h3><p>Where terms need confirmation, route the customer to Contact Support rather than inventing certainty. Revolutionary restraint.</p></div></div><div class="rbp-mo-card rbp-mo-blue"><div class="rbp-mo-ey">QA notes</div><h2 class="rbp-mo-h2">Offer governance</h2><p class="rbp-mo-p">Before publishing real offers, confirm eligibility, expiry, pricing, GST treatment, partner terms, availability and whether the offer is public or Premium Member-only.</p><ul class="rbp-mo-list"><li><span class="rbp-mo-check">✓</span><span>Archived Buying Process and List With Us pages remain unpublished.</span></li><li><span class="rbp-mo-check">✓</span><span>Every offer card must have a clear CTA.</span></li><li><span class="rbp-mo-check">✓</span><span>Do not show fake prices as live offers.</span></li><li><span class="rbp-mo-check">✓</span><span>Premium-only offers should reference the Premium Member tag model.</span></li></ul></div></div></div></section>
<section class="rbp-mo-sec rbp-mo-muted"><div class="rbp-mo-c"><div class="rbp-mo-grid rbp-mo-g2"><div><div class="rbp-mo-ey">FAQ</div><h2 class="rbp-mo-h2">Marketplace questions</h2><p class="rbp-mo-p">The kind of answers customers need before they start clicking on offers with the reckless optimism of civilisation.</p></div><div class="rbp-mo-faq"><details open><summary>Are all offers available immediately?</summary><div>No. Some offers require eligibility checks, Premium Member access, availability confirmation or a direct enquiry before they can be used.</div></details><details><summary>Are offers public or member-only?</summary><div>Offers can be public or Premium Member-only. Premium-only access should align with the customer tag <strong>Premium Member</strong>.</div></details><details><summary>What should each offer include?</summary><div>Each offer should include the title, summary, eligibility, price or TBC status, expiry where relevant, terms and a clear CTA.</div></details><details><summary>How do customers ask about an offer?</summary><div>Use the Contact page and include the offer name, business name, preferred contact method and any relevant membership or order information.</div></details></div></div></div></section>
<section class="rbp-mo-sec"><div class="rbp-mo-c"><div class="rbp-mo-cta"><div><h2>Need help with a marketplace offer?</h2><p>Use the contact pathway and include the offer name, category and business context so the request can be routed properly.</p></div><div class="rbp-mo-actions"><a class="rbp-mo-btn rbp-mo-btn-g" href="/pages/contact">Contact support</a><a class="rbp-mo-btn rbp-mo-btn-g" href="/pages/help-centre">Help Centre</a></div></div></div></section>
</div>
{% schema %}{"name":"RBP marketplace offers","settings":[],"presets":[{"name":"RBP marketplace offers"}]}{% endschema %}