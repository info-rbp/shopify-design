<style>
.rbp-mkt{--n:#0f172a;--b:#1d4ed8;--t:#0d9488;--a:#d97706;--m:#475569;--l:#e2e8f0;--bg:#f8fafc;background:#fff;color:#0f172a}.rbp-mkt *{box-sizing:border-box}.rbp-mkt a{text-decoration:none;color:inherit}.rbp-mkt-c{width:min(100% - 2.5rem,1240px);margin:auto}.rbp-mkt-sec{padding:76px 0}.rbp-mkt-muted{background:#f8fafc}.rbp-mkt-hero{background:linear-gradient(135deg,#0f172a,#1e3a8a);color:#fff}.rbp-mkt-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(300px,.48fr);gap:40px;align-items:center;padding:86px 0}.rbp-mkt-ey{display:inline-flex;border-radius:999px;background:#dbeafe;color:#1d4ed8;padding:7px 12px;font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-mkt-hero .rbp-mkt-ey{background:rgba(255,255,255,.12);color:#bfdbfe}.rbp-mkt h1{margin:16px 0;color:#fff;font-size:clamp(40px,6vw,76px);line-height:1.02;font-weight:900}.rbp-mkt h2{margin:12px 0;font-size:clamp(28px,4vw,48px);line-height:1.08;font-weight:900}.rbp-mkt h3{margin:0 0 8px;font-size:20px}.rbp-mkt p{color:#475569;line-height:1.7}.rbp-mkt-hero p{color:#cbd5e1;font-size:18px}.rbp-mkt-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:24px}.rbp-mkt-btn{display:inline-flex;align-items:center;justify-content:center;border-radius:12px;padding:13px 16px;font-weight:900;border:1px solid rgba(15,23,42,.14);background:#fff;color:#334155}.rbp-mkt-btn--primary{background:#1d4ed8;border-color:#1d4ed8;color:#fff}.rbp-mkt-card{border:1px solid #e2e8f0;border-radius:18px;background:#fff;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-mkt-hero-card{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.16);color:#fff}.rbp-mkt-hero-card p{color:#cbd5e1}.rbp-mkt-grid{display:grid;gap:18px}.rbp-mkt-g2{grid-template-columns:repeat(2,minmax(0,1fr))}.rbp-mkt-g3{grid-template-columns:repeat(3,minmax(0,1fr))}.rbp-mkt-g4{grid-template-columns:repeat(4,minmax(0,1fr))}.rbp-mkt-path{display:grid;gap:10px}.rbp-mkt-path span{width:42px;height:42px;border-radius:14px;background:#dbeafe;color:#1d4ed8;display:grid;place-items:center;font-weight:900}.rbp-mkt-list{display:grid;gap:10px;margin:16px 0 0;padding:0;list-style:none}.rbp-mkt-list li{display:grid;grid-template-columns:22px 1fr;gap:10px}.rbp-mkt-list li:before{content:"";width:18px;height:18px;margin-top:4px;border-radius:999px;background:#ccfbf1}.rbp-mkt-process{counter-reset:step}.rbp-mkt-step{position:relative;padding-left:56px}.rbp-mkt-step+.rbp-mkt-step{margin-top:18px}.rbp-mkt-step:before{counter-increment:step;content:counter(step,decimal-leading-zero);position:absolute;left:0;top:0;width:40px;height:40px;border-radius:999px;background:#1d4ed8;color:#fff;display:grid;place-items:center;font-size:12px;font-weight:900}.rbp-mkt-cta{background:linear-gradient(135deg,#1d4ed8,#0f172a);border-radius:22px;padding:36px;color:#fff}.rbp-mkt-cta h2,.rbp-mkt-cta p{color:#fff}@media(max-width:900px){.rbp-mkt-hero-in,.rbp-mkt-g2,.rbp-mkt-g3,.rbp-mkt-g4{grid-template-columns:1fr}.rbp-mkt-btn{width:100%}.rbp-mkt-sec{padding:56px 0}}
</style>
<div class="rbp-mkt">
<section class="rbp-mkt-hero"><div class="rbp-mkt-c rbp-mkt-hero-in"><div><span class="rbp-mkt-ey">RBP Marketplace</span><h1>Business opportunities, partner offers and practical growth pathways.</h1><p>Explore Business-In-A-Box packages, asset sale opportunities, partner offers, due diligence pathways and custom business builds designed for Australian SMEs.</p><div class="rbp-mkt-actions"><a class="rbp-mkt-btn rbp-mkt-btn--primary" href="#marketplace-pathways">Browse marketplace pathways</a><a class="rbp-mkt-btn" href="/pages/business-assessment">Start assessment</a><a class="rbp-mkt-btn" href="/pages/submit-a-listing">Submit a listing</a><a class="rbp-mkt-btn" href="/pages/partner-referrals">Become a partner</a></div></div><aside class="rbp-mkt-card rbp-mkt-hero-card"><h3>Marketplace pathways</h3><div class="rbp-mkt-grid"><p><strong>Business-In-A-Box</strong><br>Packaged business models and build pathways</p><p><strong>Asset Sales</strong><br>Listing, review and due diligence pathways</p><p><strong>Partner Offers</strong><br>Vetted tools, services and resources</p><p><strong>Buyer Support</strong><br>Assessment, enquiry and qualification</p></div></aside></div></section>
<section class="rbp-mkt-sec" id="marketplace-pathways"><div class="rbp-mkt-c"><span class="rbp-mkt-ey">Pathways</span><h2>Choose the right marketplace path.</h2><div class="rbp-mkt-grid rbp-mkt-g3">
{% assign paths='BIAB|Business-In-A-Box|Packaged business concepts, starter kits, launch packs and managed build options.|/pages/business-in-a-box,AS|Asset Sales|Explore business assets, operating kits, digital assets and review pathways.|/collections/asset-sales,PO|Partner Offers|Browse curated partner tools, services, finance options and resources for Australian SMEs.|/pages/offers,BP|Buyer Pathway|Use buyer guides, assessment and enquiry steps to choose the right path.|/pages/buyer-application,SP|Seller Pathway|Submit a business, asset, offer or resource for review and potential marketplace listing.|/pages/submit-a-listing,CB|Custom Business Build|Shape a tailored business model, implementation pathway or packaged commercial offer.|/pages/custom-business-build' | split: ',' %}
{% for item in paths %}{% assign p=item | split:'|' %}<a class="rbp-mkt-card rbp-mkt-path" href="{{ p[3] }}"><span>{{ p[0] }}</span><h3>{{ p[1] }}</h3><p>{{ p[2] }}</p></a>{% endfor %}
</div></div></section>
<section class="rbp-mkt-sec rbp-mkt-muted"><div class="rbp-mkt-c rbp-mkt-grid rbp-mkt-g2"><div class="rbp-mkt-card"><span class="rbp-mkt-ey">Business-In-A-Box</span><h2>Build or buy a packaged business pathway.</h2><p>Business-In-A-Box packages combine practical business concepts, templates, launch assets, advisory options and managed build support.</p><ul class="rbp-mkt-list"><li>Starter kits and launch packs</li><li>Managed Shopify store build pathways</li><li>Operational templates and process assets</li><li>Advisory and implementation support</li></ul><div class="rbp-mkt-actions"><a class="rbp-mkt-btn rbp-mkt-btn--primary" href="/pages/business-in-a-box">View Business-In-A-Box</a><a class="rbp-mkt-btn" href="/pages/business-assessment">Start assessment</a></div></div><div class="rbp-mkt-card"><span class="rbp-mkt-ey">Asset Sales</span><h2>Explore asset sale and review pathways.</h2><p>Some opportunities may require buyer qualification, confidentiality steps or paid review materials before detailed information is released.</p><ul class="rbp-mkt-list"><li>Public listing summaries</li><li>Buyer qualification</li><li>Due diligence packs</li><li>Deposit or review pathways</li><li>Private information release after approval</li></ul><div class="rbp-mkt-actions"><a class="rbp-mkt-btn rbp-mkt-btn--primary" href="/collections/asset-sales">View Asset Sales</a><a class="rbp-mkt-btn" href="/pages/asset-sales-process">Read Process</a><a class="rbp-mkt-btn" href="/pages/request-due-diligence">Request Due Diligence</a></div></div></div></section>
<section class="rbp-mkt-sec"><div class="rbp-mkt-c"><span class="rbp-mkt-ey">Featured partner offers</span><h2>Curated offers remain part of the marketplace.</h2><p>Browse curated partner tools, services, resources and finance options that support business operations and growth.</p><div class="rbp-mkt-grid rbp-mkt-g3"><article class="rbp-mkt-card"><h3>Business productivity platform</h3><p>Available after enquiry. Final inclusions and eligibility are confirmed before activation.</p><a class="rbp-mkt-btn" href="/pages/offers">View offers</a></article><article class="rbp-mkt-card"><h3>Member pricing opportunities</h3><p>Member pricing is subject to eligibility, offer approval and partner terms.</p><a class="rbp-mkt-btn" href="/pages/member-benefits">View member benefits</a></article><article class="rbp-mkt-card"><h3>Business finance tools</h3><p>Pricing confirmed after enquiry. Finance outcomes remain subject to provider assessment.</p><a class="rbp-mkt-btn" href="/pages/offers">Browse partner offers</a></article></div></div></section>
<section class="rbp-mkt-sec rbp-mkt-muted"><div class="rbp-mkt-c rbp-mkt-grid rbp-mkt-g2"><article class="rbp-mkt-card"><h2>Looking for the right business opportunity?</h2><p>Use the buyer pathway to compare options, request information, assess fit and move toward the right marketplace step.</p><div class="rbp-mkt-actions"><a class="rbp-mkt-btn rbp-mkt-btn--primary" href="/pages/buyer-application">Start Buyer Application</a><a class="rbp-mkt-btn" href="/pages/compare-opportunities">Compare Opportunities</a></div></article><article class="rbp-mkt-card"><h2>Have an asset, offer or business pathway to list?</h2><p>Submit a business asset, partner offer, resource or packaged opportunity for review.</p><div class="rbp-mkt-actions"><a class="rbp-mkt-btn rbp-mkt-btn--primary" href="/pages/submit-a-listing">Submit a Listing</a><a class="rbp-mkt-btn" href="/pages/partner-referrals">Become a Partner</a></div></article></div></section>
<section class="rbp-mkt-sec"><div class="rbp-mkt-c rbp-mkt-grid rbp-mkt-g2"><div><span class="rbp-mkt-ey">Process</span><h2>How marketplace enquiries are handled.</h2><div class="rbp-mkt-process"><div class="rbp-mkt-step"><h3>Browse or enquire</h3><p>Start with the relevant pathway, listing or assessment route.</p></div><div class="rbp-mkt-step"><h3>Confirm fit</h3><p>RBP reviews business fit, eligibility and the right next step.</p></div><div class="rbp-mkt-step"><h3>Review details</h3><p>Confidential, paid or private information is released only through the correct process.</p></div><div class="rbp-mkt-step"><h3>Move forward</h3><p>Proceed with the relevant enquiry, offer, due diligence or build pathway.</p></div></div></div><div class="rbp-mkt-card"><h3>Support links</h3><div class="rbp-mkt-grid"><a href="/pages/buyer-guide">Buyer Guide</a><a href="/pages/seller-guide">Seller Guide</a><a href="/pages/confidentiality-process">Confidentiality Process</a><a href="/pages/due-diligence-packs">Due Diligence Packs</a><a href="/pages/marketplace-terms">Marketplace Terms</a></div></div></div></section>
<section class="rbp-mkt-sec rbp-mkt-muted"><div class="rbp-mkt-c"><div class="rbp-mkt-cta"><h2>Find the right marketplace pathway for your business.</h2><p>Browse opportunities, review partner offers, submit an enquiry or use the assessment pathway to find the right next step.</p><div class="rbp-mkt-actions"><a class="rbp-mkt-btn" href="#marketplace-pathways">Browse marketplace</a><a class="rbp-mkt-btn" href="/pages/business-assessment">Start assessment</a><a class="rbp-mkt-btn" href="/pages/contact">Contact RBP</a></div></div></div></section>
</div>
