<script>
(function() {
  // ── Filter buttons
  var filterBtns = document.querySelectorAll('[data-filter]');
  var cards = document.querySelectorAll('.rbp-mkt-card');
  var noResults = document.getElementById('rbp-mkt-noresults');
  var searchInput = document.getElementById('rbp-mkt-search-input');
  var activeFilter = 'all';
  var searchQuery = '';

  function filterCards() {
    var visible = 0;
    cards.forEach(function(card) {
      var cat = card.dataset.category || '';
      var title = (card.querySelector('.rbp-mkt-card-title') || {}).textContent || '';
      var matchFilter = activeFilter === 'all' || cat.indexOf(activeFilter) !== -1;
      var matchSearch = !searchQuery || title.toLowerCase().indexOf(searchQuery) !== -1 || cat.toLowerCase().indexOf(searchQuery) !== -1;
      var show = matchFilter && matchSearch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      activeFilter = this.dataset.filter;
      filterCards();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      searchQuery = this.value.trim().toLowerCase();
      filterCards();
    });
  }

  // ── G10 QA: IntersectionObserver scroll entrance animations
  if ('IntersectionObserver' in window) {
    var animEls = document.querySelectorAll('.rbp-mkt-anim');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('rbp-mkt-anim--in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -32px 0px' });
    animEls.forEach(function(el) { io.observe(el); });
  } else {
    document.querySelectorAll('.rbp-mkt-anim').forEach(function(el) {
      el.classList.add('rbp-mkt-anim--in');
    });
  }
})();
</script>

