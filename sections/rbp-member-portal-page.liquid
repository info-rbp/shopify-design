{%- liquid
  assign is_member = false
  assign member_level = 'Not currently identified as a Premium Member'
  assign lifecycle = 'none'
  if customer
    if customer.tags contains 'rbp-premium-active' or customer.tags contains 'Premium Member'
      assign is_member = true
      assign member_level = 'Premium Membership active'
      assign lifecycle = 'active'
    elsif customer.tags contains 'rbp-premium-approved'
      assign member_level = 'Premium Membership approved'
      assign lifecycle = 'approved'
    elsif customer.tags contains 'rbp-premium-applied'
      assign member_level = 'Application under review'
      assign lifecycle = 'applied'
    elsif customer.tags contains 'rbp-premium-suspended'
      assign member_level = 'Premium Membership suspended'
      assign lifecycle = 'restricted'
    elsif customer.tags contains 'rbp-premium-cancelled'
      assign member_level = 'Premium Membership cancelled'
      assign lifecycle = 'restricted'
    endif
  endif
  assign gated_page = false
  if page.handle == 'member-resources'
    assign gated_page = true
  endif
  assign eyebrow = 'Member portal'
  assign summary = 'Use this page to understand account support, Premium Member benefits, order support, document status and payment-plan guidance.'
  assign mode = 'portal'
  if page.handle == 'member-benefits'
    assign eyebrow = 'Premium Member benefits'
    assign summary = 'Review Premium Member benefits, access pathways and support areas available through Remote Business Partner.'
    assign mode = 'benefits'
  elsif page.handle == 'account-support'
    assign eyebrow = 'Account support'
    assign summary = 'Get guidance on customer account access, login, addresses, order history and Premium Member access expectations.'
    assign mode = 'account'
  elsif page.handle == 'order-support'
    assign eyebrow = 'Order support'
    assign summary = 'Understand how to get help with orders, document products, onboarding, revisions, delivery and Business NBN enquiries.'
    assign mode = 'orders'
  elsif page.handle == 'document-order-status'
    assign eyebrow = 'Document order status'
    assign summary = 'Track the usual stages of document orders from purchase to onboarding, preparation, review, revisions and use.'
    assign mode = 'documents'
  elsif page.handle == 'payment-plan-support'
    assign eyebrow = 'Payment plan support'
    assign summary = 'Payment plan management is facilitated through Shopify Subscriptions and actioned independently where required.'
    assign mode = 'payments'
  elsif page.handle == 'member-resources'
    assign eyebrow = 'Premium Member resources'
    assign summary = 'Access Premium Member-only resource guidance and pathways. Actual member-only content will be populated later.'
    assign mode = 'resources'
  endif
-%}
<style>
.rbp-mportal{--b:#1d4ed8;--bd:#1e3a8a;--bs:#dbeafe;--s9:#0f172a;--s6:#475569;--br:rgba(15,23,42,.1);background:#fff;color:#0f172a}.rbp-mportal *{box-sizing:border-box}.rbp-mportal a{text-decoration:none;color:inherit}.rbp-mportal-c{width:min(100% - 3rem,1200px);margin:auto}.rbp-mportal-hero{background:radial-gradient(ellipse at top right,rgba(59,130,246,.24),transparent 58%),linear-gradient(135deg,#0f172a,#172554);color:#fff}.rbp-mportal-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(300px,.38fr);gap:36px;align-items:center;padding:82px 0}.rbp-mportal-ey{display:inline-flex;border-radius:999px;background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28);padding:7px 12px;font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-mportal h1{margin:16px 0 0;color:#fff;font-size:clamp(40px,6vw,76px);line-height:1.02;letter-spacing:-.045em;font-weight:900}.rbp-mportal h2{margin:10px 0 0;color:#0f172a;font-size:clamp(28px,4vw,48px);line-height:1.08;letter-spacing:-.035em;font-weight:900}.rbp-mportal p{margin:14px 0 0;color:#64748b;line-height:1.7}.rbp-mportal-hero p{color:#cbd5e1;font-size:18px}.rbp-mportal-status{border:1px solid rgba(255,255,255,.16);border-radius:24px;background:rgba(255,255,255,.08);padding:22px}.rbp-mportal-status span{display:block;color:#bfdbfe;font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-mportal-status strong{display:block;margin-top:8px;color:#fff;font-size:24px;font-weight:900}.rbp-mportal-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:24px}.rbp-mportal-btn{display:inline-flex;justify-content:center;align-items:center;border-radius:14px;padding:13px 16px;border:1px solid rgba(15,23,42,.14);background:#fff;color:#334155;font-size:14px;font-weight:900}.rbp-mportal-btn--primary{background:#1d4ed8;border-color:#1d4ed8;color:#fff}.rbp-mportal-sec{padding:72px 0}.rbp-mportal-muted{background:#f8fafc}.rbp-mportal-grid{display:grid;gap:18px}.rbp-mportal-g2{grid-template-columns:repeat(2,minmax(0,1fr))}.rbp-mportal-g3{grid-template-columns:repeat(3,minmax(0,1fr))}.rbp-mportal-g4{grid-template-columns:repeat(4,minmax(0,1fr))}.rbp-mportal-card{border:1px solid rgba(15,23,42,.1);border-radius:24px;background:#fff;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-mportal-card span{width:44px;height:44px;border-radius:15px;background:#dbeafe;color:#1d4ed8;display:grid;place-items:center;font-weight:900;margin-bottom:14px}.rbp-mportal-card h3{margin:0 0 8px;color:#0f172a;font-size:18px;font-weight:900}.rbp-mportal-card p{font-size:14px}.rbp-mportal-blue{background:linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;border:0}.rbp-mportal-blue h2,.rbp-mportal-blue h3{color:#fff}.rbp-mportal-blue p{color:#dbeafe}.rbp-mportal-list{display:grid;gap:10px;margin:18px 0 0;padding:0;list-style:none}.rbp-mportal-list li{display:grid;grid-template-columns:22px 1fr;gap:10px;color:#64748b;line-height:1.55}.rbp-mportal-check{width:18px;height:18px;border-radius:999px;background:#1d4ed8;color:#fff;display:grid;place-items:center;font-size:12px;font-weight:900}.rbp-mportal-step{position:relative;padding-left:54px}.rbp-mportal-step+.rbp-mportal-step{margin-top:18px}.rbp-mportal-step b{position:absolute;top:0;left:0;width:40px;height:40px;border-radius:999px;background:#1d4ed8;color:#fff;display:grid;place-items:center;font-size:12px}.rbp-mportal-step h3{margin:0 0 5px;color:#0f172a;font-size:16px;font-weight:900}.rbp-mportal-gate{border-radius:30px;background:linear-gradient(135deg,#0f172a,#172554);color:#fff;padding:clamp(28px,5vw,56px);text-align:center}.rbp-mportal-gate h2{color:#fff}.rbp-mportal-gate p{color:#cbd5e1;max-width:680px;margin-inline:auto}.rbp-mportal-note{border:1px solid rgba(15,23,42,.1);border-radius:22px;background:#fff;padding:22px;margin-top:18px}.rbp-mportal-note strong{display:block;color:#0f172a;font-weight:900;margin-bottom:6px}@media(max-width:989px){.rbp-mportal-hero-in,.rbp-mportal-g2,.rbp-mportal-g3,.rbp-mportal-g4{grid-template-columns:1fr}}@media(max-width:749px){.rbp-mportal-c{width:min(100% - 2rem,1200px)}.rbp-mportal-sec{padding:54px 0}.rbp-mportal-hero-in{padding:64px 0}.rbp-mportal-btn{width:100%}}
</style>
<div class="rbp-mportal">
<section class="rbp-mportal-hero"><div class="rbp-mportal-c"><div class="rbp-mportal-hero-in"><div><div class="rbp-mportal-ey">{{ eyebrow }}</div><h1>{{ page.title }}</h1><p>{{ summary }}</p><div class="rbp-mportal-actions"><a class="rbp-mportal-btn rbp-mportal-btn--primary" href="/account">Go to account</a><a class="rbp-mportal-btn" href="/pages/help-centre">Help Centre</a></div></div><aside class="rbp-mportal-status"><span>Member status</span><strong>{{ member_level }}</strong>{%- if customer -%}<p>Signed in as {{ customer.email }}</p>{%- else -%}<p>Sign in to check Premium Member access.</p>{%- endif -%}</aside></div></div></section>
{%- if gated_page and is_member == false -%}
<section class="rbp-mportal-sec"><div class="rbp-mportal-c"><div class="rbp-mportal-gate"><h2>Premium Member access required</h2><p>This page is intended for customers tagged as <strong>Premium Member</strong>. Sign in with the correct account or ask about membership access.</p><div class="rbp-mportal-actions" style="justify-content:center;"><a class="rbp-mportal-btn rbp-mportal-btn--primary" href="/account">Sign in</a><a class="rbp-mportal-btn" href="/pages/membership">View membership</a><a class="rbp-mportal-btn" href="/pages/contact">Contact support</a></div></div></div></section>
{%- elsif lifecycle == 'applied' -%}
<section class="rbp-mportal-sec"><div class="rbp-mportal-c"><div class="rbp-mportal-gate"><h2>Your Premium Membership application is under review.</h2><p>RBP will contact you after business fit, agreement and serviceability checks are reviewed.</p><div class="rbp-mportal-actions" style="justify-content:center;"><a class="rbp-mportal-btn rbp-mportal-btn--primary" href="/pages/contact">Contact support</a><a class="rbp-mportal-btn" href="/pages/membership-faq">Membership FAQ</a></div></div></div></section>
{%- elsif lifecycle == 'approved' -%}
<section class="rbp-mportal-sec"><div class="rbp-mportal-c"><div class="rbp-mportal-gate"><h2>Your Premium Membership is approved.</h2><p>Complete the agreement and activation steps supplied by RBP before member-only resources are exposed.</p><div class="rbp-mportal-actions" style="justify-content:center;"><a class="rbp-mportal-btn rbp-mportal-btn--primary" href="/pages/contact">Request activation help</a><a class="rbp-mportal-btn" href="/account">Go to account</a></div></div></div></section>
{%- elsif lifecycle == 'restricted' -%}
<section class="rbp-mportal-sec"><div class="rbp-mportal-c"><div class="rbp-mportal-gate"><h2>Premium Membership access is currently restricted.</h2><p>Use the support pathway to review your membership status before accessing member-only content.</p><div class="rbp-mportal-actions" style="justify-content:center;"><a class="rbp-mportal-btn rbp-mportal-btn--primary" href="/pages/contact">Contact support</a><a class="rbp-mportal-btn" href="/pages/help-centre">Help Centre</a></div></div></div></section>
{%- else -%}
<section class="rbp-mportal-sec"><div class="rbp-mportal-c"><div class="rbp-mportal-grid rbp-mportal-g3"><a class="rbp-mportal-card" href="/pages/member-benefits"><span>MB</span><h3>Premium Member benefits</h3><p>Benefits, inclusion areas, support expectations and access guidance.</p></a><a class="rbp-mportal-card" href="/pages/account-support"><span>AC</span><h3>Account support</h3><p>Login, address, order history and Premium Member tag access guidance.</p></a><a class="rbp-mportal-card" href="/pages/order-support"><span>OS</span><h3>Order support</h3><p>Help with orders, onboarding, revisions, delivery and support routing.</p></a><a class="rbp-mportal-card" href="/pages/document-order-status"><span>DS</span><h3>Document order status</h3><p>Purchase, onboarding, preparation, delivery, review and revisions.</p></a><a class="rbp-mportal-card" href="/pages/payment-plan-support"><span>PP</span><h3>Payment plan support</h3><p>Payment plans are facilitated through Shopify Subscriptions and actioned independently.</p></a><a class="rbp-mportal-card" href="/pages/member-resources"><span>MR</span><h3>Premium resources</h3><p>Premium-only resource area scaffolded for later content population.</p></a></div>{%- if mode == 'resources' -%}<div class="rbp-mportal-note"><strong>Resource content coming later</strong><p>Actual Premium Member-only resources will be populated later. This page is currently the gated portal shell and access-control experience.</p></div>{%- endif -%}</div></section>
<section class="rbp-mportal-sec rbp-mportal-muted"><div class="rbp-mportal-c"><div class="rbp-mportal-grid rbp-mportal-g2"><div class="rbp-mportal-card rbp-mportal-blue"><h2>Account navigation strategy</h2><p>Use the customer account for order history and addresses. Use the member portal pages for Premium Member benefits, resources, document status, payment guidance and support routing.</p><ul class="rbp-mportal-list"><li><span class="rbp-mportal-check">✓</span><span>Account page: orders and addresses</span></li><li><span class="rbp-mportal-check">✓</span><span>Premium Member pages: benefits and resource pathways</span></li><li><span class="rbp-mportal-check">✓</span><span>Shopify Subscriptions: membership billing and payment-plan support</span></li><li><span class="rbp-mportal-check">✓</span><span>Help Centre: support routing and FAQs</span></li></ul></div><div class="rbp-mportal-card"><h2>{% if mode == 'payments' %}Shopify Subscriptions payment support{% elsif mode == 'documents' %}Document order stages{% elsif mode == 'orders' %}Order support pathway{% elsif mode == 'account' %}Account support pathway{% else %}Premium Member support pathway{% endif %}</h2><div class="rbp-mportal-step"><b>01</b><h3>Review your account or page guidance</h3><p>Start with the relevant portal page and check the current order, Premium Member or support area.</p></div><div class="rbp-mportal-step"><b>02</b><h3>Collect the required details</h3><p>Use order number, product name, business name, member email or support category where relevant.</p></div><div class="rbp-mportal-step"><b>03</b><h3>Use the right support route</h3><p>Use Help Centre or Contact Support so the request can be routed correctly instead of becoming inbox fog.</p></div></div></div></div></section>
<section class="rbp-mportal-sec"><div class="rbp-mportal-c"><div class="rbp-mportal-grid rbp-mportal-g4"><div class="rbp-mportal-card"><span>01</span><h3>Premium Member benefits</h3><p>Resources, document pathways, service access and member support are connected to the Premium Member model.</p></div><div class="rbp-mportal-card"><span>02</span><h3>Tagged access</h3><p>Member-only pages check the customer tag <strong>Premium Member</strong>.</p></div><div class="rbp-mportal-card"><span>03</span><h3>Document orders</h3><p>Document products move through purchase, onboarding, preparation, review and revision/use.</p></div><div class="rbp-mportal-card"><span>04</span><h3>Subscriptions</h3><p>Subscription billing and payment plans are facilitated through Shopify Subscriptions.</p></div></div></div></section>
<section class="rbp-mportal-sec rbp-mportal-muted"><div class="rbp-mportal-c"><div class="rbp-mportal-card rbp-mportal-blue"><h2>Need help with this account area?</h2><p>Send the order number, product name, business name and support category where relevant. It saves everyone from decoding “hi help” like ancient scripture.</p><div class="rbp-mportal-actions"><a class="rbp-mportal-btn" href="/pages/contact">Contact support</a><a class="rbp-mportal-btn" href="/pages/help-centre">Visit Help Centre</a></div></div></div></section>
{%- endif -%}
</div>
{% schema %}{"name":"RBP member portal page","settings":[],"presets":[{"name":"RBP member portal page"}]}{% endschema %}
