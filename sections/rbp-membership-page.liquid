{%- liquid
assign member=false
if customer
  if customer.tags contains 'rbp-member' or customer.tags contains 'rbp-member-growth' or customer.tags contains 'rbp-member-premium' or customer.tags contains 'Premium Member'
    assign member=true
  endif
endif
-%}
<style>.rbp-mem{--b:#123fbe;--n:#071326;--i:#0f172a;--m:#5b6675;--l:rgba(15,23,42,.1);font-family:var(--font-body-family,system-ui,sans-serif);color:var(--i)}.rbp-mem *{box-sizing:border-box}.rbp-mem a{text-decoration:none}.rbp-w{width:min(100% - 2.5rem,1160px);margin:auto}.rbp-sec{padding:64px 0}.rbp-soft{background:#f7faff}.rbp-e{display:inline-flex;border-radius:999px;background:#e8efff;color:#123fbe;padding:7px 13px;font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase}.rbp-btn{display:inline-flex;justify-content:center;border-radius:999px;padding:13px 20px;font-weight:900}.rbp-p{background:var(--b);color:#fff}.rbp-s{background:#fff;color:var(--b);border:1px solid rgba(18,63,190,.2)}.rbp-hero{background:linear-gradient(135deg,#071326,#123fbe);color:#fff}.rbp-hero .rbp-w{padding:86px 0;display:grid;grid-template-columns:1fr .55fr;gap:40px;align-items:center}.rbp-hero .rbp-e{background:rgba(255,255,255,.12);color:#dbeafe}.rbp-hero h1,.rbp-head h2{font-size:clamp(34px,5vw,68px);line-height:1;letter-spacing:-.05em;margin:18px 0}.rbp-hero p,.rbp-lock p,.rbp-final p{color:#dbeafe;line-height:1.7}.rbp-card{border:1px solid var(--l);border-radius:22px;background:#fff;padding:24px;box-shadow:0 12px 28px rgba(15,23,42,.05)}.rbp-card p,.rbp-head p,.rbp-faq p{color:var(--m);line-height:1.65}.rbp-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:24px}.rbp-head{text-align:center;max-width:760px;margin:0 auto 36px}.rbp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.rbp-card h3{font-size:22px;margin:0 0 10px}.rbp-list{padding-left:18px;color:#334155;line-height:1.7}.rbp-tabs{display:flex;gap:6px;background:#eaf1ff;border-radius:16px;padding:6px}.rbp-tab{flex:1;border:0;border-radius:12px;background:transparent;font-weight:900;padding:12px}.rbp-tab.active{background:#fff;color:var(--b)}.rbp-panel{display:none;margin-top:20px}.rbp-panel.active{display:block}.rbp-portal{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}.rbp-lock,.rbp-final-card{border-radius:28px;background:linear-gradient(135deg,#071326,#123fbe);color:#fff;padding:42px;text-align:center}.rbp-faq{display:grid;gap:12px}.rbp-faq details{border:1px solid var(--l);border-radius:16px;background:#fff;padding:18px}.rbp-final-card{display:grid;grid-template-columns:1fr auto;text-align:left;align-items:center;gap:20px}@media(max-width:850px){.rbp-hero .rbp-w,.rbp-grid,.rbp-portal,.rbp-final-card{grid-template-columns:1fr}.rbp-tabs{flex-direction:column}.rbp-btn{width:100%}}</style>
<div class="rbp-mem">
<section class="rbp-hero"><div class="rbp-w"><div><span class="rbp-e">{{ section.settings.eyebrow }}</span><h1>{{ section.settings.hero_heading }}</h1><p>{{ section.settings.hero_subtext }}</p><div class="rbp-actions"><a class="rbp-btn rbp-p" href="#rbp-plans">Compare Plans</a><a class="rbp-btn rbp-s" href="/pages/contact">Talk to RBP</a></div></div><aside class="rbp-card"><span class="rbp-e">Member pathway</span><h3>Ongoing business support access.</h3><p>Membership gives customers a structured path into resources, guidance, offers and service routing.</p></aside></div></section>
<section class="rbp-sec" id="benefits"><div class="rbp-w"><div class="rbp-head"><span class="rbp-e">Benefits</span><h2>Designed for businesses that need recurring support structure.</h2><p>Membership supports resource access, account-based member status, support routing and partner offer pathways while preserving separate advisory or implementation services where needed.</p></div><div class="rbp-grid"><article class="rbp-card"><h3>Resource access</h3><p>Members can access curated resources, templates and guidance aligned to their membership level.</p></article><article class="rbp-card"><h3>Service routing</h3><p>Clearer pathways into advisory, consulting, operations and implementation support.</p></article><article class="rbp-card"><h3>Member offers</h3><p>Relevant platform or partner offers can be promoted through the member journey where available.</p></article></div></div></section>
<section class="rbp-sec rbp-soft" id="rbp-plans"><div class="rbp-w"><div class="rbp-head"><span class="rbp-e">Plans</span><h2>Foundation, Growth and Premium pathways.</h2><p>Pricing and exact inclusions remain confirm-before-activation so customers are not pushed into unclear checkout flows.</p></div><div class="rbp-grid"><article class="rbp-card"><h3>Foundation</h3><p>Entry membership for basic resource access and standard support routing.</p><ul class="rbp-list"><li>Selected resources</li><li>Help Centre access</li><li>Basic document guidance</li><li>Standard enquiry pathway</li></ul><a class="rbp-btn rbp-s" href="/pages/contact?membership=foundation">Ask about Foundation</a></article><article class="rbp-card"><h3>Growth</h3><p>Expanded membership for businesses needing more structured guidance.</p><ul class="rbp-list"><li>Everything in Foundation</li><li>Expanded resources</li><li>Structured document pathway</li><li>Member-focused service routing</li></ul><a class="rbp-btn rbp-p" href="/pages/contact?membership=growth">Ask about Growth</a></article><article class="rbp-card"><h3>Premium</h3><p>Broadest pathway for deeper access and priority-style routing where available.</p><ul class="rbp-list"><li>Everything in Growth</li><li>Broader document pathways</li><li>Expanded offer access</li><li>Priority-style routing where available</li></ul><a class="rbp-btn rbp-p" href="/pages/contact?membership=premium">Ask about Premium</a></article></div></div></section>
<section class="rbp-sec"><div class="rbp-w"><div class="rbp-head"><span class="rbp-e">Inclusions</span><h2>Compare access by level.</h2><p>Use the tabs to review how the membership pathway changes by tier.</p></div><div class="rbp-tabs"><button class="rbp-tab active" data-tab="all">All tiers</button><button class="rbp-tab" data-tab="foundation">Foundation</button><button class="rbp-tab" data-tab="growth">Growth</button><button class="rbp-tab" data-tab="premium">Premium</button></div><div class="rbp-panel active" id="tab-all"><div class="rbp-grid"><article class="rbp-card"><h3>Account access</h3><p>Customer account, purchase record and member status pathway.</p></article><article class="rbp-card"><h3>Resources</h3><p>Selected, expanded or premium-level resource routes.</p></article><article class="rbp-card"><h3>Support</h3><p>Clearer routing into the right RBP service area.</p></article></div></div><div class="rbp-panel" id="tab-foundation"><div class="rbp-card"><h3>Foundation</h3><p>Best for basic resource access, Help Centre guidance and standard contact routes.</p></div></div><div class="rbp-panel" id="tab-growth"><div class="rbp-card"><h3>Growth</h3><p>Best for expanded resources, structured document support and member-focused routing.</p></div></div><div class="rbp-panel" id="tab-premium"><div class="rbp-card"><h3>Premium</h3><p>Best for broader access, recurring guidance needs and priority-style routing where available.</p></div></div></div></section>
<section class="rbp-sec rbp-soft"><div class="rbp-w">{% if member %}<div class="rbp-head"><span class="rbp-e">Active member</span><h2>Your member access area.</h2><p>Use your account, resources and support pathways from one place.</p></div><div class="rbp-portal"><a class="rbp-card" href="/account"><h3>Your account</h3><p>Review account details and purchases.</p></a><a class="rbp-card" href="/pages/resources"><h3>Member resources</h3><p>Open the available resource pathway.</p></a><a class="rbp-card" href="/pages/help-centre"><h3>Help Centre</h3><p>Find guidance and support information.</p></a><a class="rbp-card" href="/pages/contact"><h3>Contact RBP</h3><p>Ask for help with the next step.</p></a></div>{% else %}<div class="rbp-lock"><h2>Member portal access is available to active RBP members.</h2><p>The portal appears after account-based membership access is active.</p><div class="rbp-actions" style="justify-content:center"><a class="rbp-btn rbp-s" href="/account">Log in</a><a class="rbp-btn rbp-p" href="#rbp-plans">View membership options</a></div></div>{% endif %}</div></section>
<section class="rbp-sec" id="faq"><div class="rbp-w" style="max-width:900px"><div class="rbp-head"><span class="rbp-e">FAQ</span><h2>Membership questions.</h2></div><div class="rbp-faq"><details open><summary>Which plan should I choose?</summary><p>Foundation suits entry access, Growth suits broader resources and Premium suits the widest pathway.</p></details><details><summary>Do I need to join before speaking with RBP?</summary><p>No. Use the contact pathway first if the right fit is unclear.</p></details><details><summary>How is member access recognised?</summary><p>Access can be recognised through customer account tags and Shopify-supported member workflows.</p></details></div></div></section>
<section class="rbp-sec rbp-final"><div class="rbp-w"><div class="rbp-final-card"><div><h2>Choose a practical membership pathway.</h2><p>Compare plans or talk to RBP before activating member access.</p></div><a class="rbp-btn rbp-s" href="/pages/contact">Talk to RBP</a></div></div></section></div>
<script>(()=>{document.querySelectorAll('.rbp-tab').forEach(t=>t.addEventListener('click',()=>{const r=t.closest('.rbp-mem');r.querySelectorAll('.rbp-tab').forEach(x=>x.classList.remove('active'));r.querySelectorAll('.rbp-panel').forEach(x=>x.classList.remove('active'));t.classList.add('active');const p=r.querySelector('#tab-'+t.dataset.tab);if(p)p.classList.add('active')}));})();</script>
{% schema %}{"name":"RBP Membership Page","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow label","default":"Membership"},{"type":"text","id":"hero_heading","label":"Hero heading","default":"Ongoing access to practical business support."},{"type":"textarea","id":"hero_subtext","label":"Hero subtext","default":"Membership pathways for structured access to resources, benefits, offers and support."}],"presets":[{"name":"RBP Membership Page"}]}{% endschema %}
