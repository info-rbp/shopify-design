{%- liquid
  assign draft_theme = false
  assign member_tagged = false
  if customer
    if customer.tags contains 'rbp-member' or customer.tags contains 'rbp-member-growth' or customer.tags contains 'rbp-member-premium'
      assign member_tagged = true
    endif
    if customer.tags contains 'rbp-member-growth'
      assign member_tier = 'growth'
    elsif customer.tags contains 'rbp-member-premium'
      assign member_tier = 'premium'
    elsif customer.tags contains 'rbp-member'
      assign member_tier = 'foundation'
    endif
  endif
-%}

<style>
/* ─── RBP Design Tokens ─────────────────────────────────────────── */
:root {
  --rbp-navy:       #0f172a;
  --rbp-navy-mid:   #172554;
  --rbp-blue:       #1d4ed8;
  --rbp-blue-light: #3b82f6;
  --rbp-blue-pale:  #dbeafe;
  --rbp-gold:       #f59e0b;
  --rbp-gold-pale:  #fef3c7;
  --rbp-green:      #059669;
  --rbp-green-pale: #d1fae5;
  --rbp-amber:      #d97706;
  --rbp-purple:     #7c3aed;
  --rbp-slate-9:    #0f172a;
  --rbp-slate-7:    #334155;
  --rbp-slate-6:    #475569;
  --rbp-slate-4:    #94a3b8;
  --rbp-slate-2:    #e2e8f0;
  --rbp-slate-1:    #f1f5f9;
  --rbp-slate-0:    #f8fafc;
  --rbp-white:      #ffffff;
  --rbp-radius-sm:  8px;
  --rbp-radius:     16px;
  --rbp-radius-lg:  24px;
  --rbp-shadow:     0 4px 24px rgba(15,23,42,.10);
  --rbp-shadow-lg:  0 16px 56px rgba(15,23,42,.16);
}

/* ─── Base ───────────────────────────────────────────────────────── */
.rbp-mem { background: var(--rbp-white); color: var(--rbp-slate-9); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
.rbp-mem *, .rbp-mem *::before, .rbp-mem *::after { box-sizing: border-box; margin: 0; }
.rbp-mem a { text-decoration: none; color: inherit; }
.rbp-mem ul { list-style: none; padding: 0; }
.rbp-mem-c { width: min(100% - 2.5rem, 1260px); margin-inline: auto; }
.rbp-mem-sec { padding: 88px 0; }
.rbp-mem-sec-sm { padding: 56px 0; }
.rbp-mem-muted { background: var(--rbp-slate-0); }
.rbp-mem-dark { background: var(--rbp-navy); color: var(--rbp-white); }

/* ─── Eyebrow ────────────────────────────────────────────────────── */
.rbp-mem-eye {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; border-radius: 999px;
  font-size: 11px; font-weight: 800; letter-spacing: .10em; text-transform: uppercase;
  background: var(--rbp-blue-pale); color: var(--rbp-blue);
}
.rbp-mem-eye--gold  { background: var(--rbp-gold-pale);  color: var(--rbp-amber); }
.rbp-mem-eye--green { background: var(--rbp-green-pale);  color: var(--rbp-green); }
.rbp-mem-eye--white { background: rgba(255,255,255,.14); color: rgba(255,255,255,.9); border: 1px solid rgba(255,255,255,.22); }
.rbp-mem-eye-dot { width: 6px; height: 6px; border-radius: 999px; background: currentColor; }

/* ─── Headings ───────────────────────────────────────────────────── */
.rbp-mem-h1 { font-size: clamp(42px,6.5vw,80px); font-weight: 900; line-height: 1.0; letter-spacing: -.045em; color: var(--rbp-white); }
.rbp-mem-h2 { font-size: clamp(30px,4vw,52px); font-weight: 900; line-height: 1.05; letter-spacing: -.03em; }
.rbp-mem-h3 { font-size: clamp(18px,2.5vw,26px); font-weight: 800; line-height: 1.15; letter-spacing: -.02em; }
.rbp-mem-p  { font-size: 16px; line-height: 1.75; color: var(--rbp-slate-6); }
.rbp-mem-head { text-align: center; max-width: 760px; margin: 0 auto 56px; }
.rbp-mem-head .rbp-mem-eye { margin-bottom: 16px; }
.rbp-mem-head .rbp-mem-h2 { margin: 12px 0 16px; }

/* ─── Hero ───────────────────────────────────────────────────────── */
.rbp-mem-hero {
  background:
    radial-gradient(ellipse 80% 60% at 70% 30%, rgba(59,130,246,.22), transparent 65%),
    radial-gradient(ellipse 60% 80% at 10% 80%, rgba(124,58,237,.16), transparent 60%),
    linear-gradient(150deg, #0f172a 0%, #1e3a8a 55%, #0f172a 100%);
  overflow: hidden; position: relative;
}
.rbp-mem-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.022'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
.rbp-mem-hero-in {
  display: grid;
  grid-template-columns: minmax(0,1fr) minmax(340px,.8fr);
  gap: 64px; align-items: center;
  padding: 100px 0 80px; min-height: 600px;
}
.rbp-mem-hero-text .rbp-mem-eye { margin-bottom: 20px; }
.rbp-mem-hero-text .rbp-mem-h1 { margin-bottom: 20px; }
.rbp-mem-hero-text .rbp-mem-p { color: #cbd5e1; font-size: 18px; max-width: 580px; margin-bottom: 32px; }
.rbp-mem-hero-proof {
  display: flex; flex-wrap: wrap; gap: 8px 24px;
  margin-top: 32px; padding-top: 28px;
  border-top: 1px solid rgba(255,255,255,.12);
}
.rbp-mem-hero-proof span {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: #94a3b8; font-weight: 600;
}
.rbp-mem-hero-proof span svg { flex-shrink: 0; }

/* ─── Hero floating card ─────────────────────────────────────────── */
.rbp-mem-hero-card {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.12);
  backdrop-filter: blur(20px);
  border-radius: var(--rbp-radius-lg);
  padding: 40px 36px;
  position: relative; overflow: hidden;
}
.rbp-mem-hero-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--rbp-gold), var(--rbp-blue-light));
}
.rbp-mem-hero-card-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 8px 16px; border-radius: 999px;
  background: linear-gradient(135deg, rgba(245,158,11,.18), rgba(245,158,11,.08));
  border: 1px solid rgba(245,158,11,.32);
  color: #fbbf24; font-size: 12px; font-weight: 800;
  letter-spacing: .08em; text-transform: uppercase;
  margin-bottom: 20px;
}
.rbp-mem-hero-card h3 { color: var(--rbp-white); font-size: 22px; font-weight: 800; line-height: 1.2; margin-bottom: 12px; }
.rbp-mem-hero-card p { color: #94a3b8; font-size: 15px; line-height: 1.7; margin-bottom: 24px; }
.rbp-mem-stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 24px; }
.rbp-mem-stat {
  background: rgba(255,255,255,.05); border-radius: var(--rbp-radius);
  border: 1px solid rgba(255,255,255,.08);
  padding: 20px 16px; text-align: center;
}
.rbp-mem-stat-num { font-size: 28px; font-weight: 900; color: var(--rbp-white); letter-spacing: -.03em; }
.rbp-mem-stat-label { font-size: 12px; color: #64748b; font-weight: 600; margin-top: 4px; }
.rbp-mem-stat-tag { font-size: 10px; color: #fbbf24; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; margin-top: 2px; }

/* ─── Member Status Banner ───────────────────────────────────────── */
.rbp-mem-status-bar {
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
  padding: 18px 28px; border-radius: var(--rbp-radius);
  margin-bottom: 40px;
}
.rbp-mem-status-bar--active {
  background: linear-gradient(135deg, #059669, #047857);
  color: var(--rbp-white);
}
.rbp-mem-status-bar--locked {
  background: var(--rbp-slate-1);
  border: 1px solid var(--rbp-slate-2);
  color: var(--rbp-slate-7);
}
.rbp-mem-status-bar-left { display: flex; align-items: center; gap: 14px; }
.rbp-mem-status-icon {
  width: 44px; height: 44px; border-radius: 50%;
  background: rgba(255,255,255,.18);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; flex-shrink: 0;
}
.rbp-mem-status-title { font-size: 16px; font-weight: 800; }
.rbp-mem-status-sub   { font-size: 13px; opacity: .78; margin-top: 2px; }

/* ─── Buttons ────────────────────────────────────────────────────── */
.rbp-mem-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 14px 24px; border-radius: 12px; border: none;
  font-size: 14px; font-weight: 800; line-height: 1; cursor: pointer;
  transition: all .2s ease; white-space: nowrap; text-decoration: none;
}
.rbp-mem-btn--primary { background: var(--rbp-blue); color: var(--rbp-white); box-shadow: 0 8px 24px rgba(29,78,216,.28); }
.rbp-mem-btn--primary:hover { background: #1e40af; transform: translateY(-1px); box-shadow: 0 12px 32px rgba(29,78,216,.36); }
.rbp-mem-btn--gold { background: linear-gradient(135deg, #f59e0b, #d97706); color: var(--rbp-white); box-shadow: 0 8px 24px rgba(245,158,11,.28); }
.rbp-mem-btn--gold:hover { transform: translateY(-1px); box-shadow: 0 12px 32px rgba(245,158,11,.38); }
.rbp-mem-btn--ghost { background: transparent; color: var(--rbp-slate-7); border: 1.5px solid var(--rbp-slate-2); }
.rbp-mem-btn--ghost:hover { background: var(--rbp-slate-1); border-color: var(--rbp-slate-4); }
.rbp-mem-btn--white { background: var(--rbp-white); color: var(--rbp-blue); }
.rbp-mem-btn--white:hover { background: var(--rbp-blue-pale); }
.rbp-mem-btn--sm { padding: 10px 18px; font-size: 13px; }
.rbp-mem-actions { display: flex; flex-wrap: wrap; gap: 12px; }

/* ─── Plan Cards ─────────────────────────────────────────────────── */
.rbp-mem-plans { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; align-items: stretch; }
.rbp-mem-plan {
  background: var(--rbp-white); border: 1.5px solid var(--rbp-slate-2);
  border-radius: var(--rbp-radius-lg); padding: 36px 32px;
  position: relative; overflow: hidden; display: flex; flex-direction: column;
  transition: box-shadow .25s ease, transform .25s ease, border-color .25s ease;
}
.rbp-mem-plan:hover { transform: translateY(-4px); box-shadow: var(--rbp-shadow-lg); border-color: var(--rbp-slate-4); }
.rbp-mem-plan--featured {
  border-color: var(--rbp-blue);
  box-shadow: 0 0 0 3px rgba(29,78,216,.12), var(--rbp-shadow-lg);
  transform: scale(1.02);
  z-index: 1;
}
.rbp-mem-plan--featured:hover { transform: scale(1.02) translateY(-4px); }
.rbp-mem-plan-accent {
  position: absolute; top: 0; left: 0; right: 0; height: 4px;
}
.rbp-mem-plan-badge {
  position: absolute; top: 20px; right: 20px;
  background: var(--rbp-blue); color: var(--rbp-white);
  font-size: 10px; font-weight: 800; letter-spacing: .08em;
  text-transform: uppercase; padding: 5px 12px; border-radius: 999px;
}
.rbp-mem-plan-badge--gold { background: linear-gradient(135deg, #f59e0b, #d97706); }
.rbp-mem-plan-name { font-size: 13px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--rbp-slate-6); margin-bottom: 8px; }
.rbp-mem-plan-title { font-size: 28px; font-weight: 900; color: var(--rbp-slate-9); letter-spacing: -.03em; margin-bottom: 4px; }
.rbp-mem-plan-desc { font-size: 14px; color: var(--rbp-slate-6); line-height: 1.6; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--rbp-slate-2); }
.rbp-mem-plan-price { font-size: 42px; font-weight: 900; color: var(--rbp-slate-9); letter-spacing: -.04em; line-height: 1; }
.rbp-mem-plan-price-note { font-size: 13px; color: var(--rbp-slate-4); margin-top: 4px; margin-bottom: 28px; }
.rbp-mem-plan-price sup { font-size: 20px; vertical-align: super; }
.rbp-mem-plan-price-tbc { font-size: 22px; font-weight: 900; color: var(--rbp-slate-7); }
.rbp-mem-plan-features { flex: 1; }
.rbp-mem-plan-feature {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 10px 0; border-bottom: 1px solid var(--rbp-slate-1);
  font-size: 14px; color: var(--rbp-slate-7); line-height: 1.4;
}
.rbp-mem-plan-feature:last-child { border-bottom: none; }
.rbp-mem-plan-feature-icon {
  width: 20px; height: 20px; flex-shrink: 0;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 11px; margin-top: 1px;
}
.rbp-mem-plan-feature-icon--yes { background: var(--rbp-green-pale); color: var(--rbp-green); }
.rbp-mem-plan-feature-icon--no  { background: var(--rbp-slate-1);     color: var(--rbp-slate-4); }
.rbp-mem-plan-feature-icon--plus { background: var(--rbp-gold-pale);  color: var(--rbp-amber); }
.rbp-mem-plan-cta { margin-top: 28px; }
.rbp-mem-plan-cta .rbp-mem-btn { width: 100%; justify-content: center; }

/* ─── Comparison Table ───────────────────────────────────────────── */
.rbp-mem-table-wrap { overflow-x: auto; border-radius: var(--rbp-radius-lg); border: 1px solid var(--rbp-slate-2); }
.rbp-mem-table { width: 100%; border-collapse: collapse; }
.rbp-mem-table thead { background: var(--rbp-navy); }
.rbp-mem-table th {
  padding: 18px 20px; text-align: left;
  font-size: 12px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
  color: var(--rbp-white);
}
.rbp-mem-table th:first-child { color: #94a3b8; }
.rbp-mem-table th:nth-child(3) { background: rgba(29,78,216,.35); }
.rbp-mem-table td {
  padding: 16px 20px; font-size: 14px; color: var(--rbp-slate-7);
  border-bottom: 1px solid var(--rbp-slate-1); vertical-align: middle;
}
.rbp-mem-table td:first-child { font-weight: 700; color: var(--rbp-slate-9); background: var(--rbp-slate-0); }
.rbp-mem-table td:nth-child(3) { background: rgba(29,78,216,.04); font-weight: 700; }
.rbp-mem-table tr:hover td { background: var(--rbp-slate-0); }
.rbp-mem-table tr:hover td:first-child { background: var(--rbp-slate-1); }
.rbp-mem-table tr:hover td:nth-child(3) { background: rgba(29,78,216,.08); }
.rbp-mem-table tr:last-child td { border-bottom: none; }
.rbp-mem-table .rbp-check { color: var(--rbp-green); font-weight: 900; font-size: 16px; }
.rbp-mem-table .rbp-cross { color: var(--rbp-slate-4); }
.rbp-mem-table-cat { padding: 10px 20px !important; background: var(--rbp-navy) !important; color: #64748b !important; font-size: 10px !important; font-weight: 800 !important; letter-spacing: .10em !important; text-transform: uppercase !important; }

/* ─── Lock State ─────────────────────────────────────────────────── */
.rbp-mem-lock {
  background: linear-gradient(135deg, #1e3a8a, #172554);
  border-radius: var(--rbp-radius-lg);
  padding: 60px 48px; text-align: center;
  position: relative; overflow: hidden;
}
.rbp-mem-lock::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(59,130,246,.25), transparent);
  pointer-events: none;
}
.rbp-mem-lock-icon {
  width: 80px; height: 80px; border-radius: 50%;
  background: rgba(255,255,255,.08);
  border: 2px solid rgba(255,255,255,.16);
  display: flex; align-items: center; justify-content: center;
  font-size: 36px; margin: 0 auto 24px;
}
.rbp-mem-lock h3 { color: var(--rbp-white); font-size: 28px; font-weight: 900; letter-spacing: -.02em; margin-bottom: 12px; }
.rbp-mem-lock p { color: #94a3b8; font-size: 16px; line-height: 1.7; max-width: 480px; margin: 0 auto 32px; }

/* ─── Portal card (active member) ───────────────────────────────── */
.rbp-mem-portal-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
.rbp-mem-portal-card {
  background: var(--rbp-white); border: 1.5px solid var(--rbp-slate-2);
  border-radius: var(--rbp-radius-lg); padding: 32px 28px;
  display: flex; align-items: flex-start; gap: 20px;
  position: relative; overflow: hidden;
  transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  text-decoration: none; color: inherit;
}
.rbp-mem-portal-card:hover { transform: translateY(-3px); box-shadow: var(--rbp-shadow); border-color: var(--rbp-blue); }
.rbp-mem-portal-card::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: var(--rbp-card-color, var(--rbp-blue));
  transform: scaleX(0); transform-origin: left;
  transition: transform .25s ease;
}
.rbp-mem-portal-card:hover::after { transform: scaleX(1); }
.rbp-mem-portal-icon {
  width: 52px; height: 52px; border-radius: 14px;
  background: var(--rbp-icon-bg, var(--rbp-blue-pale));
  color: var(--rbp-icon-color, var(--rbp-blue));
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; flex-shrink: 0;
}
.rbp-mem-portal-card h3 { font-size: 16px; font-weight: 800; color: var(--rbp-slate-9); margin-bottom: 6px; }
.rbp-mem-portal-card p { font-size: 14px; color: var(--rbp-slate-6); line-height: 1.6; }
.rbp-mem-portal-arrow { margin-left: auto; flex-shrink: 0; color: var(--rbp-slate-4); font-size: 20px; align-self: center; transition: transform .2s ease; }
.rbp-mem-portal-card:hover .rbp-mem-portal-arrow { transform: translateX(4px); color: var(--rbp-blue); }

/* ─── Benefits grid ──────────────────────────────────────────────── */
.rbp-mem-benefits { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.rbp-mem-benefit {
  background: var(--rbp-white); border: 1.5px solid var(--rbp-slate-2);
  border-radius: var(--rbp-radius-lg); padding: 32px 24px;
  text-align: center; position: relative; overflow: hidden;
  transition: transform .2s ease, box-shadow .2s ease;
}
.rbp-mem-benefit:hover { transform: translateY(-3px); box-shadow: var(--rbp-shadow); }
.rbp-mem-benefit-num {
  position: absolute; top: 16px; right: 20px;
  font-size: 60px; font-weight: 900; color: rgba(15,23,42,.04);
  line-height: 1; pointer-events: none;
}
.rbp-mem-benefit-icon {
  width: 60px; height: 60px; border-radius: 18px;
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; margin: 0 auto 20px;
}
.rbp-mem-benefit h3 { font-size: 16px; font-weight: 800; color: var(--rbp-slate-9); margin-bottom: 10px; }
.rbp-mem-benefit p { font-size: 14px; color: var(--rbp-slate-6); line-height: 1.6; }

/* ─── How it works steps ─────────────────────────────────────────── */
.rbp-mem-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative; }
.rbp-mem-steps::before {
  content: '';
  position: absolute; top: 28px; left: calc(12.5%); right: calc(12.5%);
  height: 2px; background: linear-gradient(90deg, var(--rbp-blue-pale), var(--rbp-blue), var(--rbp-blue-pale));
  z-index: 0;
}
.rbp-mem-step {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: center;
  text-align: center; padding: 0 16px;
}
.rbp-mem-step-num {
  width: 56px; height: 56px; border-radius: 50%;
  background: var(--rbp-blue); color: var(--rbp-white);
  font-size: 20px; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px; position: relative; z-index: 1;
  box-shadow: 0 0 0 6px var(--rbp-white), 0 0 0 8px var(--rbp-blue-pale);
}
.rbp-mem-step h3 { font-size: 16px; font-weight: 800; color: var(--rbp-slate-9); margin-bottom: 10px; }
.rbp-mem-step p { font-size: 14px; color: var(--rbp-slate-6); line-height: 1.65; }

/* ─── Testimonial / Social proof ─────────────────────────────────── */
.rbp-mem-proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.rbp-mem-proof-card {
  background: var(--rbp-white); border: 1.5px solid var(--rbp-slate-2);
  border-radius: var(--rbp-radius-lg); padding: 32px 28px;
  position: relative;
}
.rbp-mem-proof-stars { color: var(--rbp-gold); font-size: 14px; margin-bottom: 16px; letter-spacing: 2px; }
.rbp-mem-proof-quote { font-size: 15px; color: var(--rbp-slate-7); line-height: 1.7; font-style: italic; margin-bottom: 24px; }
.rbp-mem-proof-quote::before { content: '\201C'; font-size: 40px; color: var(--rbp-blue-pale); line-height: 0; vertical-align: -14px; margin-right: 6px; }
.rbp-mem-proof-author { display: flex; align-items: center; gap: 12px; }
.rbp-mem-proof-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--rbp-blue-pale); color: var(--rbp-blue);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 900; flex-shrink: 0;
}
.rbp-mem-proof-name { font-size: 14px; font-weight: 800; color: var(--rbp-slate-9); }
.rbp-mem-proof-role { font-size: 12px; color: var(--rbp-slate-4); margin-top: 2px; }
.rbp-mem-proof-tier {
  position: absolute; top: 20px; right: 20px;
  font-size: 10px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
  padding: 4px 10px; border-radius: 999px;
}
.rbp-mem-proof-tier--f { background: var(--rbp-slate-1); color: var(--rbp-slate-6); }
.rbp-mem-proof-tier--g { background: var(--rbp-blue-pale); color: var(--rbp-blue); }
.rbp-mem-proof-tier--p { background: var(--rbp-gold-pale); color: var(--rbp-amber); }

/* ─── FAQ accordion ──────────────────────────────────────────────── */
.rbp-mem-faq { display: flex; flex-direction: column; gap: 0; border-radius: var(--rbp-radius-lg); overflow: hidden; border: 1px solid var(--rbp-slate-2); }
.rbp-mem-faq details { border-bottom: 1px solid var(--rbp-slate-2); background: var(--rbp-white); }
.rbp-mem-faq details:last-child { border-bottom: none; }
.rbp-mem-faq summary {
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
  padding: 22px 28px; cursor: pointer; list-style: none;
  font-size: 15px; font-weight: 700; color: var(--rbp-slate-9);
  transition: background .15s ease;
}
.rbp-mem-faq summary:hover { background: var(--rbp-slate-0); }
.rbp-mem-faq summary::-webkit-details-marker { display: none; }
.rbp-mem-faq summary::after { content: '+'; font-size: 20px; font-weight: 300; color: var(--rbp-slate-4); flex-shrink: 0; transition: transform .2s ease; }
.rbp-mem-faq details[open] summary::after { transform: rotate(45deg); }
.rbp-mem-faq details[open] summary { background: var(--rbp-slate-0); color: var(--rbp-blue); }
.rbp-mem-faq-body { padding: 0 28px 24px; font-size: 15px; color: var(--rbp-slate-6); line-height: 1.75; }

/* ─── CTA Band ───────────────────────────────────────────────────── */
.rbp-mem-cta-band {
  background: linear-gradient(135deg, var(--rbp-blue) 0%, #1e40af 50%, var(--rbp-navy) 100%);
  border-radius: var(--rbp-radius-lg);
  padding: 64px 56px;
  display: flex; align-items: center; justify-content: space-between; gap: 40px;
  position: relative; overflow: hidden;
}
.rbp-mem-cta-band::before {
  content: '';
  position: absolute; top: -40%; right: -10%;
  width: 400px; height: 400px; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,.08), transparent 70%);
  pointer-events: none;
}
.rbp-mem-cta-band h2 { color: var(--rbp-white); font-size: clamp(26px,3.5vw,40px); font-weight: 900; letter-spacing: -.03em; margin-bottom: 10px; }
.rbp-mem-cta-band p { color: rgba(255,255,255,.72); font-size: 16px; line-height: 1.65; }
.rbp-mem-cta-actions { display: flex; flex-wrap: wrap; gap: 12px; flex-shrink: 0; }

/* ─── Trust badges ───────────────────────────────────────────────── */
.rbp-mem-trust { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 32px; }
.rbp-mem-trust-item {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; color: var(--rbp-slate-6); font-weight: 600;
}
.rbp-mem-trust-item svg { color: var(--rbp-blue); }

/* ─── Inclusion Tabs ─────────────────────────────────────────────── */
.rbp-mem-tabs { display: flex; gap: 4px; background: var(--rbp-slate-1); padding: 4px; border-radius: 12px; margin-bottom: 32px; }
.rbp-mem-tab {
  flex: 1; padding: 12px 20px; border-radius: 10px;
  border: none; background: transparent; cursor: pointer;
  font-size: 14px; font-weight: 700; color: var(--rbp-slate-6);
  transition: all .2s ease; text-align: center;
}
.rbp-mem-tab.active {
  background: var(--rbp-white); color: var(--rbp-blue);
  box-shadow: 0 2px 8px rgba(15,23,42,.1);
}
.rbp-mem-tab-panel { display: none; }
.rbp-mem-tab-panel.active { display: block; }

/* ─── Inclusions grid ────────────────────────────────────────────── */
.rbp-mem-inclusions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.rbp-mem-inclusion {
  background: var(--rbp-white); border: 1.5px solid var(--rbp-slate-2);
  border-radius: var(--rbp-radius); padding: 24px 20px;
  display: flex; align-items: flex-start; gap: 14px;
}
.rbp-mem-inclusion-icon {
  width: 40px; height: 40px; border-radius: 10px;
  background: var(--rbp-blue-pale); color: var(--rbp-blue);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex-shrink: 0;
}
.rbp-mem-inclusion h4 { font-size: 14px; font-weight: 800; color: var(--rbp-slate-9); margin-bottom: 4px; }
.rbp-mem-inclusion p { font-size: 13px; color: var(--rbp-slate-6); line-height: 1.6; }
.rbp-mem-inclusion-badge {
  display: inline-block; margin-top: 8px;
  font-size: 10px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase;
  padding: 3px 8px; border-radius: 999px;
}
.rbp-mem-inclusion-badge--f { background: var(--rbp-slate-1); color: var(--rbp-slate-6); }
.rbp-mem-inclusion-badge--g { background: var(--rbp-blue-pale); color: var(--rbp-blue); }
.rbp-mem-inclusion-badge--p { background: var(--rbp-gold-pale); color: var(--rbp-amber); }
.rbp-mem-inclusion-badge--all { background: var(--rbp-green-pale); color: var(--rbp-green); }

/* ─── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 1024px) {
