  .rbp-mem-steps    { grid-template-columns: repeat(2, 1fr); gap: 40px; }
  .rbp-mem-steps::before { display: none; }
  .rbp-mem-proof-grid { grid-template-columns: 1fr; }
  .rbp-mem-portal-grid { grid-template-columns: 1fr; }
  .rbp-mem-inclusions { grid-template-columns: 1fr 1fr; }
  .rbp-mem-cta-band { flex-direction: column; padding: 48px 36px; }
}
@media (max-width: 640px) {
