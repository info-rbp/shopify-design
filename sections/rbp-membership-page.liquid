{%- liquid
  assign mode = 'overview'
  if page.handle == 'member-benefits'
    assign mode = 'benefits'
  elsif page.handle == 'membership-faq'
    assign mode = 'faq'
  elsif page.handle == 'sign-up-today'
    assign mode = 'signup'
  endif
-%}
<style>
.rbp-mem{--b:#1d4ed8;--n:#0f172a;--m:#475569;--l:#e2e8f0;--p:#dbeafe;--g:#059669;--a:#d97706;background:#fff;color:#0f172a}.rbp-mem *{box-sizing:border-box}.rbp-mem a{text-decoration:none}.rbp-mem-c{width:min(100% - 2.5rem,1180px);margin:auto}.rbp-mem-sec{padding:72px 0}.rbp-mem-muted{background:#f8fafc}.rbp-mem-hero{background:linear-gradient(135deg,#0f172a,#1e3a8a);color:#fff}.rbp-mem-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(280px,.42fr);gap:36px;align-items:center;padding:82px 0}.rbp-mem-ey{display:inline-flex;border-radius:999px;background:#dbeafe;color:#1d4ed8;padding:7px 12px;font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-mem-hero .rbp-mem-ey{background:rgba(255,255,255,.12);color:#bfdbfe}.rbp-mem h1{margin:16px 0 14px;color:#fff;font-size:clamp(38px,6vw,72px);line-height:1.02;font-weight:900}.rbp-mem h2{margin:12px 0 12px;font-size:clamp(28px,4vw,48px);line-height:1.08;font-weight:900}.rbp-mem h3{margin:0 0 8px;font-size:19px}.rbp-mem p{color:#475569;line-height:1.7}.rbp-mem-hero p{color:#cbd5e1;font-size:18px}.rbp-mem-card{border:1px solid var(--l);border-radius:18px;background:#fff;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-mem-price{background:#fff;border-radius:18px;padding:24px;color:#0f172a}.rbp-mem-price strong{display:block;font-size:34px}.rbp-mem-grid{display:grid;gap:18px}.rbp-mem-g2{grid-template-columns:repeat(2,minmax(0,1fr))}.rbp-mem-g3{grid-template-columns:repeat(3,minmax(0,1fr))}.rbp-mem-g4{grid-template-columns:repeat(4,minmax(0,1fr))}.rbp-mem-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:24px}.rbp-mem-btn{display:inline-flex;justify-content:center;align-items:center;border-radius:12px;padding:13px 16px;font-weight:900;border:1px solid rgba(15,23,42,.14);color:#334155;background:#fff}.rbp-mem-btn--primary{background:#1d4ed8;border-color:#1d4ed8;color:#fff}.rbp-mem-list{display:grid;gap:10px;margin:16px 0 0;padding:0;list-style:none}.rbp-mem-list li{display:grid;grid-template-columns:22px 1fr;gap:10px;color:#334155}.rbp-mem-list li:before{content:"";width:18px;height:18px;margin-top:3px;border-radius:999px;background:#dbeafe}.rbp-mem-pill{display:inline-flex;border-radius:999px;padding:5px 10px;background:#f1f5f9;color:#334155;font-size:12px;font-weight:900}.rbp-mem-table{width:100%;border-collapse:collapse;background:#fff;border:1px solid #e2e8f0;border-radius:18px;overflow:hidden}.rbp-mem-table th,.rbp-mem-table td{padding:14px 16px;border-bottom:1px solid #e2e8f0;text-align:left;vertical-align:top}.rbp-mem-table th{background:#f8fafc}.rbp-mem-faq{display:grid;gap:12px}.rbp-mem-faq details{border:1px solid #e2e8f0;border-radius:14px;background:#fff;padding:18px}.rbp-mem-faq summary{font-weight:900;cursor:pointer}.rbp-mem-form{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.rbp-mem-field{display:grid;gap:6px}.rbp-mem-field label{font-weight:800;font-size:13px}.rbp-mem-field input,.rbp-mem-field textarea,.rbp-mem-field select{border:1px solid #cbd5e1;border-radius:10px;padding:12px;font:inherit}.rbp-mem-field--wide{grid-column:1/-1}.rbp-mem-note{border-left:4px solid #1d4ed8;background:#eff6ff;padding:16px;border-radius:12px}.rbp-mem-cta{background:linear-gradient(135deg,#1d4ed8,#0f172a);border-radius:22px;padding:36px;color:#fff}.rbp-mem-cta h2,.rbp-mem-cta p{color:#fff}@media(max-width:900px){.rbp-mem-hero-in,.rbp-mem-g2,.rbp-mem-g3,.rbp-mem-g4,.rbp-mem-form{grid-template-columns:1fr}.rbp-mem-btn{width:100%}.rbp-mem-sec{padding:56px 0}}
</style>
<div class="rbp-mem">
<section class="rbp-mem-hero"><div class="rbp-mem-c rbp-mem-hero-in"><div><span class="rbp-mem-ey">Premium Membership</span><h1>Remote Business Partner Premium Membership</h1><p>A single application-based B2B membership model with weekly Early Bird pricing, structured business support benefits and eligibility-based NBN inclusion.</p><div class="rbp-mem-actions"><a class="rbp-mem-btn rbp-mem-btn--primary" href="/pages/sign-up-today">Apply for Premium Membership</a><a class="rbp-mem-btn" href="/pages/member-benefits">View Full Inclusions</a></div></div><aside class="rbp-mem-price"><span class="rbp-mem-ey">Early Bird</span><strong>$50 + GST/week</strong><p>Scheduled 2027 standard rate: $100 + GST/week. 24-month B2B membership agreement. Application approval required.</p></aside></div></section>
{%- if mode == 'overview' -%}
<section class="rbp-mem-sec"><div class="rbp-mem-c rbp-mem-grid rbp-mem-g3"><article class="rbp-mem-card"><span class="rbp-mem-pill">Apply</span><h3>Application first</h3><p>Submit business details and membership interest before activation or access is confirmed.</p></article><article class="rbp-mem-card"><span class="rbp-mem-pill">Qualify</span><h3>Eligibility review</h3><p>RBP reviews business fit, service address details and any included NBN eligibility requirements.</p></article><article class="rbp-mem-card"><span class="rbp-mem-pill">Activate</span><h3>Approved access</h3><p>Approved members receive activation steps, agreement details and account-based access guidance.</p></article></div></section>
<section class="rbp-mem-sec rbp-mem-muted"><div class="rbp-mem-c rbp-mem-grid rbp-mem-g2"><div><span class="rbp-mem-ey">Value stack</span><h2>One premium model, clear access rules.</h2><p>Premium Membership brings together eligible business connectivity, platform access, templates, resources, partner offers and discounted services under one commercial model.</p><ul class="rbp-mem-list"><li>Eligible NBN 1000/400 included as part of the paid bundle, subject to qualification and serviceability.</li><li>Discounts and fair usage benefits are applied only where the product or service is eligible.</li><li>Custom work, quoted services and third-party outcomes remain subject to review and scope.</li></ul></div><div class="rbp-mem-card"><h3>NBN inclusion wording</h3><p>Eligible NBN 1000/400 is included as part of the paid Remote Business Partner Premium Membership. It is not a separate free service. Availability depends on address qualification, network technology, provider approval, provisioning, equipment and serviceability. Actual speeds may vary based on network conditions, premises wiring, equipment, service configuration and other technical factors.</p></div></div></section>
{%- elsif mode == 'benefits' -%}
<section class="rbp-mem-sec"><div class="rbp-mem-c"><span class="rbp-mem-ey">Member Benefits</span><h2>Premium Membership inclusions and access rules.</h2><table class="rbp-mem-table"><thead><tr><th>Benefit area</th><th>Access rule</th></tr></thead><tbody>
{% assign benefits='Eligible NBN 1000/400|Subject to Eligibility,20% off eligible additional NBN services|Discounted,Platform access|Included,Future applications where eligible|Subject to Eligibility,Document Nucleus|Included,Templates and template revisions|Fair Usage,Documentation suites and toolkits|Included,Resources|Included,25% off eligible on-demand services|Discounted,Business Advisor access|Fair Usage,Decision Desk self-service|Fair Usage,25% off eligible Fixer services|Discounted,Fair usage discovery calls|Fair Usage,Managed services access|Quoted Separately,50% off Bid Management onboarding fee|Discounted,20% off eligible real estate services|Discounted,35% off eligible RBP products|Discounted,$100 credit per eligible finance outcome|Subject to Eligibility,$100 credit per eligible insurance policy|Subject to Eligibility,Marketplace offers|Subject to Eligibility,Help Centre support pathways|Included' | split: ',' %}
{% for item in benefits %}{% assign p=item | split:'|' %}<tr><td>{{ p[0] }}</td><td><span class="rbp-mem-pill">{{ p[1] }}</span></td></tr>{% endfor %}
</tbody></table></div></section>
{%- elsif mode == 'faq' -%}
<section class="rbp-mem-sec rbp-mem-muted"><div class="rbp-mem-c" style="max-width:920px"><span class="rbp-mem-ey">FAQ</span><h2>Premium Membership questions.</h2><div class="rbp-mem-faq">
{% assign faqs='What is Premium Membership?::A paid B2B membership that bundles structured business benefits, eligible discounts, support pathways and account-based access.|What is the Early Bird price?::$50 + GST per week, subject to application approval and the 24-month B2B agreement.|What happens in 2027?::The scheduled standard rate is $100 + GST per week from 2027 unless the approved agreement states otherwise.|Is NBN free?::No. Eligible NBN 1000/400 is included as part of the paid membership bundle and remains subject to qualification and serviceability.|Who can apply?::Australian businesses that can provide business details, contact information and service address information for review.|Is approval required?::Yes. Submitting the form is an application, not instant membership activation.|What happens after applying?::RBP reviews the application and contacts the applicant with qualification, agreement and activation steps.|What benefits are included?::Benefits include eligible connectivity, resources, templates, fair usage advisory pathways, discounts and marketplace access where eligible.|Does unlimited mean unlimited custom work?::No. Fair usage applies to defined access pathways and does not include unlimited custom delivery or out-of-scope work.|Are all products discounted?::No. Discounts apply only to eligible products or services.|What if my address cannot receive NBN 1000/400?::RBP will review available options. Membership approval and connectivity inclusion remain subject to qualification.|How do I access member resources?::Use the member portal with the account tagged for the correct lifecycle state.' | split:'|' %}
{% for item in faqs %}{% assign p=item | split:'::' %}<details {% if forloop.first %}open{% endif %}><summary>{{ p[0] }}</summary><p>{{ p[1] }}</p></details>{% endfor %}
</div></div></section>
{%- elsif mode == 'signup' -%}
<section class="rbp-mem-sec"><div class="rbp-mem-c"><span class="rbp-mem-ey">Application</span><h2>Apply for Premium Membership.</h2><p>Submitting this form records interest only. Approval, agreement steps, serviceability and activation are confirmed separately.</p>{% form 'contact', class: 'rbp-mem-form' %}<input type="hidden" name="contact[Application Type]" value="Remote Business Partner Premium Membership Application"><input type="hidden" name="contact[Membership Offer]" value="Early Bird 50% Off - $50 + GST per week"><input type="hidden" name="contact[Source Page]" value="/pages/sign-up-today"><input type="hidden" name="contact[Requested Product]" value="Remote Business Partner Premium Membership">{% assign fields='Business name,ABN/ACN,Industry,Team size,Primary contact,Email,Phone,Service address,Current internet provider,Current contract status,Interest in additional NBN services,Primary membership need' | split: ',' %}{% for field in fields %}<div class="rbp-mem-field"><label for="mem-{{ forloop.index }}">{{ field }}</label><input id="mem-{{ forloop.index }}" name="contact[{{ field }}]" {% if field == 'Email' %}type="email"{% else %}type="text"{% endif %} required></div>{% endfor %}<div class="rbp-mem-field rbp-mem-field--wide"><label for="mem-notes">Notes</label><textarea id="mem-notes" name="contact[Notes]" rows="5"></textarea></div><div class="rbp-mem-field rbp-mem-field--wide"><label><input type="checkbox" required> I confirm this is a B2B membership application, approval is required, NBN is subject to serviceability and the membership is a paid offer.</label><label><input type="checkbox" required> I consent to RBP contacting me about this application.</label></div><button class="rbp-mem-btn rbp-mem-btn--primary" type="submit">Submit application</button>{% endform %}</div></section>
{%- endif -%}
<section class="rbp-mem-sec rbp-mem-muted"><div class="rbp-mem-c"><div class="rbp-mem-cta"><h2>Ready to take the next step?</h2><p>Apply for Premium Membership or review the full inclusion list before submitting business details.</p><div class="rbp-mem-actions"><a class="rbp-mem-btn" href="/pages/sign-up-today">Apply for Premium Membership</a><a class="rbp-mem-btn" href="/pages/member-benefits">View Full Inclusions</a></div></div></div></section>
</div>
{% schema %}{"name":"RBP Membership Page","settings":[],"presets":[{"name":"RBP Membership Page"}]}{% endschema %}
