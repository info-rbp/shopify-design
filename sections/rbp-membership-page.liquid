<script>
(function() {
  // ── Inclusion tabs
  var tabs = document.querySelectorAll('.rbp-mem-tab');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = this.dataset.tab;
      tabs.forEach(function(t) {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll('.rbp-mem-tab-panel').forEach(function(p) {
        p.classList.remove('active');
      });
      this.classList.add('active');
      this.setAttribute('aria-selected', 'true');
      var panel = document.getElementById('rbp-tab-' + target);
      if (panel) panel.classList.add('active');
    });
  });

  // ── Intersection observer: animate steps on scroll
  if ('IntersectionObserver' in window) {
    var stepItems = document.querySelectorAll('.rbp-mem-step, .rbp-mem-benefit, .rbp-mem-plan');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = entry.target.classList.contains('rbp-mem-plan--featured') ? 'scale(1.02)' : 'translateY(0)';
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    stepItems.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = el.classList.contains('rbp-mem-plan--featured') ? 'scale(1.02) translateY(12px)' : 'translateY(16px)';
      el.style.transition = 'opacity .45s ease, transform .45s ease';
      io.observe(el);
    });
  }
})();
</script>

