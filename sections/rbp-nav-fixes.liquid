{% comment %}
  RBP Nav Fixes — Legacy fallback only
  
  DEPRECATED: This section is retained as a legacy fallback only.
  It is NOT actively loaded in header-group.json as of the baseline cleanup.
  
  All IA fixes have been moved to source-level:
  - Header and mobile navigation are now rendered from rbp-header.liquid
  - Membership anchors are now defined in rbp-membership-page.liquid
  - Old route normalization is handled here as a final safety net
  
  This file may be re-enabled if admin-generated links require runtime patching.
{% endcomment %}

<script>
(function() {
  // Legacy route normalization fallback
  // Only applies old route → new route mappings if they somehow appear in the DOM
  const M = {
    '/account/login': '/account',
    '/products/business-health-check': '/pages/business-health-check',
    '/pages/membership': '/pages/membership',
    '/collections/template-packs': '/collections/templates',
    '/pages/help-center': '/pages/help-centre'
  };
  
  document.querySelectorAll('a[href]').forEach(a => {
    const href = a.getAttribute('href');
    if (M[href]) {
      a.href = M[href];
    }
  });
})();
</script>

