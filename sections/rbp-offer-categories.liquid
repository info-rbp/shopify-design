<style>
.rbp-cats{--b:#1d4ed8;--bd:#1e3a8a;--bs:#dbeafe;--s9:#0f172a;--s7:#334155;--s6:#475569;--s1:#f1f5f9;--s0:#f8fafc;--br:rgba(15,23,42,.1);--br2:rgba(15,23,42,.16);--sh:0 22px 55px rgba(15,23,42,.14);background:#fff;color:var(--s9);font-family:var(--font-body-family)}.rbp-cats *{box-sizing:border-box}.rbp-cats a{text-decoration:none;color:inherit}.rbp-cats-c{width:min(100% - 3rem,1200px);margin-inline:auto}.rbp-cats-hero{overflow:hidden;color:#fff;background:radial-gradient(ellipse at top right,rgba(59,130,246,.24),transparent 58%),linear-gradient(135deg,#0f172a 0%,#172554 54%,#0f172a 100%)}.rbp-cats-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(280px,.72fr);gap:52px;align-items:center;padding:86px 0}.rbp-cats-ey{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:var(--bs);color:var(--b);font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-cats-hero .rbp-cats-ey{background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28)}.rbp-cats-dot{width:7px;height:7px;border-radius:999px;background:currentColor}.rbp-cats-h1{margin:16px 0 0;color:#fff;font-size:clamp(38px,5vw,70px);line-height:1.03;letter-spacing:-.04em;font-weight:900}.rbp-cats-h2{margin:14px 0 0;color:var(--s9);font-size:clamp(30px,4vw,48px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-cats-p{margin:16px 0 0;color:var(--s6);font-size:16px;line-height:1.75}.rbp-cats-hero .rbp-cats-p{color:#cbd5e1;font-size:18px}.rbp-cats-panel{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:28px;padding:26px;box-shadow:0 35px 75px rgba(30,64,175,.32);backdrop-filter:blur(10px)}.rbp-cats-panel h3{margin:0 0 10px;color:#fff;font-size:22px;font-weight:900}.rbp-cats-panel p{margin:0;color:#cbd5e1;line-height:1.65}.rbp-cats-sec{padding:74px 0}.rbp-cats-muted{background:var(--s0)}.rbp-cats-head{max-width:780px;margin-bottom:34px}.rbp-cats-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.rbp-cat-card{display:flex;flex-direction:column;min-height:100%;background:#fff;border:1px solid var(--br);border-radius:24px;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05);transition:transform .18s ease,box-shadow .18s ease}.rbp-cat-card:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(15,23,42,.08)}.rbp-cat-icon{width:52px;height:52px;border-radius:18px;display:grid;place-items:center;margin-bottom:18px;background:var(--bs);color:var(--b);font-weight:900}.rbp-cat-icon img{width:100%;height:100%;object-fit:cover;border-radius:18px}.rbp-cat-title{margin:0 0 8px;color:var(--s9);font-size:20px;font-weight:900}.rbp-cat-text{margin:0;color:var(--s6);line-height:1.65;font-size:14px}.rbp-cat-pill{display:inline-flex;border-radius:999px;background:var(--s1);color:var(--s7);font-size:12px;font-weight:850;padding:7px 10px;margin-top:16px}.rbp-cat-link{display:inline-flex;align-items:center;justify-content:center;border-radius:14px;padding:13px 16px;background:var(--b);color:#fff;font-size:14px;font-weight:900;margin-top:auto;align-self:flex-start}.rbp-cats-empty{border:1px dashed var(--br2);border-radius:24px;background:#fff;padding:32px;text-align:center;color:var(--s6)}.rbp-cats-empty h3{margin:0 0 8px;color:var(--s9);font-size:22px;font-weight:900}.rbp-cats-cta{overflow:hidden;border-radius:32px;background:radial-gradient(circle at top right,rgba(255,255,255,.18),transparent 35%),linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;padding:clamp(30px,5vw,56px);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:26px;align-items:center}.rbp-cats-cta h2{margin:0;color:#fff;font-size:clamp(28px,4vw,46px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-cats-cta p{margin:12px 0 0;color:#dbeafe;line-height:1.65}.rbp-cats-btn{display:inline-flex;align-items:center;justify-content:center;border-radius:14px;padding:14px 18px;background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.24);font-size:14px;font-weight:900}@media(max-width:989px){.rbp-cats-hero-in,.rbp-cats-grid,.rbp-cats-cta{grid-template-columns:1fr}}@media(max-width:749px){.rbp-cats-c{width:min(100% - 2rem,1200px)}.rbp-cats-hero-in{padding:66px 0}.rbp-cats-sec{padding:54px 0}.rbp-cats-btn,.rbp-cat-link{width:100%}}
</style>
<div class="rbp-cats"><section class="rbp-cats-hero"><div class="rbp-cats-c"><div class="rbp-cats-hero-in"><div><div class="rbp-cats-ey"><span class="rbp-cats-dot"></span>{{ section.settings.eyebrow }}</div><h1 class="rbp-cats-h1">{{ section.settings.heading }}</h1><p class="rbp-cats-p">{{ section.settings.hero_text }}</p></div><aside class="rbp-cats-panel"><h3>{{ section.settings.panel_heading }}</h3><p>{{ section.settings.panel_text }}</p></aside></div></div></section><section class="rbp-cats-sec rbp-cats-muted"><div class="rbp-cats-c"><div class="rbp-cats-head"><div class="rbp-cats-ey">{{ section.settings.list_eyebrow }}</div><h2 class="rbp-cats-h2">{{ section.settings.list_heading }}</h2><p class="rbp-cats-p">{{ section.settings.list_text }}</p></div>{% assign category_count = 0 %}<div class="rbp-cats-grid">{% for category in shop.metaobjects.offer_category.values %}{% assign category_count = category_count | plus: 1 %}{% assign slug = category.slug.value | default: category.system.handle %}{% assign icon = category.icon.value %}{% assign offer_count = 0 %}{% for offer in shop.metaobjects.partner_offer.values %}{% assign offer_category = offer.category.value %}{% if offer.status.value == 'active' and offer_category.slug.value == slug %}{% assign offer_count = offer_count | plus: 1 %}{% endif %}{% endfor %}<a class="rbp-cat-card" href="/pages/offers?category={{ slug | url_encode }}"><div class="rbp-cat-icon">{% if icon != blank %}{{ icon | image_url: width: 180 | image_tag: loading: 'lazy', alt: category.name.value }}{% else %}{{ category.name.value | slice: 0, 2 | upcase }}{% endif %}</div><h3 class="rbp-cat-title">{{ category.name.value }}</h3>{% if category.description.value != blank %}<div class="rbp-cat-text">{{ category.description | metafield_tag }}</div>{% else %}<p class="rbp-cat-text">Browse partner offers in this business category.</p>{% endif %}<span class="rbp-cat-pill">{{ offer_count }} active offer{% unless offer_count == 1 %}s{% endunless %}</span><span class="rbp-cat-link">Browse category</span></a>{% endfor %}</div>{% if category_count == 0 %}<div class="rbp-cats-empty"><h3>No offer categories yet</h3><p>Create Offer Category metaobject entries in Shopify Admin to populate this page.</p></div>{% endif %}</div></section><section class="rbp-cats-sec"><div class="rbp-cats-c"><div class="rbp-cats-cta"><div><h2>{{ section.settings.cta_heading }}</h2><p>{{ section.settings.cta_text }}</p></div><a class="rbp-cats-btn" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a></div></div></section></div>
{% schema %}{"name":"RBP offer categories","settings":[{"type":"text","id":"eyebrow","label":"Hero eyebrow","default":"Offer Categories"},{"type":"text","id":"heading","label":"Hero heading","default":"Browse partner offers by business category."},{"type":"textarea","id":"hero_text","label":"Hero text","default":"Find offers across finance, insurance, connectivity, HR, operations, technology and other practical business categories."},{"type":"text","id":"panel_heading","label":"Hero panel heading","default":"Category-powered browsing"},{"type":"textarea","id":"panel_text","label":"Hero panel text","default":"Each category is a Shopify metaobject that filters into the main offers directory."},{"type":"text","id":"list_eyebrow","label":"List eyebrow","default":"Directory"},{"type":"text","id":"list_heading","label":"List heading","default":"Offer categories"},{"type":"textarea","id":"list_text","label":"List text","default":"Choose a category to filter the main partner offers directory."},{"type":"text","id":"cta_heading","label":"CTA heading","default":"Need help finding the right offer?"},{"type":"textarea","id":"cta_text","label":"CTA text","default":"Membership gives you a clearer pathway to relevant business tools, advisory support and partner benefits."},{"type":"text","id":"cta_label","label":"CTA label","default":"View Membership Options"},{"type":"text","id":"cta_link","label":"CTA link","default":"/pages/membership"}],"presets":[{"name":"RBP offer categories"}]}{% endschema %}