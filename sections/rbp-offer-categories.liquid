<style>
  .rbp-cats{--b:#1d4ed8;--bs:#dbeafe;--s9:#0f172a;--s7:#334155;--s6:#475569;--s0:#f8fafc;--br:rgba(15,23,42,.1);--br2:rgba(15,23,42,.16);background:#fff;color:var(--s9);font-family:var(--font-body-family)}.rbp-cats *{box-sizing:border-box}.rbp-cats a{text-decoration:none;color:inherit}.rbp-cats-c{width:min(100% - 3rem,1200px);margin-inline:auto}.rbp-cats-hero{color:#fff;background:linear-gradient(135deg,#0f172a,#172554);padding:86px 0}.rbp-cats-ey{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:var(--bs);color:var(--b);font-size:12px;font-weight:900;text-transform:uppercase}.rbp-cats-hero .rbp-cats-ey{background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28)}.rbp-cats-dot{width:7px;height:7px;border-radius:999px;background:currentColor}.rbp-cats-h1{margin:16px 0 0;color:#fff;font-size:clamp(38px,5vw,70px);line-height:1.03;font-weight:900}.rbp-cats-h2{margin:14px 0 0;color:var(--s9);font-size:clamp(30px,4vw,48px);line-height:1.06;font-weight:900}.rbp-cats-p{margin:16px 0 0;color:var(--s6);font-size:16px;line-height:1.75}.rbp-cats-hero .rbp-cats-p{color:#cbd5e1;font-size:18px}.rbp-cats-panel{margin-top:30px;max-width:720px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:24px;padding:26px}.rbp-cats-panel h3{margin:0 0 10px;color:#fff;font-size:22px;font-weight:900}.rbp-cats-panel p{margin:0;color:#cbd5e1;line-height:1.65}.rbp-cats-sec{padding:74px 0}.rbp-cats-muted{background:var(--s0)}.rbp-cats-head{max-width:800px;margin-bottom:32px}.rbp-cats-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.rbp-cat-card{display:flex;flex-direction:column;gap:18px;background:#fff;border:1px solid var(--br);border-radius:24px;padding:24px;min-height:100%;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-cat-icon{width:64px;height:64px;border-radius:20px;background:linear-gradient(135deg,#0f172a,#1d4ed8);display:grid;place-items:center;color:#fff;font-size:20px;font-weight:900;overflow:hidden}.rbp-cat-icon img{width:100%;height:100%;object-fit:cover}.rbp-cat-card h3{margin:0;color:var(--s9);font-size:22px;font-weight:900}.rbp-cat-card p{margin:0;color:var(--s6);line-height:1.65}.rbp-cat-meta{margin-top:auto;color:var(--b);font-size:13px;font-weight:900}.rbp-cats-empty{border:1px dashed var(--br2);border-radius:24px;background:#fff;padding:32px;text-align:center;color:var(--s6)}.rbp-cats-empty h3{margin:0 0 8px;color:var(--s9);font-size:22px;font-weight:900}.rbp-cats-btn{display:inline-flex;align-items:center;justify-content:center;border-radius:14px;padding:14px 18px;border:1px solid transparent;background:var(--b);color:#fff;font-size:14px;font-weight:900;line-height:1}.rbp-cats-cta{overflow:hidden;border-radius:28px;background:linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;padding:clamp(30px,5vw,56px);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:26px;align-items:center}.rbp-cats-cta h2{margin:0;color:#fff;font-size:clamp(28px,4vw,46px);line-height:1.06;font-weight:900}.rbp-cats-cta p{margin:12px 0 0;color:#dbeafe;line-height:1.65}@media(max-width:989px){.rbp-cats-grid,.rbp-cats-cta{grid-template-columns:1fr}.rbp-cats-c{width:min(100% - 2rem,1200px)}}
</style>

<div class="rbp-cats">
  <section class="rbp-cats-hero"><div class="rbp-cats-c"><span class="rbp-cats-ey"><span class="rbp-cats-dot"></span>{{ section.settings.eyebrow }}</span><h1 class="rbp-cats-h1">{{ section.settings.heading }}</h1><p class="rbp-cats-p">{{ section.settings.hero_text }}</p><div class="rbp-cats-panel"><h3>{{ section.settings.panel_heading }}</h3><p>{{ section.settings.panel_text }}</p></div></div></section>
  <section class="rbp-cats-sec rbp-cats-muted"><div class="rbp-cats-c"><div class="rbp-cats-head"><span class="rbp-cats-ey"><span class="rbp-cats-dot"></span>{{ section.settings.list_eyebrow }}</span><h2 class="rbp-cats-h2">{{ section.settings.list_heading }}</h2><p class="rbp-cats-p">{{ section.settings.list_text }}</p></div>
    {% assign category_count = 0 %}
    <div class="rbp-cats-grid">
      {% for category in shop.metaobjects.offer_category.values %}
        {% assign category_count = category_count | plus: 1 %}
        {% assign category_url = category.system.url %}
        {% if category_url == blank %}{% assign category_url = '/offer-categories/' | append: category.system.handle %}{% endif %}
        {% assign icon = category.icon.value %}
        {% assign offer_count = 0 %}
        {% for offer in shop.metaobjects.partner_offer.values %}
          {% assign offer_category = offer.category.value %}
          {% assign offer_visibility = offer.visibility.value | default: '' %}
          {% if offer.status.value == 'active' and offer_visibility == 'public' and offer_category.system.handle == category.system.handle %}
            {% assign offer_count = offer_count | plus: 1 %}
          {% endif %}
        {% endfor %}
        <a class="rbp-cat-card" href="{{ category_url }}"><div class="rbp-cat-icon">{% if icon != blank %}{{ icon | image_url: width: 180 | image_tag: loading: 'lazy', alt: category.name.value }}{% else %}{{ category.name.value | slice: 0, 2 | upcase }}{% endif %}</div><div><h3>{{ category.name.value }}</h3>{% if category.description.value != blank %}<p>{{ category.description | metafield_tag }}</p>{% else %}<p>Browse public partner offers in this business category.</p>{% endif %}</div><span class="rbp-cat-meta">{{ offer_count }} public offer{% unless offer_count == 1 %}s{% endunless %} - View category</span></a>
      {% endfor %}
    </div>
    {% if category_count == 0 %}<div class="rbp-cats-empty"><h3>No offer categories yet</h3><p>Create Offer Category metaobject entries in Shopify Admin to populate this page.</p></div>{% endif %}
  </div></section>
  <section class="rbp-cats-sec"><div class="rbp-cats-c"><div class="rbp-cats-cta"><div><h2>{{ section.settings.cta_heading }}</h2><p>{{ section.settings.cta_text }}</p></div><a class="rbp-cats-btn" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a></div></div></section>
</div>

{% schema %}
{"name":"RBP offer categories","settings":[{"type":"text","id":"eyebrow","label":"Hero eyebrow","default":"Partner Offers"},{"type":"text","id":"heading","label":"Hero heading","default":"Browse partner offers by category."},{"type":"textarea","id":"hero_text","label":"Hero text","default":"Explore practical partner offers across business finance, technology, operations, connectivity, insurance and other useful service categories."},{"type":"text","id":"panel_heading","label":"Hero panel heading","default":"Start with a category"},{"type":"textarea","id":"panel_text","label":"Hero panel text","default":"Choose a category to view relevant offers, compare options and open each offer on its own detail page."},{"type":"text","id":"list_eyebrow","label":"List eyebrow","default":"Offer categories"},{"type":"text","id":"list_heading","label":"List heading","default":"Find offers by business need"},{"type":"textarea","id":"list_text","label":"List text","default":"Select a category to see the available partner offers in that area."},{"type":"text","id":"cta_heading","label":"CTA heading","default":"Explore practical business offers"},{"type":"textarea","id":"cta_text","label":"CTA text","default":"Each offer is reviewed, organised by category and redeemable through a direct partner link."},{"type":"text","id":"cta_label","label":"CTA label","default":"Browse categories"},{"type":"text","id":"cta_link","label":"CTA link","default":"/pages/offers"}],"presets":[{"name":"RBP offer categories"}]}
{% endschema %}
