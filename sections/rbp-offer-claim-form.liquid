<style>.rbp-claim{--b:#1d4ed8;--bd:#1e3a8a;--s9:#0f172a;--s7:#334155;--s6:#475569;--s0:#f8fafc;--br:rgba(15,23,42,.1);font-family:var(--font-body-family);background:#fff;color:var(--s9)}.rbp-claim *{box-sizing:border-box}.rbp-claim-c{width:min(100% - 2rem,900px);margin-inline:auto}.rbp-claim-hero{background:radial-gradient(circle at top right,rgba(59,130,246,.22),transparent 40%),linear-gradient(135deg,#0f172a,#172554);color:#fff;padding:84px 0}.rbp-claim-h1{margin:0;font-size:clamp(38px,5vw,64px);line-height:1.02;font-weight:900;letter-spacing:-.04em}.rbp-claim-p{margin:18px 0 0;color:#cbd5e1;line-height:1.75;font-size:18px}.rbp-claim-sec{padding:70px 0;background:var(--s0)}.rbp-claim-card{background:#fff;border:1px solid var(--br);border-radius:28px;padding:32px;box-shadow:0 12px 30px rgba(15,23,42,.08)}.rbp-claim-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}.rbp-claim-field{display:flex;flex-direction:column;gap:8px}.rbp-claim-field-full{grid-column:1/-1}.rbp-claim label{font-size:14px;font-weight:800;color:var(--s7)}.rbp-claim input,.rbp-claim textarea{width:100%;border:1px solid rgba(15,23,42,.16);border-radius:14px;padding:14px 16px;font-size:15px;color:var(--s9);background:#fff}.rbp-claim textarea{min-height:140px;resize:vertical}.rbp-claim-btn{display:inline-flex;align-items:center;justify-content:center;border:none;border-radius:16px;padding:16px 22px;background:var(--b);color:#fff;font-size:15px;font-weight:900;cursor:pointer}.rbp-claim-note{margin-top:18px;color:var(--s6);font-size:14px;line-height:1.7}@media(max-width:749px){.rbp-claim-grid{grid-template-columns:1fr}}</style><div class="rbp-claim"><section class="rbp-claim-hero"><div class="rbp-claim-c"><h1 class="rbp-claim-h1">Claim a partner offer</h1><p class="rbp-claim-p">Submit your details and the Remote Business Partner team will connect you with the relevant offer or provider.</p></div></section><section class="rbp-claim-sec"><div class="rbp-claim-c"><div class="rbp-claim-card">{% form 'contact' %}<div class="rbp-claim-grid"><div class="rbp-claim-field"><label>First name</label><input type="text" name="contact[first_name]" required></div><div class="rbp-claim-field"><label>Last name</label><input type="text" name="contact[last_name]" required></div><div class="rbp-claim-field"><label>Email</label><input type="email" name="contact[email]" required></div><div class="rbp-claim-field"><label>Phone</label><input type="tel" name="contact[phone]"></div><div class="rbp-claim-field rbp-claim-field-full"><label>Offer</label><input type="text" name="contact[offer]" value="{{ request.params.offer | escape }}" readonly></div><div class="rbp-claim-field rbp-claim-field-full"><label>Business details</label><textarea name="contact[body]" placeholder="Tell us about your business and what you are looking for."></textarea></div><div class="rbp-claim-field rbp-claim-field-full"><button class="rbp-claim-btn" type="submit">Submit claim request</button></div></div>{% if form.posted_successfully? %}<p class="rbp-claim-note">Your claim request has been submitted successfully.</p>{% endif %}{% if form.errors %}<div class="rbp-claim-note">Please complete the required fields correctly.</div>{% endif %}{% endform %}<p class="rbp-claim-note">Claim requests are submitted through Shopify contact handling and can later be expanded into a fully tracked offer-claim workflow.</p></div></div></section></div>{% schema %}{"name":"RBP offer claim form","settings":[],"presets":[{"name":"RBP offer claim form"}]}{% endschema %}