<style>
  .rbp-offer-detail{--b:#1d4ed8;--bd:#1e3a8a;--bs:#dbeafe;--s9:#0f172a;--s7:#334155;--s6:#475569;--s5:#64748b;--s1:#f1f5f9;--s0:#f8fafc;--br:rgba(15,23,42,.1);--br2:rgba(15,23,42,.16);font-family:var(--font-body-family);background:#fff;color:var(--s9)}.rbp-offer-detail *{box-sizing:border-box}.rbp-offer-detail a{text-decoration:none}.rbp-od-c{width:min(100% - 3rem,1180px);margin-inline:auto}.rbp-od-hero{color:#fff;background:linear-gradient(135deg,#0f172a,#172554);padding:84px 0}.rbp-od-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(280px,.56fr);gap:48px;align-items:center}.rbp-od-ey{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28);font-size:12px;font-weight:900;text-transform:uppercase}.rbp-od-dot{width:7px;height:7px;border-radius:999px;background:currentColor}.rbp-od-h1{margin:16px 0 0;color:#fff;font-size:clamp(38px,5vw,68px);line-height:1.03;font-weight:900}.rbp-od-p{margin:16px 0 0;color:#cbd5e1;font-size:18px;line-height:1.75}.rbp-od-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:28px}.rbp-od-btn{display:inline-flex;align-items:center;justify-content:center;border-radius:14px;padding:15px 19px;font-size:14px;font-weight:900;line-height:1}.rbp-od-btn-p{background:var(--b);color:#fff;box-shadow:0 18px 36px rgba(29,78,216,.24)}.rbp-od-btn-g{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.24)}.rbp-od-panel{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:24px;padding:24px}.rbp-od-img{overflow:hidden;border-radius:22px;background:linear-gradient(135deg,#0f172a,#1d4ed8);min-height:240px;display:grid;place-items:center;color:#fff;font-size:38px;font-weight:900}.rbp-od-img img{width:100%;height:300px;object-fit:cover;display:block}.rbp-od-meta{display:flex;flex-wrap:wrap;gap:8px;margin-top:18px}.rbp-od-pill{border-radius:999px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);color:#dbeafe;padding:8px 11px;font-size:12px;font-weight:850}.rbp-od-sec{padding:70px 0}.rbp-od-muted{background:var(--s0)}.rbp-od-grid{display:grid;grid-template-columns:minmax(0,1fr) 340px;gap:28px;align-items:start}.rbp-od-card{background:#fff;border:1px solid var(--br);border-radius:24px;padding:28px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-od-card h2{margin:0 0 14px;color:var(--s9);font-size:30px;line-height:1.1;font-weight:900}.rbp-od-card h3{margin:0 0 12px;color:var(--s9);font-size:20px;font-weight:900}.rbp-od-rich,.rbp-od-rich p{color:var(--s6);line-height:1.75;font-size:15px}.rbp-od-rich p:first-child{margin-top:0}.rbp-od-side{display:grid;gap:16px}.rbp-od-code{border-radius:18px;background:#fef3c7;color:#92400e;padding:16px;font-weight:900;text-align:center;margin-bottom:16px}.rbp-od-side .rbp-od-btn{width:100%;background:var(--b);color:#fff}.rbp-od-unavailable{border-radius:18px;background:#f1f5f9;color:#475569;padding:16px;font-weight:850;line-height:1.6}.rbp-od-disclosure{font-size:13px;color:var(--s5);line-height:1.65}.rbp-od-back{display:inline-flex;margin-top:18px;color:var(--b);font-weight:900}@media(max-width:989px){.rbp-od-hero-in,.rbp-od-grid{grid-template-columns:1fr}}@media(max-width:749px){.rbp-od-c{width:min(100% - 2rem,1180px)}.rbp-od-hero{padding:64px 0}.rbp-od-sec{padding:52px 0}.rbp-od-btn{width:100%}}
</style>

{% assign offer = metaobject %}
{% assign status = offer.status.value | default: '' %}
{% assign visibility = offer.visibility.value | default: '' %}
{% assign partner = offer.partner.value %}
{% assign category = offer.category.value %}
{% assign partner_name = partner.name.value | default: '' %}
{% assign category_name = category.name.value | default: 'Partner offer' %}
{% assign hero_image = offer.hero_image.value %}
{% assign cta_url = offer.cta_url.value %}
{% assign button_label = offer.cta_label.value | default: 'Redeem Offer' %}
{% assign is_external = false %}
{% if cta_url contains 'http://' or cta_url contains 'https://' %}{% assign is_external = true %}{% endif %}
{% assign is_public_offer = false %}
{% if status == 'active' and visibility == 'public' %}{% assign is_public_offer = true %}{% endif %}
{% assign seo_title = offer.seo_title.value | default: offer.title.value %}
{% assign seo_desc = offer.seo_description.value | default: offer.short_description.value | strip_html | escape %}

<div class="rbp-offer-detail"><section class="rbp-od-hero"><div class="rbp-od-c"><div class="rbp-od-hero-in"><div><div class="rbp-od-ey"><span class="rbp-od-dot"></span>{{ category_name }}</div><h1 class="rbp-od-h1">{{ offer.title.value }}</h1>{% if offer.short_description.value != blank %}<p class="rbp-od-p">{{ offer.short_description.value }}</p>{% endif %}<div class="rbp-od-actions">{% if is_public_offer and cta_url != blank %}<a class="rbp-od-btn rbp-od-btn-p" href="{{ cta_url }}"{% if is_external %} target="_blank" rel="noopener sponsored"{% endif %}>{{ button_label }}</a>{% endif %}<a class="rbp-od-btn rbp-od-btn-g" href="/pages/offers">Back to categories</a></div></div><aside class="rbp-od-panel"><div class="rbp-od-img">{% if hero_image != blank %}{{ hero_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: offer.title.value }}{% else %}{{ offer.title.value | slice: 0, 2 | upcase }}{% endif %}</div><div class="rbp-od-meta">{% if partner_name != blank %}<span class="rbp-od-pill">{{ partner_name }}</span>{% endif %}<span class="rbp-od-pill">{{ category_name }}</span>{% if offer.is_top_offer.value == true or offer.is_top_offer.value == 'true' %}<span class="rbp-od-pill">Top offer</span>{% endif %}{% if offer.is_exclusive_offer.value == true or offer.is_exclusive_offer.value == 'true' %}<span class="rbp-od-pill">Exclusive</span>{% endif %}{% if offer.is_limited_time_offer.value == true or offer.is_limited_time_offer.value == 'true' %}<span class="rbp-od-pill">Limited time</span>{% endif %}</div></aside></div></div></section><section class="rbp-od-sec rbp-od-muted"><div class="rbp-od-c"><div class="rbp-od-grid"><main class="rbp-od-card"><h2>Offer details</h2>{% if offer.full_description.value != blank %}<div class="rbp-od-rich">{{ offer.full_description | metafield_tag }}</div>{% elsif offer.short_description.value != blank %}<div class="rbp-od-rich"><p>{{ offer.short_description.value }}</p></div>{% else %}<div class="rbp-od-rich"><p>Details for this partner offer will be added soon.</p></div>{% endif %}{% if offer.terms.value != blank %}<hr style="border:0;border-top:1px solid rgba(15,23,42,.1);margin:26px 0"><h3>Terms</h3><div class="rbp-od-rich">{{ offer.terms | metafield_tag }}</div>{% endif %}<a class="rbp-od-back" href="/pages/offers">Browse all categories</a></main><aside class="rbp-od-side"><div class="rbp-od-card"><h3>Redeem this offer</h3>{% if offer.offer_code.value != blank %}<div class="rbp-od-code">Code: {{ offer.offer_code.value }}</div>{% endif %}{% if is_public_offer and cta_url != blank %}<p class="rbp-od-rich">Use the button below to continue to the partner website.</p><a class="rbp-od-btn" href="{{ cta_url }}"{% if is_external %} target="_blank" rel="noopener sponsored"{% endif %}>{{ button_label }}</a>{% else %}<div class="rbp-od-unavailable">This offer is not currently available.</div>{% endif %}</div>{% if offer.partner_disclosure.value != blank %}<div class="rbp-od-card"><h3>Disclosure</h3><p class="rbp-od-disclosure">{{ offer.partner_disclosure.value }}</p></div>{% endif %}</aside></div></div></section><script type="application/ld+json">{"@context":"https://schema.org","@type":"Offer","name":{{ seo_title | json }},"description":{{ seo_desc | json }},"url":{{ request.origin | append: request.path | json }},{% if partner_name != blank %}"seller":{"@type":"Organization","name":{{ partner_name | json }}},{% endif %}"category":{{ category_name | json }}}</script></div>
{% schema %}{"name":"RBP offer detail","settings":[],"presets":[{"name":"RBP offer detail"}]}{% endschema %}
