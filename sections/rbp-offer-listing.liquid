<style>
.rbp-offers{--b:#1d4ed8;--bd:#1e3a8a;--bs:#dbeafe;--s9:#0f172a;--s7:#334155;--s6:#475569;--s1:#f1f5f9;--s0:#f8fafc;--br:rgba(15,23,42,.1);--br2:rgba(15,23,42,.16);--sh:0 22px 55px rgba(15,23,42,.14);background:#fff;color:var(--s9);font-family:var(--font-body-family)}.rbp-offers *{box-sizing:border-box}.rbp-offers a{text-decoration:none;color:inherit}.rbp-offers-c{width:min(100% - 3rem,1200px);margin-inline:auto}.rbp-offers-hero{overflow:hidden;color:#fff;background:radial-gradient(ellipse at top right,rgba(59,130,246,.24),transparent 58%),linear-gradient(135deg,#0f172a 0%,#172554 54%,#0f172a 100%)}.rbp-offers-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(280px,.72fr);gap:52px;align-items:center;padding:86px 0}.rbp-offers-ey{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:var(--bs);color:var(--b);font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-offers-hero .rbp-offers-ey{background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28)}.rbp-offers-dot{width:7px;height:7px;border-radius:999px;background:currentColor}.rbp-offers-h1{margin:16px 0 0;color:#fff;font-size:clamp(38px,5vw,70px);line-height:1.03;letter-spacing:-.04em;font-weight:900}.rbp-offers-h2{margin:14px 0 0;color:var(--s9);font-size:clamp(30px,4vw,48px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-offers-p{margin:16px 0 0;color:var(--s6);font-size:16px;line-height:1.75}.rbp-offers-hero .rbp-offers-p{color:#cbd5e1;font-size:18px}.rbp-offers-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:28px}.rbp-offers-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:14px;padding:14px 18px;border:1px solid transparent;font-size:14px;font-weight:900;line-height:1}.rbp-offers-btn-p{background:var(--b);color:#fff;box-shadow:0 18px 36px rgba(29,78,216,.24)}.rbp-offers-btn-g{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.24)}.rbp-offers-btn-o{background:#fff;color:var(--s7);border-color:var(--br2)}.rbp-offers-panel{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:28px;padding:26px;box-shadow:0 35px 75px rgba(30,64,175,.32);backdrop-filter:blur(10px)}.rbp-offers-panel h3{margin:0 0 10px;color:#fff;font-size:22px;font-weight:900}.rbp-offers-panel p{margin:0;color:#cbd5e1;line-height:1.65}.rbp-offers-sec{padding:74px 0}.rbp-offers-muted{background:var(--s0)}.rbp-offers-head{max-width:800px;margin-bottom:32px}.rbp-offers-toolbar{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:14px;margin:28px 0 22px}.rbp-offers-search{width:100%;border:1px solid var(--br2);border-radius:16px;background:#fff;color:var(--s9);padding:15px 16px;font-size:15px}.rbp-offers-filter-row{display:flex;flex-wrap:wrap;gap:8px}.rbp-offers-filter{border:1px solid var(--br);background:#fff;color:var(--s7);border-radius:999px;padding:9px 12px;font-size:12px;font-weight:900;cursor:pointer}.rbp-offers-filter.is-active{background:var(--b);border-color:var(--b);color:#fff}.rbp-offers-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.rbp-offer-card{overflow:hidden;display:flex;flex-direction:column;min-height:100%;background:#fff;border:1px solid var(--br);border-radius:24px;box-shadow:0 1px 2px rgba(15,23,42,.05);transition:transform .18s ease,box-shadow .18s ease}.rbp-offer-card:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(15,23,42,.08)}.rbp-offer-media{min-height:178px;background:radial-gradient(circle at top right,rgba(96,165,250,.4),transparent 35%),linear-gradient(135deg,#0f172a,#1d4ed8);display:grid;place-items:center;color:#fff;position:relative}.rbp-offer-mark{width:74px;height:74px;border-radius:24px;display:grid;place-items:center;background:rgba(255,255,255,.13);border:1px solid rgba(255,255,255,.18);font-size:24px;font-weight:900}.rbp-offer-badges{position:absolute;left:14px;top:14px;display:flex;flex-wrap:wrap;gap:7px}.rbp-offer-badge{border-radius:999px;background:rgba(255,255,255,.92);color:var(--b);padding:6px 9px;font-size:11px;font-weight:900;line-height:1}.rbp-offer-body{padding:24px;display:flex;flex-direction:column;flex:1}.rbp-offer-meta{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px}.rbp-offer-pill{border-radius:999px;background:var(--s1);color:var(--s7);padding:7px 10px;font-size:12px;font-weight:850}.rbp-offer-pill-blue{background:var(--bs);color:var(--b)}.rbp-offer-title{margin:0;color:var(--s9);font-size:20px;font-weight:900;line-height:1.2}.rbp-offer-text{margin:12px 0 0;color:var(--s6);line-height:1.65;font-size:14px}.rbp-offer-footer{display:flex;flex-wrap:wrap;gap:10px;align-items:center;justify-content:space-between;margin-top:auto;padding-top:22px}.rbp-offer-code{border-radius:999px;background:#fef3c7;color:#92400e;padding:7px 10px;font-size:12px;font-weight:900}.rbp-offer-card.is-locked .rbp-offer-media:after{content:'Member access';position:absolute;right:14px;bottom:14px;border-radius:999px;background:rgba(15,23,42,.84);color:#fff;padding:7px 10px;font-size:11px;font-weight:900}.rbp-offers-empty{border:1px dashed var(--br2);border-radius:24px;background:#fff;padding:32px;text-align:center;color:var(--s6)}.rbp-offers-empty h3{margin:0 0 8px;color:var(--s9);font-size:22px;font-weight:900}.rbp-offers-cta{overflow:hidden;border-radius:32px;background:radial-gradient(circle at top right,rgba(255,255,255,.18),transparent 35%),linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;padding:clamp(30px,5vw,56px);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:26px;align-items:center}.rbp-offers-cta h2{margin:0;color:#fff;font-size:clamp(28px,4vw,46px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-offers-cta p{margin:12px 0 0;color:#dbeafe;line-height:1.65}.rbp-offers-hide{display:none!important}@media(max-width:989px){.rbp-offers-hero-in,.rbp-offers-grid,.rbp-offers-cta{grid-template-columns:1fr}.rbp-offers-toolbar{grid-template-columns:1fr}}@media(max-width:749px){.rbp-offers-c{width:min(100% - 2rem,1200px)}.rbp-offers-hero-in{padding:66px 0}.rbp-offers-sec{padding:54px 0}.rbp-offers-btn{width:100%}}
</style>
{% assign filter_mode = section.settings.filter_mode | default: 'all' %}{% assign today_seconds = 'now' | date: '%s' | plus: 0 %}{% assign rendered_count = 0 %}
<div class="rbp-offers" data-rbp-offers><section class="rbp-offers-hero"><div class="rbp-offers-c"><div class="rbp-offers-hero-in"><div><div class="rbp-offers-ey"><span class="rbp-offers-dot"></span>{{ section.settings.eyebrow }}</div><h1 class="rbp-offers-h1">{{ section.settings.heading }}</h1><p class="rbp-offers-p">{{ section.settings.hero_text }}</p><div class="rbp-offers-actions"><a class="rbp-offers-btn rbp-offers-btn-p" href="{{ section.settings.primary_cta_link }}">{{ section.settings.primary_cta_label }}</a><a class="rbp-offers-btn rbp-offers-btn-g" href="{{ section.settings.secondary_cta_link }}">{{ section.settings.secondary_cta_label }}</a></div></div><aside class="rbp-offers-panel"><h3>{{ section.settings.panel_heading }}</h3><p>{{ section.settings.panel_text }}</p></aside></div></div></section><section class="rbp-offers-sec rbp-offers-muted"><div class="rbp-offers-c"><div class="rbp-offers-head"><div class="rbp-offers-ey">{{ section.settings.list_eyebrow }}</div><h2 class="rbp-offers-h2">{{ section.settings.list_heading }}</h2><p class="rbp-offers-p">{{ section.settings.list_text }}</p></div>{% if section.settings.show_search %}<div class="rbp-offers-toolbar"><input class="rbp-offers-search" type="search" placeholder="Search offers, partners or categories" data-offer-search><div class="rbp-offers-filter-row"><button class="rbp-offers-filter is-active" type="button" data-category-filter="all">All</button>{% for category in shop.metaobjects.offer_category.values %}{% assign category_slug = category.slug.value | default: category.system.handle %}<button class="rbp-offers-filter" type="button" data-category-filter="{{ category_slug | escape }}">{{ category.name.value }}</button>{% endfor %}</div></div>{% endif %}<div class="rbp-offers-grid" data-offer-grid>{% for offer in shop.metaobjects.partner_offer.values %}{% assign status = offer.status.value | default: '' %}{% assign include_offer = false %}{% assign is_top = offer.is_top_offer.value %}{% assign is_exclusive = offer.is_exclusive_offer.value %}{% assign is_limited = offer.is_limited_time_offer.value %}{% assign start_seconds = 0 %}{% assign end_seconds = 9999999999 %}{% if offer.start_date.value != blank %}{% assign start_seconds = offer.start_date.value | date: '%s' | plus: 0 %}{% endif %}{% if offer.end_date.value != blank %}{% assign end_seconds = offer.end_date.value | date: '%s' | plus: 0 %}{% endif %}{% if status == 'active' %}{% case filter_mode %}{% when 'exclusive' %}{% if is_exclusive == true or is_exclusive == 'true' %}{% assign include_offer = true %}{% endif %}{% when 'top' %}{% if is_top == true or is_top == 'true' %}{% assign include_offer = true %}{% endif %}{% when 'limited_time' %}{% if is_limited == true or is_limited == 'true' %}{% if start_seconds <= today_seconds and end_seconds >= today_seconds %}{% assign include_offer = true %}{% endif %}{% endif %}{% else %}{% assign include_offer = true %}{% endcase %}{% endif %}{% if include_offer %}{% assign rendered_count = rendered_count | plus: 1 %}{% render 'rbp-offer-card', offer: offer %}{% endif %}{% endfor %}</div><div class="rbp-offers-empty {% if rendered_count > 0 %}rbp-offers-hide{% endif %}" data-offer-empty><h3>{{ section.settings.empty_heading }}</h3><p>{{ section.settings.empty_text }}</p><div class="rbp-offers-actions" style="justify-content:center"><a class="rbp-offers-btn rbp-offers-btn-p" href="{{ section.settings.empty_cta_link }}">{{ section.settings.empty_cta_label }}</a></div></div></div></section><section class="rbp-offers-sec"><div class="rbp-offers-c"><div class="rbp-offers-cta"><div><h2>{{ section.settings.cta_heading }}</h2><p>{{ section.settings.cta_text }}</p></div><a class="rbp-offers-btn rbp-offers-btn-g" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a></div></div></section></div><script>(()=>{const root=document.currentScript.closest('[data-rbp-offers]');if(!root)return;const input=root.querySelector('[data-offer-search]');const buttons=[...root.querySelectorAll('[data-category-filter]')];const cards=[...root.querySelectorAll('[data-rbp-offer]')];const empty=root.querySelector('[data-offer-empty]');const params=new URLSearchParams(window.location.search);let active=params.get('category')||'all';const norm=v=>(v||'').toString().trim().toLowerCase();function apply(){const q=norm(input?input.value:'');let count=0;cards.forEach(card=>{const okCat=active==='all'||card.dataset.category===active;const okSearch=!q||norm(card.dataset.search).includes(q);const show=okCat&&okSearch;card.classList.toggle('rbp-offers-hide',!show);if(show)count++;});if(empty)empty.classList.toggle('rbp-offers-hide',count>0)}function activeBtn(){buttons.forEach(b=>b.classList.toggle('is-active',b.dataset.categoryFilter===active))}if(!buttons.some(b=>b.dataset.categoryFilter===active))active='all';buttons.forEach(b=>b.addEventListener('click',()=>{active=b.dataset.categoryFilter||'all';activeBtn();apply()}));if(input)input.addEventListener('input',apply);activeBtn();apply();})();</script>{% schema %}{"name":"RBP offer listing","settings":[{"type":"select","id":"filter_mode","label":"Offer filter","default":"all","options":[{"value":"all","label":"All active offers"},{"value":"exclusive","label":"Exclusive offers"},{"value":"top","label":"Top offers"},{"value":"limited_time","label":"Limited-time offers"}]},{"type":"checkbox","id":"show_search","label":"Show search and category filters","default":true},{"type":"text","id":"eyebrow","label":"Hero eyebrow","default":"Partner Offers"},{"type":"text","id":"heading","label":"Hero heading","default":"Business offers built for practical savings."},{"type":"textarea","id":"hero_text","label":"Hero text","default":"Browse curated partner offers, exclusive member benefits, and practical business deals from the Remote Business Partner network."},{"type":"text","id":"primary_cta_label","label":"Primary CTA label","default":"Browse Offers"},{"type":"text","id":"primary_cta_link","label":"Primary CTA link","default":"/pages/offers"},{"type":"text","id":"secondary_cta_label","label":"Secondary CTA label","default":"View Membership"},{"type":"text","id":"secondary_cta_link","label":"Secondary CTA link","default":"/pages/membership-options"},{"type":"text","id":"panel_heading","label":"Hero panel heading","default":"Structured partner benefits"},{"type":"textarea","id":"panel_text","label":"Hero panel text","default":"Offers are managed as Shopify metaobjects so they can be filtered, featured, locked for members and reused across the storefront."},{"type":"text","id":"list_eyebrow","label":"List eyebrow","default":"Offer directory"},{"type":"text","id":"list_heading","label":"List heading","default":"Explore active partner offers"},{"type":"textarea","id":"list_text","label":"List text","default":"Use search and category filters to find offers relevant to your business."},{"type":"text","id":"empty_heading","label":"Empty heading","default":"No matching offers yet"},{"type":"textarea","id":"empty_text","label":"Empty text","default":"The structure is ready. Add Partner Offer metaobject entries in Shopify Admin to populate this page."},{"type":"text","id":"empty_cta_label","label":"Empty CTA label","default":"View Membership Options"},{"type":"text","id":"empty_cta_link","label":"Empty CTA link","default":"/pages/membership-options"},{"type":"text","id":"cta_heading","label":"CTA heading","default":"Want access to member-only offers?"},{"type":"textarea","id":"cta_text","label":"CTA text","default":"Membership unlocks exclusive offers, resources, advisory support, tools and practical small-business pathways."},{"type":"text","id":"cta_label","label":"CTA label","default":"Compare Membership Options"},{"type":"text","id":"cta_link","label":"CTA link","default":"/pages/membership-options"}],"presets":[{"name":"RBP offer listing"}]}{% endschema %}