<script>
(function() {
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('rbp-off-anim--in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -32px 0px' });
    document.querySelectorAll('.rbp-off-anim').forEach(function(el) { io.observe(el); });
  } else {
    document.querySelectorAll('.rbp-off-anim').forEach(function(el) {
      el.classList.add('rbp-off-anim--in');
    });
  }
})();
</script>

