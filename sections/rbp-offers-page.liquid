<style>
/* ─── RBP Offers Tokens (inherit from marketplace palette) ────────── */
.rbp-offers {
  --off-navy:      #0f172a;
  --off-purple:    #7c3aed;
  --off-purple-pale:#ede9fe;
  --off-teal:      #0d9488;
  --off-teal-pale: #ccfbf1;
  --off-amber:     #d97706;
  --off-amber-pale:#fef3c7;
  --off-green:     #059669;
  --off-green-pale:#d1fae5;
  --off-blue:      #1d4ed8;
  --off-blue-pale: #dbeafe;
  --off-slate-9:   #0f172a;
  --off-slate-7:   #334155;
  --off-slate-6:   #475569;
  --off-slate-4:   #94a3b8;
  --off-slate-2:   #e2e8f0;
  --off-slate-1:   #f1f5f9;
  --off-slate-0:   #f8fafc;
  --off-white:     #ffffff;
  --off-radius:    16px;
  --off-radius-lg: 24px;
  --off-shadow:    0 4px 24px rgba(15,23,42,.10);
  --off-shadow-lg: 0 16px 56px rgba(15,23,42,.14);
  background: var(--off-white); color: var(--off-slate-9);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}
.rbp-offers *, .rbp-offers *::before, .rbp-offers *::after { box-sizing: border-box; margin: 0; }
.rbp-offers a { text-decoration: none; color: inherit; }
.rbp-offers ul { list-style: none; padding: 0; }
.rbp-offers-c { width: min(100% - 2.5rem, 1260px); margin-inline: auto; }
.rbp-offers-sec { padding: 88px 0; }
.rbp-offers-sec-sm { padding: 56px 0; }
.rbp-offers-muted { background: var(--off-slate-0); }

/* ─── Eyebrow ────────────────────────────────────────────────────── */
.rbp-offers-eye {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; border-radius: 999px;
  font-size: 11px; font-weight: 800; letter-spacing: .10em; text-transform: uppercase;
  background: var(--off-amber-pale); color: var(--off-amber);
}
.rbp-offers-eye--white { background: rgba(255,255,255,.14); color: rgba(255,255,255,.9); border: 1px solid rgba(255,255,255,.22); }
.rbp-offers-eye--purple { background: var(--off-purple-pale); color: var(--off-purple); }
.rbp-offers-eye-dot { width: 6px; height: 6px; border-radius: 999px; background: currentColor; animation: off-blink 2s infinite; }
@keyframes off-blink { 0%,100%{opacity:1} 50%{opacity:.3} }

/* ─── Headings ───────────────────────────────────────────────────── */
.rbp-offers-h1 { font-size: clamp(38px,5.5vw,72px); font-weight: 900; line-height: 1.0; letter-spacing: -.045em; color: var(--off-white); }
.rbp-offers-h2 { font-size: clamp(26px,4vw,48px); font-weight: 900; line-height: 1.06; letter-spacing: -.035em; }
.rbp-offers-p  { font-size: 16px; line-height: 1.75; color: var(--off-slate-6); }
.rbp-offers-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
.rbp-offers-head .rbp-offers-eye { margin-bottom: 16px; }
.rbp-offers-head .rbp-offers-h2  { margin: 12px 0 16px; }

/* ─── Hero ───────────────────────────────────────────────────────── */
.rbp-offers-hero {
  background:
    radial-gradient(ellipse 70% 60% at 80% 30%, rgba(245,158,11,.18), transparent 55%),
    radial-gradient(ellipse 50% 60% at 15% 75%, rgba(124,58,237,.14), transparent 55%),
    linear-gradient(145deg, #0f172a 0%, #1c1404 55%, #0f172a 100%);
  overflow: hidden; position: relative;
}
.rbp-offers-hero-in {
  padding: 88px 0 72px;
  display: grid; grid-template-columns: minmax(0,1fr) minmax(320px,.75fr);
  gap: 60px; align-items: center; min-height: 520px;
}
.rbp-offers-hero-text .rbp-offers-eye { margin-bottom: 20px; }
.rbp-offers-hero-text .rbp-offers-h1 { margin-bottom: 18px; }
.rbp-offers-hero-text .rbp-offers-p  { color: #94a3b8; font-size: 17px; max-width: 540px; margin-bottom: 28px; }
.rbp-offers-hero-proof { display: flex; flex-wrap: wrap; gap: 8px 20px; margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,.1); }
.rbp-offers-hero-proof span { font-size: 13px; color: #64748b; font-weight: 600; display: flex; align-items: center; gap: 7px; }

/* ─── Hero info card ─────────────────────────────────────────────── */
.rbp-offers-hero-card {
  background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.14);
  backdrop-filter: blur(20px); border-radius: var(--off-radius-lg);
  padding: 36px 30px; position: relative; overflow: hidden;
}
.rbp-offers-hero-card::before { content: ''; position: absolute; top:0;left:0;right:0;height:3px; background: linear-gradient(90deg,#f59e0b,#7c3aed); }
.rbp-offers-hero-card h3 { color: var(--off-white); font-size: 18px; font-weight: 800; margin-bottom: 10px; }
.rbp-offers-hero-card p  { color: #94a3b8; font-size: 14px; line-height: 1.7; }
.rbp-offers-stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px; }
.rbp-offers-stat { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: var(--off-radius); padding: 16px; text-align: center; }
.rbp-offers-stat-num { font-size: 24px; font-weight: 900; color: var(--off-white); }
.rbp-offers-stat-label { font-size: 11px; color: #64748b; margin-top: 3px; }

/* ─── Buttons ────────────────────────────────────────────────────── */
.rbp-offers-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 13px 22px; border-radius: 12px; border: none;
  font-size: 14px; font-weight: 800; cursor: pointer; line-height: 1;
  transition: all .2s ease; text-decoration: none; white-space: nowrap;
}
.rbp-offers-btn--amber  { background: linear-gradient(135deg,#f59e0b,#d97706); color: var(--off-white); box-shadow: 0 8px 24px rgba(245,158,11,.28); }
.rbp-offers-btn--amber:hover  { transform: translateY(-1px); box-shadow: 0 12px 32px rgba(245,158,11,.36); }
.rbp-offers-btn--purple { background: var(--off-purple); color: var(--off-white); box-shadow: 0 8px 24px rgba(124,58,237,.24); }
.rbp-offers-btn--purple:hover { background: #6d28d9; transform: translateY(-1px); }
.rbp-offers-btn--ghost  { background: transparent; color: var(--off-slate-7); border: 1.5px solid var(--off-slate-2); }
.rbp-offers-btn--ghost:hover  { border-color: var(--off-purple); color: var(--off-purple); }
.rbp-offers-btn--white  { background: var(--off-white); color: var(--off-amber); }
.rbp-offers-btn--white:hover  { background: var(--off-amber-pale); }
.rbp-offers-btn--sm { padding: 9px 16px; font-size: 13px; }
.rbp-offers-actions { display: flex; flex-wrap: wrap; gap: 12px; }

/* ─── Offer detail cards ─────────────────────────────────────────── */
.rbp-offers-list { display: flex; flex-direction: column; gap: 24px; }
.rbp-offer-card {
  background: var(--off-white); border: 1.5px solid var(--off-slate-2);
  border-radius: var(--off-radius-lg); overflow: hidden;
  display: grid; grid-template-columns: 220px 1fr auto;
  transition: box-shadow .25s, border-color .25s;
  position: relative;
}
.rbp-offer-card:hover { box-shadow: var(--off-shadow-lg); border-color: var(--off-purple); }
.rbp-offer-card::before {
  content: ''; position: absolute; top:0;left:0;bottom:0;width:4px;
  background: var(--offer-accent, var(--off-purple));
}
.rbp-offer-card-img {
  background: var(--offer-bg, var(--off-purple-pale));
  display: flex; align-items: center; justify-content: center;
  font-size: 60px; padding: 32px;
}
.rbp-offer-card-body { padding: 28px 28px; }
.rbp-offer-card-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }
.rbp-offer-badge {
  padding: 4px 10px; border-radius: 999px;
  font-size: 10px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase;
}
.rbp-offer-badge--category  { background: var(--off-slate-1); color: var(--off-slate-6); }
.rbp-offer-badge--partner   { background: var(--off-purple-pale); color: var(--off-purple); }
.rbp-offer-badge--member    { background: var(--off-blue-pale); color: var(--off-blue); }
.rbp-offer-badge--exclusive { background: var(--off-amber-pale); color: var(--off-amber); }
.rbp-offer-badge--new       { background: var(--off-green-pale); color: var(--off-green); }
.rbp-offer-card-title { font-size: 20px; font-weight: 900; color: var(--off-slate-9); letter-spacing: -.02em; margin-bottom: 8px; }
.rbp-offer-card-provider { font-size: 13px; color: var(--off-slate-4); font-weight: 600; margin-bottom: 12px; }
.rbp-offer-card-desc { font-size: 14px; color: var(--off-slate-6); line-height: 1.7; margin-bottom: 16px; }
.rbp-offer-card-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.rbp-offer-card-tag { padding: 4px 10px; background: var(--off-slate-0); border: 1px solid var(--off-slate-2); border-radius: 999px; font-size: 12px; color: var(--off-slate-6); font-weight: 600; }
.rbp-offer-card-action {
  padding: 28px 28px; display: flex; flex-direction: column;
  align-items: flex-end; justify-content: space-between; min-width: 200px;
}
.rbp-offer-card-price { text-align: right; }
.rbp-offer-card-price-num { font-size: 28px; font-weight: 900; color: var(--off-slate-9); letter-spacing: -.03em; }
.rbp-offer-card-price-tbc { font-size: 16px; font-weight: 800; color: var(--off-slate-7); }
.rbp-offer-card-price-note { font-size: 12px; color: var(--off-slate-4); margin-top: 4px; }

/* ─── Claim flow ─────────────────────────────────────────────────── */
.rbp-offers-claim {
  background: linear-gradient(135deg, #1c1404, #2e1a06 50%, #0f172a);
  border-radius: var(--off-radius-lg); padding: 56px 48px;
  position: relative; overflow: hidden;
}
.rbp-offers-claim::before {
  content: ''; position: absolute;
  top: -30%; right: -5%; width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle, rgba(245,158,11,.12), transparent 70%);
}
.rbp-offers-claim-inner { position: relative; z-index: 1; max-width: 820px; margin: 0 auto; }
.rbp-offers-claim h2 { color: var(--off-white); font-size: clamp(24px,3.5vw,38px); font-weight: 900; letter-spacing: -.03em; margin: 16px 0 12px; }
.rbp-offers-claim p  { color: #94a3b8; font-size: 15px; line-height: 1.7; margin-bottom: 32px; }
.rbp-offers-claim-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 36px; }
.rbp-offers-claim-step {
  background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--off-radius); padding: 24px 20px; text-align: center;
}
.rbp-offers-claim-step-num {
  width: 44px; height: 44px; border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: var(--off-white); font-size: 18px; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 14px;
}
.rbp-offers-claim-step h4 { color: var(--off-white); font-size: 14px; font-weight: 800; margin-bottom: 6px; }
.rbp-offers-claim-step p  { color: #64748b; font-size: 13px; line-height: 1.6; }

/* ─── CTA band ───────────────────────────────────────────────────── */
.rbp-offers-cta-band {
  background: linear-gradient(135deg, #d97706 0%, #b45309 50%, #0f172a 100%);
  border-radius: var(--off-radius-lg); padding: 60px 52px;
  display: flex; align-items: center; justify-content: space-between; gap: 40px;
  position: relative; overflow: hidden;
}
.rbp-offers-cta-band::before { content: ''; position: absolute; top:-40%;right:-8%;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.07),transparent 70%); }
.rbp-offers-cta-band h2 { color: var(--off-white); font-size: clamp(24px,3.5vw,38px); font-weight: 900; letter-spacing: -.03em; margin-bottom: 10px; }
.rbp-offers-cta-band p { color: rgba(255,255,255,.68); font-size: 16px; line-height: 1.65; }

/* ─── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .rbp-offers-hero-in { grid-template-columns: 1fr; gap: 36px; min-height: unset; padding: 72px 0 56px; }
  .rbp-offer-card { grid-template-columns: 1fr; }
  .rbp-offer-card-img { height: 160px; }
  .rbp-offer-card-action { flex-direction: row; min-width: unset; padding: 16px 28px 28px; }
  .rbp-offers-claim-steps { grid-template-columns: 1fr; }
  .rbp-offers-cta-band { flex-direction: column; padding: 48px 32px; }
}
@media (max-width: 640px) {
  .rbp-offers-sec { padding: 60px 0; }
  .rbp-offer-card-action { flex-direction: column; align-items: flex-start; }
}
/* ─── G10 QA: Focus-visible ─────────────────────────────────────── */
.rbp-offers a:focus-visible,
.rbp-offers button:focus-visible {
  outline: 3px solid #d97706;
  outline-offset: 3px;
  border-radius: 6px;
}
/* ─── G10 QA: Scroll entrance animations ───────────────────────── */
.rbp-off-anim {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1);
}
.rbp-off-anim.rbp-off-anim--in { opacity: 1; transform: translateY(0); }
.rbp-off-anim--d1 { transition-delay: .08s; }
.rbp-off-anim--d2 { transition-delay: .16s; }
.rbp-off-anim--d3 { transition-delay: .24s; }
.rbp-off-anim--d4 { transition-delay: .32s; }
</style>

