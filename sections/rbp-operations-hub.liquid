{% comment %}
  RBP Operations Hub — G2 Missing Hub UX
  Version: 1.0 | New section — operations dashboard for members
  Purpose: Central operations management hub — documents, tools, active services, processes
{% endcomment %}

<style>
.rbp-ops-hub {
  --rbp-blue: #1d4ed8;
  --rbp-blue-mid: #2563eb;
  --rbp-indigo: #4f46e5;
  --rbp-emerald: #059669;
  --rbp-teal: #0d9488;
  --rbp-amber: #d97706;
  --rbp-slate-900: #0f172a;
  --rbp-slate-800: #1e293b;
  --rbp-slate-700: #334155;
  --rbp-slate-600: #475569;
  --rbp-slate-500: #64748b;
  --rbp-slate-400: #94a3b8;
  --rbp-slate-100: #f1f5f9;
  --rbp-slate-50: #f8fafc;
  --rbp-border: rgba(15,23,42,.09);
  font-family: var(--font-body-family, system-ui, sans-serif);
}
.rbp-ops-hub *, .rbp-ops-hub *::before, .rbp-ops-hub *::after { box-sizing: border-box; }

/* ── Hero ──────────────────────────────────────────────── */
.rbp-ops-hero {
  background: linear-gradient(135deg, #0d1a0f 0%, #0f2a1a 55%, #0f172a 100%);
  padding: 80px 0 72px; position: relative; overflow: hidden;
}
.rbp-ops-hero::before {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(ellipse at 20% 50%, rgba(5,150,105,.2) 0%, transparent 55%),
              radial-gradient(ellipse at 85% 30%, rgba(13,148,136,.12) 0%, transparent 50%);
}
.rbp-ops-hero-inner {
  width: min(100% - 2.5rem, 1200px); margin-inline: auto;
  display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 48px;
  position: relative;
}
.rbp-ops-eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(5,150,105,.2); border: 1px solid rgba(5,150,105,.3);
  border-radius: 999px; padding: 6px 14px;
  color: #6ee7b7; font-size: 11.5px; font-weight: 800;
  letter-spacing: .1em; text-transform: uppercase; margin-bottom: 18px;
}
.rbp-ops-hero h1 {
  font-size: clamp(32px, 5vw, 54px); font-weight: 900;
  letter-spacing: -.035em; line-height: 1.06; color: #fff; margin: 0 0 18px;
}
.rbp-ops-hero h1 span { color: #6ee7b7; }
.rbp-ops-hero-sub { font-size: 16.5px; color: #94a3b8; line-height: 1.7; font-weight: 500; max-width: 500px; margin-bottom: 32px; }
.rbp-ops-hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.rbp-ops-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 22px; border-radius: 13px;
  font-size: 14px; font-weight: 800; text-decoration: none;
  transition: all .18s ease;
}
.rbp-ops-btn-primary { background: #059669; color: #fff; box-shadow: 0 6px 22px rgba(5,150,105,.3); }
.rbp-ops-btn-primary:hover { background: #047857; transform: translateY(-2px); }
.rbp-ops-btn-ghost { background: rgba(255,255,255,.08); color: #cbd5e1; border: 1px solid rgba(255,255,255,.14); }
.rbp-ops-btn-ghost:hover { background: rgba(255,255,255,.14); color: #fff; }

/* Ops quick stats */
.rbp-ops-hero-stats {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px; min-width: 240px;
}
.rbp-ops-stat-chip {
  background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1);
  border-radius: 14px; padding: 16px; backdrop-filter: blur(8px);
}
.rbp-ops-stat-chip-val { font-size: 26px; font-weight: 900; color: #fff; letter-spacing: -.03em; line-height: 1; }
.rbp-ops-stat-chip-label { font-size: 11px; color: #64748b; font-weight: 700; margin-top: 5px; }

/* ── Body ──────────────────────────────────────────────── */
.rbp-ops-breadcrumb {
  background: #fff; border-bottom: 1px solid var(--rbp-border);
  padding: 12px 0;
}
.rbp-ops-breadcrumb-inner {
  width: min(100% - 2.5rem, 1200px); margin-inline: auto;
  display: flex; align-items: center; gap: 6px;
  font-size: 12.5px; color: var(--rbp-slate-500); font-weight: 600;
}
.rbp-ops-breadcrumb a { color: var(--rbp-blue); text-decoration: none; }
.rbp-ops-breadcrumb a:hover { text-decoration: underline; }

.rbp-ops-body { background: var(--rbp-slate-50); padding: 64px 0 80px; }
.rbp-ops-container { width: min(100% - 2.5rem, 1200px); margin-inline: auto; }

.rbp-ops-section-head { margin-bottom: 28px; }
.rbp-ops-section-label {
  font-size: 10.5px; font-weight: 900; text-transform: uppercase;
  letter-spacing: .14em; color: var(--rbp-slate-400); margin-bottom: 8px;
}
.rbp-ops-section-title {
  font-size: clamp(20px, 3vw, 28px); font-weight: 900;
  letter-spacing: -.025em; color: var(--rbp-slate-900); margin: 0 0 6px;
}

/* ── Tool grid ──────────────────────────────────────────── */
.rbp-ops-tool-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
  margin-bottom: 60px;
}
.rbp-ops-tool {
  background: #fff; border: 1px solid var(--rbp-border);
  border-radius: 18px; padding: 22px;
  text-decoration: none; color: inherit;
  display: flex; flex-direction: column; align-items: flex-start;
  transition: transform .18s ease, box-shadow .18s ease;
}
.rbp-ops-tool:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(15,23,42,.09); }
.rbp-ops-tool-icon {
  width: 44px; height: 44px; border-radius: 13px;
  background: var(--rbp-tool-bg, var(--rbp-slate-100));
  display: grid; place-items: center; font-size: 18px; margin-bottom: 16px;
}
.rbp-ops-tool-name { font-size: 14.5px; font-weight: 900; color: var(--rbp-slate-900); margin-bottom: 6px; letter-spacing: -.01em; }
.rbp-ops-tool-desc { font-size: 12.5px; color: var(--rbp-slate-500); line-height: 1.55; font-weight: 500; flex: 1; }
.rbp-ops-tool-arrow {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 12px; font-weight: 800; color: var(--rbp-blue);
  margin-top: 14px;
}

/* ── Process cards ──────────────────────────────────────── */
.rbp-ops-process { margin-bottom: 60px; }
.rbp-ops-process-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.rbp-ops-process-card {
  background: #fff; border: 1px solid var(--rbp-border);
  border-radius: 20px; padding: 26px; position: relative;
}
.rbp-ops-process-num {
  position: absolute; top: 20px; right: 20px;
  width: 28px; height: 28px; border-radius: 999px;
  background: var(--rbp-slate-100); color: var(--rbp-slate-500);
  display: grid; place-items: center;
  font-size: 11px; font-weight: 900;
}
.rbp-ops-process-icon { font-size: 24px; margin-bottom: 14px; }
.rbp-ops-process-title { font-size: 15px; font-weight: 900; color: var(--rbp-slate-900); margin: 0 0 8px; }
.rbp-ops-process-desc { font-size: 13px; color: var(--rbp-slate-500); line-height: 1.65; font-weight: 500; }
.rbp-ops-process-steps {
  margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--rbp-border);
  display: flex; flex-direction: column; gap: 6px;
}
.rbp-ops-process-step {
  display: flex; align-items: center; gap: 8px;
  font-size: 12.5px; color: var(--rbp-slate-600); font-weight: 600;
}
.rbp-ops-process-step svg { color: var(--rbp-emerald); flex-shrink: 0; }

/* ── Resource quick-access ──────────────────────────────── */
.rbp-ops-resource-grid { display: grid; grid-template-columns: 3fr 2fr; gap: 20px; margin-bottom: 60px; }
.rbp-ops-resource-main {
  background: #fff; border: 1px solid var(--rbp-border);
  border-radius: 20px; overflow: hidden;
}
.rbp-ops-resource-header {
  padding: 20px 24px; border-bottom: 1px solid var(--rbp-border);
  display: flex; align-items: center; justify-content: space-between;
}
.rbp-ops-resource-header-title { font-size: 14px; font-weight: 900; color: var(--rbp-slate-900); }
.rbp-ops-resource-view-all {
  font-size: 12.5px; font-weight: 800; color: var(--rbp-blue); text-decoration: none;
}
.rbp-ops-resource-list { }
.rbp-ops-resource-item {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 24px; border-bottom: 1px solid rgba(15,23,42,.05);
  text-decoration: none; color: inherit;
  transition: background .12s;
}
.rbp-ops-resource-item:last-child { border-bottom: none; }
.rbp-ops-resource-item:hover { background: var(--rbp-slate-50); }
.rbp-ops-resource-file-icon {
  width: 36px; height: 36px; border-radius: 9px;
  background: var(--rbp-slate-100); display: grid; place-items: center;
  font-size: 15px; flex-shrink: 0;
}
.rbp-ops-resource-item-body { flex: 1; }
.rbp-ops-resource-item-name { font-size: 13.5px; font-weight: 800; color: var(--rbp-slate-800); }
.rbp-ops-resource-item-meta { font-size: 11.5px; color: var(--rbp-slate-400); font-weight: 600; margin-top: 2px; }
.rbp-ops-resource-item-action { color: var(--rbp-slate-400); }

.rbp-ops-resource-side {
  display: flex; flex-direction: column; gap: 16px;
}
.rbp-ops-side-card {
  background: #fff; border: 1px solid var(--rbp-border);
  border-radius: 18px; padding: 22px; flex: 1;
}
.rbp-ops-side-card-title { font-size: 13px; font-weight: 900; color: var(--rbp-slate-900); margin-bottom: 12px; }
.rbp-ops-side-card p { font-size: 12.5px; color: var(--rbp-slate-500); line-height: 1.6; font-weight: 500; }
.rbp-ops-side-card a {
  display: inline-flex; align-items: center; gap: 6px;
  margin-top: 14px; padding: 9px 16px; border-radius: 10px;
  background: var(--rbp-blue); color: #fff;
  font-size: 12.5px; font-weight: 800; text-decoration: none;
  transition: background .15s;
}
.rbp-ops-side-card a:hover { background: var(--rbp-blue-mid); }

/* ── Pending actions banner ─────────────────────────────── */
.rbp-ops-pending {
  background: linear-gradient(135deg, #fffbeb 0%, #fff7ed 100%);
  border: 1px solid rgba(217,119,6,.2); border-radius: 18px;
  padding: 24px 28px; display: flex; align-items: center; gap: 20px;
  margin-bottom: 60px;
}
.rbp-ops-pending-icon { font-size: 28px; flex-shrink: 0; }
.rbp-ops-pending-body { flex: 1; }
.rbp-ops-pending-title { font-size: 15px; font-weight: 900; color: #92400e; margin-bottom: 4px; }
.rbp-ops-pending-text { font-size: 13.5px; color: #b45309; font-weight: 500; line-height: 1.5; }
.rbp-ops-pending a {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 10px 18px; border-radius: 11px;
  background: #d97706; color: #fff;
  font-size: 13px; font-weight: 800; text-decoration: none;
  white-space: nowrap; flex-shrink: 0; transition: background .15s;
}
.rbp-ops-pending a:hover { background: #b45309; }

/* ── Responsive ─────────────────────────────────────────── */
@media (max-width: 1023px) {
  .rbp-ops-tool-grid { grid-template-columns: repeat(2, 1fr); }
  .rbp-ops-process-grid { grid-template-columns: 1fr 1fr; }
  .rbp-ops-resource-grid { grid-template-columns: 1fr; }
  .rbp-ops-hero-inner { grid-template-columns: 1fr; }
  .rbp-ops-hero-stats { display: none; }
}
@media (max-width: 640px) {
  .rbp-ops-tool-grid { grid-template-columns: 1fr 1fr; }
  .rbp-ops-process-grid { grid-template-columns: 1fr; }
  .rbp-ops-pending { flex-direction: column; align-items: flex-start; }
}
</style>

<div class="rbp-ops-hub">

  {%- comment %} ── Hero ── {% endcomment %}
  <section class="rbp-ops-hero" aria-labelledby="rbp-ops-h1">
    <div class="rbp-ops-hero-inner">
      <div>
        <div class="rbp-ops-eyebrow" aria-hidden="true">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
          Operations Hub
        </div>
        <h1 id="rbp-ops-h1">Your business <span>operations</span>,<br>all in one place.</h1>
        <p class="rbp-ops-hero-sub">Access tools, templates, process guides, active service dashboards, and operational resources — everything you need to run your business efficiently.</p>
        <div class="rbp-ops-hero-actions">
          <a href="#tools" class="rbp-ops-btn rbp-ops-btn-primary">
            Explore tools
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
          <a href="/pages/member-portal" class="rbp-ops-btn rbp-ops-btn-ghost">Member portal</a>
        </div>
      </div>
      <div class="rbp-ops-hero-stats" aria-label="Operations summary">
        <div class="rbp-ops-stat-chip">
          <div class="rbp-ops-stat-chip-val">699</div>
          <div class="rbp-ops-stat-chip-label">On-demand services</div>
        </div>
        <div class="rbp-ops-stat-chip">
          <div class="rbp-ops-stat-chip-val">2k+</div>
          <div class="rbp-ops-stat-chip-label">Templates available</div>
        </div>
        <div class="rbp-ops-stat-chip">
          <div class="rbp-ops-stat-chip-val">5</div>
          <div class="rbp-ops-stat-chip-label">Core service types</div>
        </div>
        <div class="rbp-ops-stat-chip">
          <div class="rbp-ops-stat-chip-val">AU</div>
          <div class="rbp-ops-stat-chip-label">Australian focused</div>
        </div>
      </div>
    </div>
  </section>

  {%- comment %} ── Breadcrumb ── {% endcomment %}
  <nav class="rbp-ops-breadcrumb" aria-label="Breadcrumb">
    <div class="rbp-ops-breadcrumb-inner">
      <a href="/">Home</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      <span aria-current="page">Operations Hub</span>
    </div>
  </nav>

  <div class="rbp-ops-body" id="tools">
    <div class="rbp-ops-container">

      {%- comment %} Pending actions notice — shown when Codex populates data {% endcomment %}
      <div class="rbp-ops-pending" role="alert" aria-label="Pending action required">
        <div class="rbp-ops-pending-icon" aria-hidden="true">⚠️</div>
        <div class="rbp-ops-pending-body">
          <div class="rbp-ops-pending-title">Action may be required on active engagements</div>
          <p class="rbp-ops-pending-text">Log in to your account to view any pending actions, document requests, or status updates on your active services.</p>
        </div>
        <a href="/account/login">
          Check account
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      {%- comment %} Operations tools {% endcomment %}
      <div class="rbp-ops-section-head">
        <p class="rbp-ops-section-label">Quick access tools</p>
        <h2 class="rbp-ops-section-title">Operational tools &amp; resources</h2>
      </div>
      <div class="rbp-ops-tool-grid">
        <a href="/pages/document-hub" class="rbp-ops-tool" style="--rbp-tool-bg:#eff6ff;" aria-label="Document Hub">
          <div class="rbp-ops-tool-icon">🗂️</div>
          <span class="rbp-ops-tool-name">Document Hub</span>
          <span class="rbp-ops-tool-desc">Access, manage, and download your business documents and agreements.</span>
          <span class="rbp-ops-tool-arrow">Open hub <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/collections/business-templates" class="rbp-ops-tool" style="--rbp-tool-bg:#f0fdf4;" aria-label="Business Templates">
          <div class="rbp-ops-tool-icon">📄</div>
          <span class="rbp-ops-tool-name">Business Templates</span>
          <span class="rbp-ops-tool-desc">2,600+ ready-to-use templates across finance, HR, legal, operations, and more.</span>
          <span class="rbp-ops-tool-arrow">Browse templates <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/pages/retainer-builder" class="rbp-ops-tool" style="--rbp-tool-bg:#fef9c3;" aria-label="Retainer Builder">
          <div class="rbp-ops-tool-icon">🔁</div>
          <span class="rbp-ops-tool-name">Retainer Builder</span>
          <span class="rbp-ops-tool-desc">Build a custom ongoing retainer from the services and support hours you need.</span>
          <span class="rbp-ops-tool-arrow">Build retainer <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/pages/business-assessment" class="rbp-ops-tool" style="--rbp-tool-bg:#f5f3ff;" aria-label="Business Assessment">
          <div class="rbp-ops-tool-icon">📊</div>
          <span class="rbp-ops-tool-name">Business Assessment</span>
          <span class="rbp-ops-tool-desc">Run a self-guided business health assessment to identify gaps and priorities.</span>
          <span class="rbp-ops-tool-arrow">Start assessment <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/collections/toolkits" class="rbp-ops-tool" style="--rbp-tool-bg:#fff7ed;" aria-label="Toolkits">
          <div class="rbp-ops-tool-icon">🧰</div>
          <span class="rbp-ops-tool-name">Toolkits</span>
          <span class="rbp-ops-tool-desc">Comprehensive toolkit packs for Finance, HR, Legal, Risk, Marketing and more.</span>
          <span class="rbp-ops-tool-arrow">View toolkits <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/collections/documentation-suites" class="rbp-ops-tool" style="--rbp-tool-bg:#ecfdf5;" aria-label="Documentation Suites">
          <div class="rbp-ops-tool-icon">📑</div>
          <span class="rbp-ops-tool-name">Documentation Suites</span>
          <span class="rbp-ops-tool-desc">Complete documentation packs for industry-specific compliance and operations.</span>
          <span class="rbp-ops-tool-arrow">Browse suites <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/collections/dashboards-calculators" class="rbp-ops-tool" style="--rbp-tool-bg:#eff6ff;" aria-label="Dashboards and Calculators">
          <div class="rbp-ops-tool-icon">📈</div>
          <span class="rbp-ops-tool-name">Dashboards &amp; Calculators</span>
          <span class="rbp-ops-tool-desc">Ready-to-use business dashboards, financial models, and calculators.</span>
          <span class="rbp-ops-tool-arrow">Open tools <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/pages/member-portal" class="rbp-ops-tool" style="--rbp-tool-bg:#fdf2f8;" aria-label="Member Portal">
          <div class="rbp-ops-tool-icon">💎</div>
          <span class="rbp-ops-tool-name">Member Portal</span>
          <span class="rbp-ops-tool-desc">Access your active engagements, exclusive content, and member-only resources.</span>
          <span class="rbp-ops-tool-arrow">Open portal <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
      </div>

      {%- comment %} Key process flows {% endcomment %}
      <div class="rbp-ops-section-head">
        <p class="rbp-ops-section-label">How it works</p>
        <h2 class="rbp-ops-section-title">Core operational processes</h2>
      </div>
      <div class="rbp-ops-process-grid rbp-ops-process">
        <div class="rbp-ops-process-card">
          <span class="rbp-ops-process-num">1</span>
          <div class="rbp-ops-process-icon">🎯</div>
          <h3 class="rbp-ops-process-title">Engage a Core Service</h3>
          <p class="rbp-ops-process-desc">Complete an intake form, get matched to the right service, and begin your engagement.</p>
          <div class="rbp-ops-process-steps">
            <div class="rbp-ops-process-step">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Submit intake form
            </div>
            <div class="rbp-ops-process-step">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Team review within 1 business day
            </div>
            <div class="rbp-ops-process-step">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Service commences
            </div>
          </div>
        </div>
        <div class="rbp-ops-process-card">
          <span class="rbp-ops-process-num">2</span>
          <div class="rbp-ops-process-icon">⚡</div>
          <h3 class="rbp-ops-process-title">Buy an On-Demand Service</h3>
          <p class="rbp-ops-process-desc">Browse, purchase, and receive your on-demand service. Most are fulfilled within 48 hours.</p>
