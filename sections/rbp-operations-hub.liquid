<style>
.rbp-ops{--b:#123fbe;--bd:#0b2f94;--n:#071326;--i:#0f172a;--m:#5b6675;--s:#f3f7ff;--l:rgba(15,23,42,.1);font-family:var(--font-body-family,system-ui,sans-serif);color:var(--i);background:linear-gradient(180deg,#eef5ff,#fff)}.rbp-ops *{box-sizing:border-box}.rbp-ops a{text-decoration:none;color:inherit}.rbp-wrap{width:min(100% - 2.5rem,1200px);margin:auto}.rbp-eye{display:inline-flex;gap:7px;align-items:center;border-radius:999px;background:rgba(18,63,190,.1);color:var(--bd);padding:7px 13px;font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase}.rbp-eye:before{content:'';width:7px;height:7px;border-radius:50%;background:currentColor}.rbp-btn{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;min-height:46px;padding:13px 20px;font-size:13px;font-weight:900}.rbp-btn--p{background:var(--b);color:#fff;box-shadow:0 12px 28px rgba(18,63,190,.24)}.rbp-btn--s{background:#fff;color:var(--bd);border:1px solid rgba(18,63,190,.18)}.rbp-hero{padding:clamp(56px,8vw,108px) 0;overflow:hidden;position:relative}.rbp-hero:before{content:'';position:absolute;inset:-20% -10% auto auto;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,rgba(37,99,235,.16),transparent 66%)}.rbp-hero-grid{position:relative;display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.75fr);gap:clamp(32px,6vw,72px);align-items:center}.rbp-hero h1{font-size:clamp(42px,6vw,76px);line-height:.98;letter-spacing:-.055em;margin:18px 0;color:var(--i)}.rbp-lead{max-width:640px;color:var(--m);font-size:17px;line-height:1.75}.rbp-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:28px}.rbp-visual{min-height:390px;border-radius:28px;background:radial-gradient(circle at 22% 18%,rgba(96,165,250,.48),transparent 27%),linear-gradient(145deg,#071326,#14223a 58%,#123fbe 150%);box-shadow:0 30px 76px rgba(15,23,42,.22);position:relative;overflow:hidden}.rbp-visual:after{content:'';position:absolute;left:-15%;right:-15%;bottom:-18%;height:48%;background:repeating-linear-gradient(90deg,rgba(255,255,255,.07) 0 1px,transparent 1px 28px);transform:perspective(520px) rotateX(64deg);opacity:.75}.rbp-feature{position:absolute;left:24px;right:24px;bottom:24px;z-index:2;display:flex;justify-content:space-between;gap:16px;background:rgba(255,255,255,.95);border-radius:18px;padding:18px 20px;box-shadow:0 18px 42px rgba(0,0,0,.18)}.rbp-feature small{display:block;color:var(--b);font-size:10px;font-weight:950;text-transform:uppercase;letter-spacing:.1em}.rbp-feature strong{display:block;margin-top:4px}.rbp-trust{background:linear-gradient(135deg,var(--bd),var(--b));color:#fff}.rbp-trust .rbp-wrap{display:flex;flex-wrap:wrap;justify-content:center;gap:14px 30px;padding:28px 0}.rbp-trust span{font-size:13px;font-weight:850}.rbp-sec{padding:clamp(56px,7vw,92px) 0}.rbp-soft{background:#f7faff}.rbp-head{text-align:center;max-width:740px;margin:0 auto 38px}.rbp-head h2{font-size:clamp(30px,4vw,50px);line-height:1.06;letter-spacing:-.04em;margin:12px 0;color:var(--i)}.rbp-head p{color:var(--m);line-height:1.7;margin:0}.rbp-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.rbp-card{border:1px solid var(--l);border-radius:22px;background:#fff;padding:24px;box-shadow:0 12px 30px rgba(15,23,42,.05)}.rbp-card.dark{min-height:250px;display:flex;flex-direction:column;justify-content:flex-end;color:#fff;background:radial-gradient(circle at 80% 18%,rgba(147,197,253,.28),transparent 28%),linear-gradient(145deg,#071326,#15233a 70%,#123fbe 160%)}.rbp-card h3{font-size:22px;line-height:1.15;margin:0 0 10px;letter-spacing:-.02em}.rbp-card p{color:var(--m);line-height:1.65;margin:0 0 16px}.rbp-card.dark p{color:rgba(255,255,255,.78)}.rbp-card a{color:var(--b);font-weight:900;font-size:13px}.rbp-card.dark a{color:#bfdbfe}.rbp-proof .rbp-card{text-align:center}.rbp-icon{width:54px;height:54px;margin:0 auto 16px;border-radius:18px;display:grid;place-items:center;background:#dbeafe;color:var(--b);font-weight:950}.rbp-split{display:grid;grid-template-columns:300px 1fr;gap:clamp(24px,4vw,48px);align-items:start}.rbp-side{position:sticky;top:110px}.rbp-side h2{font-size:clamp(30px,4vw,44px);line-height:1.06;margin:12px 0}.rbp-list{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}.rbp-note{grid-column:1/-1;border-radius:24px;background:linear-gradient(135deg,#071326,#123fbe);color:#fff;padding:26px;display:grid;grid-template-columns:1fr auto;gap:18px;align-items:center}.rbp-note p{color:#dbeafe;margin:0}.rbp-final{padding-bottom:clamp(56px,7vw,96px)}.rbp-final-card{border-radius:28px;background:linear-gradient(135deg,#071326,#123fbe);color:#fff;padding:clamp(32px,5vw,58px);display:grid;grid-template-columns:1fr auto;gap:24px;align-items:center}.rbp-final-card p{color:#dbeafe}@media(max-width:900px){.rbp-hero-grid,.rbp-grid,.rbp-split,.rbp-list,.rbp-note,.rbp-final-card{grid-template-columns:1fr}.rbp-side{position:static}}@media(max-width:620px){.rbp-wrap{width:min(100% - 1.5rem,1200px)}.rbp-btn{width:100%}.rbp-visual{min-height:320px}}
</style>

<div class="rbp-ops" data-rbp-section="operations-public-landing">
  <section class="rbp-hero" aria-labelledby="rbp-ops-title">
    <div class="rbp-wrap rbp-hero-grid">
      <div><span class="rbp-eye">Operations</span><h1 id="rbp-ops-title">Practical systems for day-to-day business operations.</h1><p class="rbp-lead">Templates, toolkits, documentation suites and resources designed to help businesses operate with more structure, clarity and repeatable workflows.</p><div class="rbp-actions"><a class="rbp-btn rbp-btn--p" href="/collections/templates">Browse Templates</a><a class="rbp-btn rbp-btn--s" href="/pages/our-process">View Our Process</a></div></div>
      <div class="rbp-visual" aria-label="Structured operations resource panel"><a class="rbp-feature" href="/pages/our-process"><span><small>Recommended starting point</small><strong>Our Process</strong></span><span aria-hidden="true">→</span></a></div>
    </div>
  </section>

  <section class="rbp-trust" aria-label="Operations credibility markers"><div class="rbp-wrap"><span>Structured Business Resources</span><span>Onboarding-Led Delivery</span><span>Prepared Documentation</span><span>Practical Operational Support</span></div></section>

  <section class="rbp-sec" aria-labelledby="rbp-curated"><div class="rbp-wrap"><div class="rbp-head"><span class="rbp-eye">Curated resources</span><h2 id="rbp-curated">Curated by operational need</h2><p>Start with the resource category that best matches the workflow, document set or operational system you are trying to improve.</p></div><div class="rbp-grid"><article class="rbp-card dark"><h3>Templates</h3><p>Prepared business documents and practical forms for common operating needs.</p><a href="/collections/templates">Browse templates →</a></article><article class="rbp-card dark"><h3>Documentation Suites</h3><p>Connected document packs for workflows that need more than a single template.</p><a href="/collections/documentation-suites">View suites →</a></article><article class="rbp-card dark"><h3>Toolkits</h3><p>Practical resource packs for broader business processes and operating systems.</p><a href="/collections/toolkits">View toolkits →</a></article></div></div></section>

  <section class="rbp-sec rbp-soft rbp-proof" aria-labelledby="rbp-proof"><div class="rbp-wrap"><div class="rbp-head"><span class="rbp-eye">Why the structure matters</span><h2 id="rbp-proof">Built for practical business use</h2></div><div class="rbp-grid"><article class="rbp-card"><div class="rbp-icon">01</div><h3>Prepared Resources</h3><p>Resources are structured so customers can understand what is included and what inputs may still be required.</p></article><article class="rbp-card"><div class="rbp-icon">02</div><h3>Clear Delivery Pathways</h3><p>Product and resource pathways should explain purchase, preparation, onboarding and delivery steps.</p></article><article class="rbp-card"><div class="rbp-icon">03</div><h3>Business-Ready Structure</h3><p>Content is organised around business functions, workflows and operational use cases.</p></article></div></div></section>

  <section class="rbp-sec" aria-labelledby="rbp-pathways"><div class="rbp-wrap rbp-split"><aside class="rbp-side"><span class="rbp-eye">Pathways</span><h2 id="rbp-pathways">Explore operations pathways</h2><p>Use these routes to move from a general operating need to the right process page, resource collection or support pathway.</p></aside><div class="rbp-list"><article class="rbp-card"><h3>Our Process</h3><p>Understand how RBP scopes, prepares and supports operational work.</p><a href="/pages/our-process">View process →</a></article><article class="rbp-card"><h3>Templates</h3><p>Browse prepared documents and forms for everyday operating needs.</p><a href="/collections/templates">Browse templates →</a></article><article class="rbp-card"><h3>Documentation Suites</h3><p>Find connected document packs for structured workflows.</p><a href="/collections/documentation-suites">View suites →</a></article><article class="rbp-card"><h3>Toolkits</h3><p>Use practical packs for wider business systems and functions.</p><a href="/collections/toolkits">View toolkits →</a></article><article class="rbp-card"><h3>Industry Packs</h3><p>Explore industry-focused operating documents where available.</p><a href="/collections/industry-packs">Explore industry packs →</a></article><article class="rbp-card"><h3>Resources</h3><p>Review broader guides, tools and support material for business operations.</p><a href="/pages/resources">View resources →</a></article><aside class="rbp-note"><div><h3>Not sure what resource fits?</h3><p>Start with the process page or contact RBP so the next operational step is clearer.</p></div><a class="rbp-btn rbp-btn--s" href="/pages/contact">Contact RBP</a></aside></div></div></section>

  <section class="rbp-final" aria-label="Operations next step"><div class="rbp-wrap"><div class="rbp-final-card"><div><h2>Give the operating work a clearer structure.</h2><p>Browse templates, review the process, or contact RBP when the right pathway needs to be clarified first.</p></div><a class="rbp-btn rbp-btn--p" href="/collections/templates">Browse Templates</a></div></div></section>
</div>

