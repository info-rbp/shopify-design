{%- liquid
  assign has_onboarding_item = false
  for line_item in order.line_items
    if line_item.product.metafields.custom.requires_onboarding_form.value == true or line_item.product.tags contains 'Template' or line_item.product.tags contains 'Templates' or line_item.product.product_type contains 'Template'
      assign has_onboarding_item = true
    endif
  endfor
-%}

{%- if has_onboarding_item -%}
  <section class="customer rbp-order-onboarding section-{{ section.id }}-padding">
    <div class="rbp-order-onboarding__card">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
      <div class="rbp-order-onboarding__items">
        {%- for line_item in order.line_items -%}
          {%- if line_item.product.metafields.custom.requires_onboarding_form.value == true or line_item.product.tags contains 'Template' or line_item.product.tags contains 'Templates' or line_item.product.product_type contains 'Template' -%}
            {%- assign onboarding_url = line_item.product.metafields.custom.onboarding_form.value | default: '/pages/template-customisation-onboarding' -%}
            {%- assign onboarding_category = line_item.product.metafields.custom.onboarding_question_set.value | default: line_item.product.metafields.custom.product_family.value | default: '' -%}
            <div class="rbp-order-onboarding__item">
              <strong>{{ line_item.title | escape }}</strong>
              <a class="button button--secondary" href="{{ onboarding_url }}?order={{ order.name | url_encode }}&product={{ line_item.product.handle | url_encode }}&title={{ line_item.product.title | url_encode }}&sku={{ line_item.sku | url_encode }}&category={{ onboarding_category | url_encode }}">Complete onboarding form</a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
  <style>
    .rbp-order-onboarding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
    .rbp-order-onboarding__card { border: 1px solid rgba(var(--color-foreground), .12); border-radius: 16px; padding: 22px; background: rgba(var(--color-foreground), .03); }
    .rbp-order-onboarding__card h2 { margin-top: 0; }
    .rbp-order-onboarding__items { display: grid; gap: 12px; margin-top: 16px; }
    .rbp-order-onboarding__item { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 12px; border-top: 1px solid rgba(var(--color-foreground), .1); padding-top: 12px; }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "RBP order onboarding CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Next step: complete your onboarding form" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Your order includes a customised digital product. Complete the onboarding form for each applicable product so we can begin customisation." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 0 }
  ],
  "presets": [ { "name": "RBP order onboarding CTA" } ]
}
{% endschema %}
