<script>
(function(){
  // NBN address checker — hooks into Codex /apps/rbp-bridge/api/check-address
  var checkBtn = document.getElementById('rbp-nbn-check-btn');
  if(!checkBtn) return;
  checkBtn.addEventListener('click', function(){
    var address = document.getElementById('rbp-nbn-address').value.trim();
    var result = document.getElementById('rbp-avail-result');
    if(!address){ result.style.display='block'; result.style.color='#b45309'; result.textContent='Please enter your business address to check availability.'; return; }
    checkBtn.textContent='Checking…'; checkBtn.disabled=true;
    // Placeholder — Codex will connect /apps/rbp-bridge/api/check-address
    setTimeout(function(){
      result.style.display='block';
      result.style.color='#047857';
      result.innerHTML='<strong>Address submitted.</strong> Our team will confirm availability within 1 business day. <a href="/pages/contact" style="color:#047857;font-weight:700;">Questions? Contact us.</a>';
      checkBtn.textContent='Check availability'; checkBtn.disabled=false;
    }, 1200);
  });
})();
</script>

