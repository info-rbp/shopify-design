<style>
.rbp-res{--b:#1d4ed8;--bd:#1e3a8a;--bs:#dbeafe;--s9:#0f172a;--s7:#334155;--s6:#475569;--s0:#f8fafc;--br:rgba(15,23,42,.1);--br2:rgba(15,23,42,.16);--sh:0 22px 55px rgba(15,23,42,.14);background:#fff;color:var(--s9)}.rbp-res *{box-sizing:border-box}.rbp-res a{text-decoration:none;color:inherit}.rbp-res-c{width:min(100% - 3rem,1200px);margin-inline:auto}.rbp-res-hero{overflow:hidden;color:#fff;background:radial-gradient(ellipse at top right,rgba(59,130,246,.24),transparent 58%),linear-gradient(135deg,#0f172a 0%,#172554 52%,#0f172a 100%)}.rbp-res-hero-in{display:grid;grid-template-columns:minmax(0,1fr) minmax(310px,.72fr);gap:56px;align-items:center;padding:86px 0;min-height:560px}.rbp-res-ey{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:#dbeafe;color:#1d4ed8;font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.rbp-res-hero .rbp-res-ey{background:rgba(59,130,246,.18);color:#93c5fd;border:1px solid rgba(147,197,253,.28)}.rbp-res-dot{width:7px;height:7px;border-radius:999px;background:currentColor}.rbp-res-h1{margin:16px 0 0;color:#fff;font-size:clamp(40px,6vw,76px);line-height:1.02;letter-spacing:-.045em;font-weight:900}.rbp-res-h2{margin:14px 0 0;color:var(--s9);font-size:clamp(30px,4vw,50px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-res-p{margin:16px 0 0;color:var(--s6);font-size:16px;line-height:1.75}.rbp-res-hero .rbp-res-p{color:#cbd5e1;font-size:18px;max-width:760px}.rbp-res-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:28px}.rbp-res-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:14px;padding:14px 18px;border:1px solid transparent;font-size:14px;font-weight:900;line-height:1}.rbp-res-btn-p{background:#1d4ed8;color:#fff;box-shadow:0 18px 36px rgba(29,78,216,.24)}.rbp-res-btn-g{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.24)}.rbp-res-btn-o{background:#fff;color:var(--s7);border-color:var(--br2)}.rbp-res-search{margin-top:28px;display:flex;gap:10px;background:#fff;border-radius:18px;padding:8px;box-shadow:0 18px 40px rgba(2,6,23,.28)}.rbp-res-search input{flex:1;min-width:0;border:0;outline:0;color:#0f172a;font-size:16px;padding:12px 14px;background:transparent}.rbp-res-search button{border:0;border-radius:14px;background:#1d4ed8;color:#fff;font-weight:900;padding:12px 18px;cursor:pointer}.rbp-res-card{background:#fff;border:1px solid var(--br);border-radius:24px;padding:24px;box-shadow:0 1px 2px rgba(15,23,42,.05)}.rbp-res-hero-card{border:1px solid rgba(255,255,255,.14);border-radius:28px;background:rgba(255,255,255,.08);box-shadow:0 35px 75px rgba(30,64,175,.32);padding:26px}.rbp-res-hero-card h3{margin:0 0 12px;color:#fff;font-size:22px;font-weight:900}.rbp-res-hero-card p{margin:0;color:#cbd5e1;line-height:1.7}.rbp-res-sec{padding:74px 0}.rbp-res-muted{background:#f8fafc}.rbp-res-head{max-width:780px;margin:0 auto 36px;text-align:center}.rbp-res-grid{display:grid;gap:20px}.rbp-res-g2{grid-template-columns:repeat(2,minmax(0,1fr))}.rbp-res-g3{grid-template-columns:repeat(3,minmax(0,1fr))}.rbp-res-g4{grid-template-columns:repeat(4,minmax(0,1fr))}.rbp-res-icon{width:46px;height:46px;border-radius:16px;display:grid;place-items:center;margin-bottom:16px;background:#dbeafe;color:#1d4ed8;font-weight:900}.rbp-res-title{margin:0 0 8px;color:#0f172a;font-size:18px;font-weight:900}.rbp-res-text,.rbp-res-rich,.rbp-res-rich p,.rbp-res-rich li{margin:0;color:#64748b;line-height:1.65;font-size:14px}.rbp-res-link{display:inline-flex;align-items:center;gap:6px;margin-top:16px;color:#1d4ed8;font-size:13px;font-weight:900}.rbp-res-list{display:grid;gap:10px;margin:18px 0 0;padding:0;list-style:none}.rbp-res-list li{display:grid;grid-template-columns:22px minmax(0,1fr);gap:10px;color:#64748b;line-height:1.55;font-size:14px}.rbp-res-check{width:18px;height:18px;border-radius:999px;display:inline-grid;place-items:center;background:#3b82f6;color:#fff;font-size:12px;line-height:1;flex:0 0 auto}.rbp-res-blue{background:linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;border:0;box-shadow:var(--sh)}.rbp-res-blue .rbp-res-title,.rbp-res-blue .rbp-res-h2{color:#fff}.rbp-res-blue .rbp-res-text,.rbp-res-blue .rbp-res-p,.rbp-res-blue li{color:#dbeafe}.rbp-res-faq details{background:#fff;border:1px solid var(--br);border-radius:18px;padding:0 18px}.rbp-res-faq details+details{margin-top:12px}.rbp-res-faq summary{cursor:pointer;padding:18px 0;color:#0f172a;font-weight:900}.rbp-res-faq summary::-webkit-details-marker{display:none}.rbp-res-faq div{padding-bottom:18px;color:#64748b;line-height:1.7}.rbp-res-cta{border-radius:32px;background:radial-gradient(circle at top right,rgba(255,255,255,.18),transparent 35%),linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;padding:clamp(28px,5vw,56px);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:28px;align-items:center}.rbp-res-cta h2{margin:0;color:#fff;font-size:clamp(28px,4vw,48px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-res-cta p{margin:12px 0 0;color:#dbeafe;line-height:1.7;max-width:760px}@media(max-width:989px){.rbp-res-hero-in,.rbp-res-g2,.rbp-res-g3,.rbp-res-g4,.rbp-res-cta{grid-template-columns:1fr}.rbp-res-hero-card{display:none}.rbp-res-head{text-align:left;margin-inline:0}.rbp-res-search{display:grid}.rbp-res-search button{width:100%}}@media(max-width:749px){.rbp-res-c{width:min(100% - 2rem,1200px)}.rbp-res-sec{padding:54px 0}.rbp-res-hero-in{padding:68px 0;min-height:auto}.rbp-res-btn{width:100%}}
</style>
{%- liquid
 assign mode = 'resources'
 if page.handle == 'knowledge-base'
  assign mode = 'knowledge'
 elsif page.handle == 'frequently-asked-questions'
  assign mode = 'faq'
 endif
 assign articles = page.metafields.custom.featured_help_articles.value
 assign faqs = page.metafields.custom.featured_faqs.value
 assign heading = page.title
 assign eyebrow = 'Resource Library'
 assign summary = 'Browse practical business articles, guides, tools, downloads and educational resources from Remote Business Partner.'
 assign card_title = 'Resources without the scavenger hunt'
 assign card_text = 'This area consolidates content that used to be spread across overlapping pages, because apparently every website eventually tries to become a junk drawer.'
 if mode == 'knowledge'
  assign eyebrow = 'Knowledge Base'
  assign summary = 'Use the Knowledge Base as the article library for structured business guidance, product education, service explainers and support knowledge.'
  assign card_title = 'Article library and learning hub'
  assign card_text = 'The Knowledge Base is designed for evergreen guidance, not dated news posts pretending to be help documentation.'
 elsif mode == 'faq'
  assign eyebrow = 'Frequently Asked Questions'
  assign summary = 'Find direct answers to common questions about documents, membership, business services, support, orders and Business NBN.'
  assign card_title = 'Reusable answers in one place'
  assign card_text = 'FAQs should be managed once and reused across Help Centre, products, collections and support pages. Revolutionary, apparently.'
 elsif page.handle == 'articles'
  assign heading = 'Articles'
  assign summary = 'Read practical business articles, explainers and educational content connected to Remote Business Partner services and products.'
 elsif page.handle == 'guides'
  assign heading = 'Guides'
  assign summary = 'Browse step-by-step guides that help explain business processes, document pathways and support options.'
 elsif page.handle == 'tools'
  assign heading = 'Tools'
  assign summary = 'Find practical tools, checklists and business resources designed to support planning, operations and decision-making.'
 elsif page.handle == 'downloads'
  assign heading = 'Downloads'
  assign summary = 'Access downloadable resources, forms, support materials and business documents where available.'
 elsif page.handle == 'educational'
  assign heading = 'Educational'
  assign summary = 'Explore educational resources that help business owners understand products, services, support pathways and operational topics.'
 endif
-%}
<div class="rbp-res">
<section class="rbp-res-hero"><div class="rbp-res-c"><div class="rbp-res-hero-in"><div><div class="rbp-res-ey"><span class="rbp-res-dot"></span>{{ eyebrow }}</div><h1 class="rbp-res-h1">{{ heading }}</h1><p class="rbp-res-p">{{ summary }}</p><form class="rbp-res-search" action="{{ routes.search_url }}" method="get" role="search"><input type="search" name="q" placeholder="Search resources, help topics, products or services" aria-label="Search resources"><button type="submit">Search</button></form><div class="rbp-res-actions"><a class="rbp-res-btn rbp-res-btn-p" href="/pages/help-centre">Visit Help Centre -&gt;</a><a class="rbp-res-btn rbp-res-btn-g" href="/pages/contact">Contact Support</a></div></div><aside class="rbp-res-hero-card"><h3>{{ card_title }}</h3><p>{{ card_text }}</p></aside></div></div></section>
{%- if mode == 'faq' -%}
<section class="rbp-res-sec"><div class="rbp-res-c"><div class="rbp-res-grid rbp-res-g2"><div><div class="rbp-res-ey">FAQ</div><h2 class="rbp-res-h2">Common questions</h2><p class="rbp-res-p">This page is the reusable FAQ display. Once FAQ metaobjects are assigned, they will replace the fallback questions below.</p></div><div class="rbp-res-faq">{%- if faqs != blank -%}{%- for q in faqs -%}{%- assign f=q.fields -%}<details {% if forloop.first %}open{% endif %}><summary>{{ f.question.value }}</summary><div>{{ f.answer | metafield_tag }}</div></details>{%- endfor -%}{%- else -%}<details open><summary>How do document orders work?</summary><div>Customer buys the document, completes onboarding, waits for delivery, reviews the order, then asks for revisions or uses it immediately.</div></details><details><summary>Do I receive documents instantly?</summary><div>No. Document products use an onboarding and delivery process unless a product specifically says otherwise.</div></details><details><summary>How do I contact support?</summary><div>Use the Contact page and include your order number, business name and support area where relevant.</div></details><details><summary>How do I choose a membership plan?</summary><div>Start with Membership Options and compare inclusions. Use the contact form if you need help choosing.</div></details>{%- endif -%}</div></div></div></section>
{%- else -%}
<section class="rbp-res-sec rbp-res-muted"><div class="rbp-res-c"><div class="rbp-res-head"><div class="rbp-res-ey">Content categories</div><h2 class="rbp-res-h2">Browse the consolidated resource library</h2><p class="rbp-res-p">Articles, guides, tools, downloads and educational resources now sit under one clear content system instead of several tiny competing kingdoms.</p></div><div class="rbp-res-grid rbp-res-g5"><a class="rbp-res-card" href="/pages/articles"><div class="rbp-res-icon">AR</div><h3 class="rbp-res-title">Articles</h3><p class="rbp-res-text">Practical explainers and business education content.</p><span class="rbp-res-link">Browse articles -&gt;</span></a><a class="rbp-res-card" href="/pages/guides"><div class="rbp-res-icon">GD</div><h3 class="rbp-res-title">Guides</h3><p class="rbp-res-text">Step-by-step resources and process guidance.</p><span class="rbp-res-link">Browse guides -&gt;</span></a><a class="rbp-res-card" href="/pages/tools"><div class="rbp-res-icon">TL</div><h3 class="rbp-res-title">Tools</h3><p class="rbp-res-text">Checklists, practical tools and support resources.</p><span class="rbp-res-link">Browse tools -&gt;</span></a><a class="rbp-res-card" href="/pages/downloads"><div class="rbp-res-icon">DL</div><h3 class="rbp-res-title">Downloads</h3><p class="rbp-res-text">Downloadable materials and resource files.</p><span class="rbp-res-link">Browse downloads -&gt;</span></a><a class="rbp-res-card" href="/pages/educational"><div class="rbp-res-icon">ED</div><h3 class="rbp-res-title">Educational</h3><p class="rbp-res-text">Learning content for products, services and business topics.</p><span class="rbp-res-link">Browse education -&gt;</span></a></div></div></section>
<section class="rbp-res-sec"><div class="rbp-res-c"><div class="rbp-res-head"><div class="rbp-res-ey">Featured knowledge</div><h2 class="rbp-res-h2">Helpful articles and guidance</h2><p class="rbp-res-p">Assign Help Article metaobjects to this page to replace the fallback cards.</p></div><div class="rbp-res-grid rbp-res-g3">{%- if articles != blank -%}{%- for item in articles limit: 9 -%}{%- assign a=item.fields -%}<a class="rbp-res-card" href="{{ a.primary_cta_link.value | default: '/pages/contact' }}"><div class="rbp-res-icon">{{ forloop.index }}</div><h3 class="rbp-res-title">{{ a.title.value }}</h3><p class="rbp-res-text">{{ a.summary.value }}</p><span class="rbp-res-link">{{ a.primary_cta_label.value | default: 'Read more' }} -&gt;</span></a>{%- endfor -%}{%- else -%}<a class="rbp-res-card" href="/pages/our-process"><div class="rbp-res-icon">01</div><h3 class="rbp-res-title">How document orders work</h3><p class="rbp-res-text">Understand purchase, onboarding, delivery, review and revisions.</p><span class="rbp-res-link">Read guide -&gt;</span></a><a class="rbp-res-card" href="/pages/membership"><div class="rbp-res-icon">02</div><h3 class="rbp-res-title">How membership works</h3><p class="rbp-res-text">Compare member pathways, inclusions and support access.</p><span class="rbp-res-link">View membership -&gt;</span></a><a class="rbp-res-card" href="/pages/business-nbn"><div class="rbp-res-icon">03</div><h3 class="rbp-res-title">How Business NBN works</h3><p class="rbp-res-text">Start with availability, plans, provisioning and support pathways.</p><span class="rbp-res-link">View NBN -&gt;</span></a>{%- endif -%}</div></div></section>
<section class="rbp-res-sec rbp-res-muted"><div class="rbp-res-c"><div class="rbp-res-grid rbp-res-g2"><div class="rbp-res-card rbp-res-blue"><div class="rbp-res-ey">Support hierarchy</div><h2 class="rbp-res-h2">Where each area now belongs</h2><ul class="rbp-res-list"><li><span class="rbp-res-check">✓</span><span>Help Centre is the support hub.</span></li><li><span class="rbp-res-check">✓</span><span>Knowledge Base is the article library.</span></li><li><span class="rbp-res-check">✓</span><span>FAQ is the reusable answer display.</span></li><li><span class="rbp-res-check">✓</span><span>Articles, Guides, Tools, Downloads and Educational are Resource Library categories.</span></li></ul></div><div class="rbp-res-card"><div class="rbp-res-ey">Need support?</div><h2 class="rbp-res-h2">Use the Help Centre first</h2><p class="rbp-res-p">Troubleshooting and Support Centre now route into the Help Centre experience so customers are not sent through duplicate support doors like some terrible office maze.</p><div class="rbp-res-actions"><a class="rbp-res-btn rbp-res-btn-p" href="/pages/help-centre">Go to Help Centre</a><a class="rbp-res-btn rbp-res-btn-o" href="/pages/frequently-asked-questions">View FAQ</a></div></div></div></div></section>
{%- endif -%}
<section class="rbp-res-sec"><div class="rbp-res-c"><div class="rbp-res-cta"><div><h2>Need a clearer answer?</h2><p>Use the Help Centre for support routing or contact us with the details. One clean path beats nine duplicate pages pretending to be strategy.</p></div><div class="rbp-res-actions"><a class="rbp-res-btn rbp-res-btn-g" href="/pages/help-centre">Help Centre</a><a class="rbp-res-btn rbp-res-btn-g" href="/pages/contact">Contact Support</a></div></div></div></section>
</div>
{% schema %}{"name":"RBP resource library","settings":[],"presets":[{"name":"RBP resource library"}]}{% endschema %}