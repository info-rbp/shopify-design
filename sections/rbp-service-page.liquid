t:1.55;font-size:14px}.rbp-service-step{position:relative;padding-left:54px}.rbp-service-step+.rbp-service-step{margin-top:20px}.rbp-service-step-num{position:absolute;top:0;left:0;width:40px;height:40px;border-radius:999px;background:#1d4ed8;color:#fff;display:grid;place-items:center;font-size:12px;font-weight:900}.rbp-service-step h3{margin:0 0 5px;color:#0f172a;font-size:16px;font-weight:900}.rbp-service-step p{margin:0;color:#64748b;line-height:1.65}.rbp-service-panel-blue{background:linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;border:0;box-shadow:var(--sh)}.rbp-service-panel-blue .rbp-service-title,.rbp-service-panel-blue .rbp-service-h2{color:#fff}.rbp-service-panel-blue .rbp-service-text,.rbp-service-panel-blue .rbp-service-p{color:#dbeafe}.rbp-service-faq details{background:#fff;border:1px solid var(--br);border-radius:18px;padding:0 18px}.rbp-service-faq details+details{margin-top:12px}.rbp-service-faq summary{cursor:pointer;padding:18px 0;color:#0f172a;font-weight:900}.rbp-service-faq summary::-webkit-details-marker{display:none}.rbp-service-faq div{padding-bottom:18px;color:#64748b;line-height:1.7}.rbp-service-cta{border-radius:32px;background:radial-gradient(circle at top right,rgba(255,255,255,.18),transparent 35%),linear-gradient(135deg,#1d4ed8,#1e3a8a);color:#fff;padding:clamp(28px,5vw,56px);display:grid;grid-template-columns:minmax(0,1fr) auto;gap:28px;align-items:center}.rbp-service-cta h2{margin:0;color:#fff;font-size:clamp(28px,4vw,48px);line-height:1.06;letter-spacing:-.035em;font-weight:900}.rbp-service-cta p{margin:12px 0 0;color:#dbeafe;line-height:1.7;max-width:760px}@media(max-width:989px){.rbp-service-hero-in,.rbp-service-g2,.rbp-service-g3,.rbp-service-g4,.rbp-service-cta{grid-template-columns:1fr}.rbp-service-hero-card{display:none}.rbp-service-head{text-align:left;margin-inline:0}}@media(max-width:749px){.rbp-service-c{width:min(100% - 2rem,1200px)}.rbp-service-sec{padding:54px 0}.rbp-service-hero-in{padding:68px 0;min-height:auto}